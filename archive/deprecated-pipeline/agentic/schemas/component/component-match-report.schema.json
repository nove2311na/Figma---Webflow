{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentMatchReportSchema",
  "type": "object",
  "required": ["timestamp", "matched_instances", "unmatched_instances", "status", "blockers"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "matched_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["figma_node_id", "figma_node_name", "component_id", "signature_id", "confidence", "matching_notes"],
        "properties": {
          "figma_node_id": {
            "type": "string"
          },
          "figma_node_name": {
            "type": "string"
          },
          "component_id": {
            "type": "string"
          },
          "signature_id": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "matching_notes": {
            "type": "string"
          }
        }
      }
    },
    "unmatched_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["figma_node_id", "figma_node_name", "highest_candidate_component", "highest_confidence", "reason"],
        "properties": {
          "figma_node_id": {
            "type": "string"
          },
          "figma_node_name": {
            "type": "string"
          },
          "highest_candidate_component": {
            "type": ["string", "null"]
          },
          "highest_confidence": {
            "type": "number"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}