{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Missing Mapping Report Schema",
  "type": "object",
  "required": ["resolved_at", "missing_classes", "missing_tokens", "unresolved_elements", "confidence_score", "success"],
  "properties": {
    "resolved_at": { "type": "string", "format": "date-time" },
    "missing_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "class_name", "reason"],
        "properties": {
          "node_id": { "type": "string" },
          "class_name": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "missing_tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "token_name", "raw_value"],
        "properties": {
          "node_id": { "type": "string" },
          "token_name": { "type": "string" },
          "raw_value": { "type": "string" }
        }
      }
    },
    "unresolved_elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "node_name", "reason"],
        "properties": {
          "node_id": { "type": "string" },
          "node_name": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "confidence_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "success": { "type": "boolean" }
  }
}