{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HTML Validation Report Schema",
  "type": "object",
  "required": ["verified_at", "local_html_path", "checks", "failures", "success"],
  "properties": {
    "verified_at": { "type": "string", "format": "date-time" },
    "local_html_path": { "type": "string" },
    "checks": {
      "type": "object",
      "required": ["html_syntax", "class_strictness", "accessibility", "client_first_structure"],
      "properties": {
        "html_syntax": { "type": "boolean" },
        "class_strictness": { "type": "boolean" },
        "accessibility": { "type": "boolean" },
        "client_first_structure": { "type": "boolean" }
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "details"],
        "properties": {
          "node_id": { "type": "string" },
          "rule": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    },
    "success": { "type": "boolean" }
  }
}