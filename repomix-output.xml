<file path="agentic/memory/README.md">
# Agentic Memory

Use this folder for memory candidates and approved memory cards.

Memory promotion requires:

- source,
- date,
- owner,
- validation status,
- reason to persist.

Do not store raw chat transcripts or secrets here.
</file>

<file path="agentic/policies/mcp-config.example.json">
{
  "mcpServers": {
    "webflow": {
      "command": "python",
      "args": ["-m", "configure_webflow_mcp_after_auth"],
      "env": {
        "WEBFLOW_MCP_NOTE": "Replace this example value with an approved Claude Code Webflow MCP command after auth is configured outside the repo."
      }
    }
  }
}
</file>

<file path="agentic/rules/asset-alt.rules.yaml">
asset_alt_policy:
  enforce_alt_text: true
  alt_requirements:
    informative: required
    functional: required
    decorative:
      alt_value: ""
      role: presentation
    complex: required_extended
  forbidden_generic_alts:
    - image
    - logo
    - photo
    - placeholder
</file>

<file path="agentic/rules/class-selection.rules.yaml">
selection_policy:
  strict_mode: true
  missing_class_behavior: block
  allow_inline_style: false
  allow_hardcoded_hex: false
  allow_new_class_proposals: false
  final_class_source:
    - client-first-library-contract
    - webflow-native-class-index
    - structural-conventions

structural_convention_classes:
  - page-wrapper
  - main-wrapper
</file>

<file path="agentic/rules/concurrency-policy.yaml">
concurrency_policy:
  figma_extraction:
    parallel_frames: true
    max_workers: 4
  section_rendering:
    parallel: true
    max_workers: 4
  webflow_mutation:
    parallel: false
    max_workers: 1
</file>

<file path="agentic/rules/html-qa.rules.yaml">
html_qa_rules:
  validate_nesting: true
  validate_attributes: true
  enforce_rem_units: true
  check_data_markers:
    required_attributes:
      - data-section
      - data-component
      - data-figma-node
  forbidden_tags:
    - style
    - font
  forbidden_styles:
    - inline_style
    - hardcoded_hex_colors
</file>

<file path="agentic/rules/retry-policy.yaml">
retry_policy:
  mcp_calls:
    max_retries: 3
    backoff_factor: 2.0
    initial_delay_seconds: 1.0
  network_failures:
    max_retries: 5
    backoff_factor: 1.5
    initial_delay_seconds: 2.0
</file>

<file path="agentic/rules/webflow-mcp.rules.yaml">
webflow_mcp_rules:
  allow_variable_creation: true
  allow_variable_deletion: false
  allow_class_creation: true
  allow_class_deletion: false
  allow_symbol_unlinking: false
  enforce_publish_approval: true
  max_retries_on_rate_limit: 3
  rate_limit_backoff_seconds: 5
</file>

<file path="agentic/schemas/_shared/meta.schema.json">
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://figwebflow.local/schemas/_shared/meta.schema.json",
  "title": "Meta",
  "description": "Provenance + identity for a contract envelope. Every contract carries a meta block.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "extractedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "Contract schema version, semver."
    },
    "source": {
      "type": "string",
      "enum": ["figma", "webflow", "client-first-baseline", "synthesized"],
      "description": "Where this contract's data originated."
    },
    "baseline": {
      "type": "string",
      "description": "Path to the baseline contract this was validated against, if any."
    },
    "projectName": { "type": "string" },
    "workspaceName": { "type": "string" },
    "extractedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the data was extracted."
    },
    "extractedBy": {
      "type": "string",
      "description": "Who/what produced this. e.g. figma-mcp, design-system-sync/task-1, figma-to-html-architect/task-3."
    },
    "nodeId": {
      "type": "string",
      "description": "Figma node id if the contract was produced from a specific Figma node."
    }
  }
}
</file>

<file path="agentic/schemas/_shared/ref-envelope.schema.json">
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://figwebflow.local/schemas/_shared/ref-envelope.schema.json",
  "title": "RefEnvelope",
  "description": "Minimal envelope: meta + data. The LLM fills data entries that match the $ref'd entry schema. additionalProperties:false at every level prevents shape invention.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "data"],
  "properties": {
    "meta": {
      "$ref": "meta.schema.json"
    },
    "data": {
      "type": "object",
      "description": "Payload. Sub-shape defined by the contract that composes this envelope. The composing schema adds 'properties' to data, each $ref'd to a shared entry schema.",
      "additionalProperties": false,
      "properties": {}
    }
  }
}
</file>

<file path="agentic/schemas/_shared/style-entry.schema.json">
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://figwebflow.local/schemas/_shared/style-entry.schema.json",
  "title": "StyleEntry",
  "description": "One Figma text style / Webflow class. Composed into figma-contract and webflow-contract via $ref.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "properties"],
  "properties": {
    "name": { "type": "string" },
    "figmaId": { "type": "string" },
    "webflowId": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["text-style"]
    },
    "mode": {
      "type": ["string", "null"],
      "description": "Legacy: singular mode name. V3.1+ uses modes (plural) on variables. Kept for V3.0 backward compat."
    },
    "figmaStyleName": { "type": "string" },
    "webflowClassName": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["heading", "text", "utility", "combo", "custom"]
    },
    "properties": {
      "type": "object",
      "description": "Style properties. V3.1+ uses {value, unit} objects for sizes. V3.0 legacy templates used strings (often var() references). Both shapes accepted for backward compat.",
      "additionalProperties": false,
      "required": ["font-family", "font-size", "font-weight", "line-height"],
      "properties": {
        "font-family": { "type": "string" },
        "font-size": {
          "oneOf": [
            { "type": "string", "description": "Legacy V3.0: raw value, often a var() reference like 'var(--_typography---font-size--tiny)'." },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit"],
              "properties": {
                "value": { "type": "number" },
                "unit": { "type": "string", "enum": ["rem", "px", "%"] }
              }
            }
          ]
        },
        "font-weight": { "type": ["number", "string"] },
        "line-height": {
          "oneOf": [
            { "type": "string", "description": "Legacy V3.0: raw value like '1.5em' or 'var(--_typography---font-height--xlarge)'." },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "unit"],
              "properties": {
                "value": { "type": "number" },
                "unit": { "type": "string", "enum": ["rem", "px", "%", "unitless", "em"] }
              }
            }
          ]
        },
        "letter-spacing": {
          "oneOf": [
            { "type": "string", "description": "Legacy V3.0: raw value like '0em' or 'var(--_typography---letter-spacing--default)'." },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "value": { "type": "number" },
                "unit": { "type": "string", "enum": ["rem", "px", "em"] }
              }
            }
          ]
        }
      }
    },
    "breakpoints": {
      "type": "object",
      "description": "Per-breakpoint property overrides. Keys: 'main' (desktop), 'medium' (tablet), 'small' (mobile-landscape), 'tiny' (mobile-portrait).",
      "additionalProperties": { "type": "object" }
    },
    "pseudoStates": {
      "type": "object",
      "description": "Per-pseudo-class overrides. Keys: 'hover', 'focus', 'focus-visible', 'active', 'disabled'."
    },
    "matchPolicy": {
      "type": "object",
      "description": "How the Webflow sync matches this style to a Figma source. Used by the validator.",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["property_similarity", "exact_name", "id"] },
        "requiredProperties": { "type": "array", "items": { "type": "string" } },
        "optionalProperties": { "type": "array", "items": { "type": "string" } },
        "minimumConfidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "projectExtension": { "type": "boolean" }
  }
}
</file>

<file path="agentic/schemas/_shared/variable-entry.schema.json">
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://figwebflow.local/schemas/_shared/variable-entry.schema.json",
  "title": "VariableEntry",
  "description": "One design-token variable. Used by Figma and Webflow contracts via $ref. Schema is Figma-first: the Webflow side uses the same shape with aliasOf pointing to the Figma source.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "figmaId", "namespace", "type", "value", "modes"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name. May change across renames. Do NOT use as sync key."
    },
    "figmaId": {
      "type": "string",
      "pattern": "^VariableID:[a-zA-Z0-9_-]+:[0-9]+$",
      "description": "Figma variable id. Stable across renames, machines, people. REQUIRED for cross-machine sync. Pattern: VariableID:<id>:<index>. The id part can be a hex string, a UUID, 'tpl-<hash>' for templates, or 'example-<slug>' for documentation."
    },
    "webflowId": {
      "type": "string",
      "description": "Webflow variable id once synced. Set by the write step, not the producer."
    },
    "type": {
      "type": "string",
      "enum": [
        "color",
        "font-family",
        "font-size",
        "font-weight",
        "line-height",
        "letter-spacing",
        "spacing",
        "size",
        "border-radius",
        "border-width",
        "alias",
        "number",
        "string",
        "boolean"
      ]
    },
    "namespace": {
      "type": "string",
      "enum": [
        "_theme",
        "_typography",
        "_sizes",
        "_layout",
        "_focus",
        "_brand",
        "_neutral",
        "_font-weight",
        "other"
      ],
      "description": "Webflow CSS variable namespace. The user's CSS uses --_theme---*, --_typography---*, --_sizes---*, etc. Pick the closest match; use 'other' if no good fit."
    },
    "value": {
      "description": "Primary mode value. Flattened from valuesByMode[default] in Figma. Type matches the 'type' field — string for colors, number for sizes, etc."
    },
    "modes": {
      "type": "object",
      "description": "mode_id → value. e.g. { 'default': '#000', 'dark': '#fff' }. Keys are normalized: 'default' for the primary mode, 'dark' for the dark theme, etc. Raw Figma keys like 'Mode 1:1' must be normalized before this point. At minimum, the 'default' key is required.",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "unit": {
      "type": ["string", "null"],
      "description": "CSS unit if applicable. Allowed: 'rem', 'px' (1px borders only), '%'. Process rejects em/vh/vw/pt per CLAUDE.md."
    },
    "aliasOf": {
      "type": ["string", "null"],
      "description": "Figma variable id this aliases, if type='alias'. Required for alias chains like var(--_theme---text-color--primary) = var(--neutral--black)."
    },
    "mode": {
      "type": ["string", "null"],
      "description": "Legacy: singular mode name. V3.1+ uses `modes` (plural object). Kept for backward compat with V3.0 templates. New producers should emit `modes` and omit `mode`."
    },
    "figmaName": {
      "type": ["string", "null"],
      "description": "Legacy: Figma display name. The contract top-level key is the canonical name now. Kept for V3.0 round-trip templates."
    },
    "webflowName": {
      "type": ["string", "null"],
      "description": "Legacy: Webflow display name. The contract top-level key is the canonical name now. Kept for V3.0 round-trip templates."
    },
    "updatePolicy": {
      "type": ["string", "null"],
      "description": "Legacy: V3.0 update policy values. V3.1+ uses an enum {create, update, skip, delete}. Legacy values (update_value_only, etc.) are still accepted for backward compat."
    },
    "collection": {
      "type": ["string", "null"],
      "description": "Legacy: Figma collection name (e.g. 'Layout', 'Typography'). Kept for backward compat with V3.0 templates. New producers should derive from namespace instead."
    },
    "resolvedValue": {
      "type": ["string", "number", "boolean", "null"],
      "description": "Legacy: pre-computed value with units applied. Kept for V3.0 templates where value + unit were kept separate. New producers should put the resolved value in `value` and use `m.default` for the primary mode."
    },
    "source": {
      "type": "object",
      "description": "Provenance of this variable.",
      "additionalProperties": false,
      "properties": {
        "selector": { "type": "string" },
        "property": { "type": "string" },
        "collection": { "type": "string" }
      }
    },
    "editableInFigma": { "type": "boolean", "default": true },
    "syncPolicy": {
      "type": "string",
      "enum": ["push", "pull", "manual", "ignore"],
      "description": "How this variable should sync between Figma and Webflow."
    },
    "projectExtension": {
      "type": "boolean",
      "description": "True if this variable is project-specific (not from the Client-First baseline). Required for the baseline contract to allow non-baseline variables."
    }
  }
}
</file>

<file path="agentic/schemas/library/client-first-library.schema.json">
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
