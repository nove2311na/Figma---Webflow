import yaml
d = yaml.safe_load(open('knowledge-base/client-first/INDEX.yaml'))
mine = [e for e in d['entries'] if 'design-system-sync' in e.get('applicable_skill',[])]
for e in mine[:5]: print(f\"  - {e['file_path']}  [tags: {e['topic_tags']}]\")
