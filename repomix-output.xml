        baseline_file = self.ds_dir / "test-baseline.json"
        baseline_file.write_text(json.dumps(baseline_data), encoding="utf-8")

        # Also add them to the Webflow contract to simulate them being in the stylesheet
        wf_contract = {
            "variables": {},
