 1: #!/usr/bin/env python3
 2: """Deterministic quality gate for Semantic IR and Class Selection."""
 3: from __future__ import annotations
 4: 
 5: import json
 6: import sys
 7: from pathlib import Path
 8: 
 9: def validate_semantic_ir(root: Path) -> list[str]:
10:     failures = []
11:     semantic_tree_path = root / "workspace" / "semantic" / "figma.semantic-tree.json"
12:     missing_report_path = root / "workspace" / "reports" / "missing-mapping-report.json"
13: 
14:     if not semantic_tree_path.exists():
15:         failures.append("Semantic IR tree file is missing.")
16:         return failures
17:     if not missing_report_path.exists():
18:         failures.append("Missing mapping report is missing.")
19:         return failures
20: 
21:     try:
22:         tree = json.loads(semantic_tree_path.read_text(encoding="utf-8"))
23:     except Exception as e:
24:         failures.append(f"Failed to parse semantic tree JSON: {e}")
25:         return failures
26: 
27:     try:
28:         report = json.loads(missing_report_path.read_text(encoding="utf-8"))
29:     except Exception as e:
30:         failures.append(f"Failed to parse missing mapping report JSON: {e}")
31:         return failures
32: 
33:     if not report.get("success", False):
34:         failures.append("Missing mapping report indicates FAILURE.")
35: 
36:     confidence = report.get("confidence_score", 0.0)
37:     if confidence < 0.60:
38:         failures.append(f"Semantic resolver confidence score {confidence} is below strict threshold 0.60")
39: 
40:     missing_classes = report.get("missing_classes", [])
41:     if missing_classes:
42:         for mc in missing_classes:
43:             failures.append(f"Missing class mapping on node '{mc.get('node_id')}': {mc.get('class_name')} - {mc.get('reason')}")
44: 
45:     # Schema check
46:     for key in ("node_id", "name", "semantic_tree", "metadata"):
47:         if key not in tree:
48:             failures.append(f"Semantic tree missing key: {key}")
49: 
50:     return failures
51: 
