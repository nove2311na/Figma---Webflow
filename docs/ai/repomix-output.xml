  1: #!/usr/bin/env python3
  2: """Run benchmarking suite on clean, messy, and broken fixtures to verify compiler quality."""
  3: from __future__ import annotations
  4: 
  5: import json
  6: import subprocess
  7: import sys
  8: from pathlib import Path
  9: 
 10: def run_cmd(args: list[str]) -> tuple[int, str, str]:
 11:     res = subprocess.run(
 12:         [sys.executable] + args,
 13:         capture_output=True,
 14:         text=True,
 15:         encoding="utf-8"
 16:     )
 17:     return res.returncode, res.stdout, res.stderr
 18: 
 19: def run_benchmarks(root: Path) -> dict:
 20:     results = {
 21:         "tag_resolver_accuracy": 0.0,
 22:         "invented_classes_count": 0,
 23:         "broken_fixtures_failed_correctly": True,
 24:         "details": []
 25:     }
 26: 
 27:     # Temporary directory for benchmark runs inside workspace/
 28:     bench_dir = root / "workspace" / "benchmarks"
 29:     bench_dir.mkdir(parents=True, exist_ok=True)
 30: 
 31:     # 1. Clean hero fixture compilation
 32:     code, stdout, stderr = run_cmd([
 33:         "scripts/pipeline/normalize_figma_nodes.py",
 34:         "--input", "tests/fixtures/figma/hero-clean.json",
 35:         "--output", str(bench_dir / "hero-clean.normalized.json"),
 36:         "--report", str(bench_dir / "hero-clean.norm-report.json")
 37:     ])
 38:     
 39:     if code != 0:
 40:         results["details"].append(f"hero-clean normalization failed: {stderr}")
 41:     else:
 42:         code, stdout, stderr = run_cmd([
 43:             "scripts/pipeline/resolve_semantic_ir.py",
 44:             "--input", str(bench_dir / "hero-clean.normalized.json"),
 45:             "--output", str(bench_dir / "hero-clean.semantic.json"),
 46:             "--reports-dir", str(bench_dir)
 47:         ])
 48:         if code != 0:
 49:             results["details"].append(f"hero-clean semantic resolution failed: {stderr}")
 50:         else:
 51:             # Check accuracy on clean
 52:             sem_data = json.loads((bench_dir / "hero-clean.semantic.json").read_text(encoding="utf-8"))
 53:             tree = sem_data.get("semantic_tree", {})
 54:             
 55:             # Retrieve tags recursively
 56:             tags = {}
 57:             def collect_tags(node):
 58:                 tags[node.get("name")] = node.get("tag")
 59:                 for child in node.get("children", []):
 60:                     collect_tags(child)
 61:             collect_tags(tree)
 62:             
 63:             # Expected mappings
 64:             expected_tags = {
 65:                 "[section] Hero Clean": "section",
 66:                 "Hero Title": "h1",
 67:                 "Hero Paragraph": "p",
 68:                 "CTA Button": "a"
 69:             }
 70:             
 71:             matches = 0
 72:             for name, tag in expected_tags.items():
 73:                 if tags.get(name) == tag:
 74:                     matches += 1
 75:             accuracy = matches / len(expected_tags) if expected_tags else 0.0
 76:             results["tag_resolver_accuracy"] = accuracy
 77:             results["details"].append(f"Clean Hero Tag Resolver Accuracy: {accuracy * 100:.1f}%")
 78: 
 79:     # 2. Check for invented classes
 80:     if (bench_dir / "hero-clean.semantic.json").exists():
 81:         sem_data = json.loads((bench_dir / "hero-clean.semantic.json").read_text(encoding="utf-8"))
 82:         contract_data = json.loads((root / "knowledge-base" / "generated" / "client-first-library-contract.json").read_text(encoding="utf-8"))
 83:         allowed = set(contract_data.get("allowed_classes", [])) | set(contract_data.get("allowed_combo_classes", [])) | set(contract_data.get("structural_convention_classes", []))
 84: 
 85:         invented = []
 86:         def check_classes(node):
 87:             for cls in node.get("classes", []):
 88:                 if cls not in allowed and not cls.startswith("w-"):
 89:                     invented.append(cls)
 90:             for child in node.get("children", []):
 91:                 check_classes(child)
 92:         check_classes(sem_data.get("semantic_tree", {}))
 93:         results["invented_classes_count"] = len(invented)
 94:         if invented:
 95:             results["details"].append(f"Invented classes found: {invented}")
 96: 
 97:     # 3. Broken fixtures check
 98:     broken_checks = [
 99:         ("tests/fixtures/broken/missing-class.json", "class_name"),
100:         ("tests/fixtures/broken/hardcoded-hex.json", "untokenized color")
101:     ]
102:     
103:     for path, expected_err_keyword in broken_checks:
104:         # Step 1: Normalize
105:         norm_out = bench_dir / "broken.normalized.json"
106:         norm_rep = bench_dir / "broken.norm-report.json"
107:         code, stdout, stderr = run_cmd([
108:             "scripts/pipeline/normalize_figma_nodes.py",
109:             "--input", path,
110:             "--output", str(norm_out),
111:             "--report", str(norm_rep)
112:         ])
113:         
114:         # If normalizer passed, run resolver
115:         if code == 0:
116:             code, stdout, stderr = run_cmd([
117:                 "scripts/pipeline/resolve_semantic_ir.py",
118:                 "--input", str(norm_out),
119:                 "--output", str(bench_dir / "broken.semantic.json"),
120:                 "--reports-dir", str(bench_dir)
121:             ])
122:             
123:         # Check if compilation failed as expected
124:         if code == 0:
125:             results["broken_fixtures_failed_correctly"] = False
126:             results["details"].append(f"Fixture {path} compiled successfully but was expected to fail.")
127:         else:
128:             results["details"].append(f"Fixture {path} failed correctly as expected (code: {code}).")
129: 
130:     return results
131: 
132: def main() -> int:
133:     root = Path(__file__).resolve().parents[3]
134:     
135:     print("Running resolver benchmarks...")
136:     bench_results = run_benchmarks(root)
137:     
138:     print("\nBenchmark Results:")
139:     print(f"  Tag Resolver Accuracy: {bench_results['tag_resolver_accuracy'] * 100:.1f}% (target: >=95%)")
140:     print(f"  Invented Classes Count: {bench_results['invented_classes_count']} (target: 0)")
141:     print(f"  Broken Fixtures Failed Correctly: {bench_results['broken_fixtures_failed_correctly']}")
142:     
143:     passed = (
144:         bench_results["tag_resolver_accuracy"] >= 0.95 and
145:         bench_results["invented_classes_count"] == 0 and
146:         bench_results["broken_fixtures_failed_correctly"]
147:     )
148:     
149:     print(f"\nOverall Benchmark Verdict: {'PASS' if passed else 'FAIL'}")
150:     for detail in bench_results["details"]:
151:         print(f"  - {detail}")
152: 
153:     # Save benchmark report
154:     report_path = root / "workspace" / "reports" / "resolver-benchmark-report.json"
155:     report_path.write_text(json.dumps(bench_results, indent=2), encoding="utf-8")
156:     
157:     return 0 if passed else 1
158: 
159: if __name__ == "__main__":
160:     sys.exit(main())
