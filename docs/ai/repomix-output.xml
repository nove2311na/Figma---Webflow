 38: def resolve_library(target: Path, site_id: str) -> Path:
 39:     """Return path to client-first-library.json for site_id.
 40: 
 41:     Raises FileNotFoundError when the project is not registered.
 42:     """
 43:     registry = load_registry(target)
 44:     for project in registry.get("projects", []):
 45:         if project.get("webflow_site_id") == site_id:
 46:             lib_path = target / project["library_path"]
 47:             return lib_path
 48:     raise FileNotFoundError(f"site_id '{site_id}' not found in registry")
 49: 
 50: 
 51: def load_library(target: Path, site_id: str) -> dict[str, Any]:
 52:     """Load client-first-library.json for site_id."""
 53:     lib_path = resolve_library(target, site_id)
 54:     return json.loads(lib_path.read_text(encoding="utf-8"))
