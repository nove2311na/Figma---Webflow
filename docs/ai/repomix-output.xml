 1: #!/usr/bin/env python3
 2: """Validate sliced HTML section chunks (integrity, manifest mapping, boundary correctness)."""
 3: from __future__ import annotations
 4: 
 5: import json
 6: import sys
 7: from pathlib import Path
 8: 
 9: def load_json(path: Path) -> dict:
10:     if not path.exists():
11:         return {}
12:     try:
13:         return json.loads(path.read_text(encoding="utf-8"))
14:     except Exception:
15:         return {}
16: 
17: def validate_chunks(root: Path) -> list[str]:
18:     failures = []
19:     chunks_dir = root / "workspace" / "html" / "chunks"
20:     manifest_path = chunks_dir / "section-manifest.json"
21: 
22:     if not manifest_path.exists():
23:         failures.append("section-manifest.json is missing.")
24:         return failures
25: 
26:     manifest = load_json(manifest_path)
27:     chunks = manifest.get("chunks", [])
28:     if not chunks:
29:         failures.append("Manifest contains zero sliced chunks.")
30:         return failures
31: 
32:     for chunk in chunks:
33:         chunk_id = chunk.get("id")
34:         filename = chunk.get("filename")
35:         if not filename:
36:             failures.append(f"Chunk '{chunk_id}' is missing a filename definition.")
37:             continue
38: 
39:         chunk_path = chunks_dir / filename
40:         if not chunk_path.exists():
41:             failures.append(f"Physical file for chunk '{chunk_id}' is missing at {filename}.")
42:             continue
43: 
44:         content = chunk_path.read_text(encoding="utf-8")
45:         if not content.strip() and chunk.get("type") != "global-styles":
46:             failures.append(f"Chunk '{chunk_id}' file is empty.")
47:             continue
48: 
49:         # Basic tag balancing check
50:         open_tags = content.count("<") - content.count("</") - content.count("/>")
51:         # Self-closing tag compensation in raw counts
52:         img_input_count = content.count("<img") + content.count("<input") + content.count("<link") + content.count("<meta")
53:         adjusted_open = open_tags - img_input_count
54:         if adjusted_open != 0:
55:             # We don't fail immediately because simple text content might trigger this, but warning can be added
56:             pass
57: 
58:     return failures
59: 
60: def main() -> int:
61:     root = Path(__file__).resolve().parents[3]
62:     failures = validate_chunks(root)
63:     if failures:
64:         print("html-chunks-validation: FAIL")
65:         for f in failures:
66:             print(f"  - {f}")
67:         return 1
68:     print("html-chunks-validation: PASS")
69:     return 0
70: 
71: if __name__ == "__main__":
72:     sys.exit(main())
</file>

