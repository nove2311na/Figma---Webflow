 1: #!/usr/bin/env python3
 2: """Validate generated workspace artifacts when a workspace exists."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import json
 7: from pathlib import Path
 8: from typing import Any
 9: 
10: 
11: REQUIRED_REACT_FIELDS = ("reason", "action", "observation", "next_decision")
12: CORE_FILES = ("meta.json", "page_structure.json", "state.json", "error-logs.json")
13: 
14: 
15: def load_json(path: Path) -> Any:
16:     return json.loads(path.read_text(encoding="utf-8"))
17: 
18: 
19: def require_keys(payload: dict[str, Any], keys: tuple[str, ...], path: Path, failures: list[str]) -> None:
20:     for key in keys:
21:         if key not in payload or payload[key] in ("", None):
22:             failures.append(f"{path.as_posix()} missing {key}")
23: 
24: 
25: def validate_state_entries(entries: Any, path: Path) -> list[str]:
26:     failures: list[str] = []
27:     if not isinstance(entries, list):
28:         return [f"{path.as_posix()} must be a list"]
29: 
30:     for index, entry in enumerate(entries):
31:         if not isinstance(entry, dict):
32:             failures.append(f"{path.as_posix()} entry {index} must be an object")
33:             continue
34:         require_keys(entry, ("agent", "phase", "type", "message"), path, failures)
35:         entry_type = str(entry.get("type", "")).lower()
36:         phase = str(entry.get("phase", "")).lower()
37:         if "webflow" in entry_type or phase == "phase_2_webflow_build":
38:             missing = [field for field in REQUIRED_REACT_FIELDS if not str(entry.get(field, "")).strip()]
39:             if missing:
40:                 failures.append(f"{path.as_posix()} entry {index} missing ReAct fields: {', '.join(missing)}")
41:     return failures
42: 
43: 
44: def validate_workspace(root: Path) -> list[str]:
45:     workspace = root / "workspace"
46:     if not workspace.exists():
47:         return []
48: 
49:     failures: list[str] = []
50:     for filename in CORE_FILES:
51:         path = workspace / filename
52:         if not path.is_file():
53:             failures.append(f"workspace/{filename} is missing")
54: 
55:     for path in workspace.rglob("*.json"):
56:         try:
57:             payload = load_json(path)
58:         except (OSError, json.JSONDecodeError) as error:
59:             failures.append(f"{path.as_posix()} invalid JSON: {error}")
60:             continue
61: 
62:         if path.name == "meta.json" and isinstance(payload, dict):
63:             require_keys(payload, ("projectName", "figmaUrl", "initializedAt", "runtime"), path, failures)
64:         if path.name == "state.json":
65:             failures.extend(validate_state_entries(payload, path))
66:         if path.name == "error-logs.json" and not isinstance(payload, list):
67:             failures.append(f"{path.as_posix()} must be a list")
68:     return failures
69: 
70: 
71: def main(argv: list[str] | None = None) -> int:
72:     parser = argparse.ArgumentParser(description=__doc__)
73:     parser.add_argument("--target", default=".", help="Folder to validate")
74:     args = parser.parse_args(argv)
75: 
76:     failures = validate_workspace(Path(args.target).resolve())
77:     if failures:
78:         print("workspace artifact gate: fail")
79:         for failure in failures:
80:             print(f"  - {failure}")
81:         return 1
82:     print("workspace artifact gate: pass")
83:     return 0
84: 
85: 
86: if __name__ == "__main__":
87:     raise SystemExit(main())
</file>

