<file path="scripts/archive_workspace.py">
 1: #!/usr/bin/env python3
 2: """Archive the workspace and wipe it only after zip validation."""
 3: from __future__ import annotations
 4: 
 5: import json
 6: import re
 7: import shutil
 8: import zipfile
 9: from datetime import datetime, timezone
10: from pathlib import Path
11: 
12: 
13: ROOT = Path(__file__).resolve().parents[1]
14: WORKSPACE_DIR = ROOT / "workspace"
15: ARCHIVES_DIR = ROOT / "archives"
16: 
17: 
18: def safe_name(value: str) -> str:
19:     """Return a filesystem-safe archive name part."""
20:     return re.sub(r"[^a-zA-Z0-9_-]+", "_", value).strip("_") or "unknown_project"
21: 
22: 
23: def project_name() -> str:
24:     """Read project name from workspace metadata."""
25:     meta_path = WORKSPACE_DIR / "meta.json"
26:     if not meta_path.exists():
27:         return "unknown_project"
28:     try:
29:         data = json.loads(meta_path.read_text(encoding="utf-8"))
30:     except json.JSONDecodeError:
31:         return "unknown_project"
32:     return safe_name(str(data.get("projectName", "unknown_project")))
33: 
34: 
35: def archive_workspace() -> Path | None:
36:     """Create an archive and clear the workspace after validation."""
37:     if not WORKSPACE_DIR.exists():
38:         print("workspace directory does not exist; nothing to archive")
39:         return None
40: 
41:     ARCHIVES_DIR.mkdir(parents=True, exist_ok=True)
42:     timestamp = datetime.now(timezone.utc).isoformat().replace(":", "-").replace(".", "-")
43:     archive_path = ARCHIVES_DIR / f"{project_name()}_{timestamp}.zip"
44: 
45:     with zipfile.ZipFile(archive_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
46:         for path in WORKSPACE_DIR.rglob("*"):
47:             if path.is_file():
48:                 archive.write(path, path.relative_to(WORKSPACE_DIR))
49: 
50:     if not archive_path.exists() or archive_path.stat().st_size <= 0:
51:         raise RuntimeError("archive validation failed; workspace was not deleted")
52: 
53:     shutil.rmtree(WORKSPACE_DIR)
54:     WORKSPACE_DIR.mkdir(parents=True)
55:     return archive_path
56: 
57: 
58: def main() -> int:
59:     archive_path = archive_workspace()
60:     if archive_path:
61:         print(f"workspace archived: {archive_path}")
62:         print("workspace wiped and recreated empty")
63:     return 0
64: 
65: 
66: if __name__ == "__main__":
67:     raise SystemExit(main())
