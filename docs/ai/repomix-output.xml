 53: class ClientFirstResolver:
 54:     def __init__(self, tag_rules: dict[str, Any], class_rules: dict[str, Any], contract: dict[str, Any], var_index: dict[str, Any]):
 55:         self.tag_rules = tag_rules.get("tag_resolution", {})
 56:         self.class_rules = class_rules.get("selection_policy", {})
 57:         self.contract = contract
 58:         self.var_index = var_index
 59:         
 60:         self.allowed_classes = set(contract.get("allowed_classes", []))
 61:         self.allowed_combo_classes = set(contract.get("allowed_combo_classes", []))
 62:         self.structural_classes = set(contract.get("structural_convention_classes", ["page-wrapper", "main-wrapper", "padding-global", "container-large"]))
 63:         self.reserved_classes = set(contract.get("reserved_webflow_classes", []))
 64:         self.allowed_variables = set(contract.get("allowed_variables", []))
 65: 
 66:         # Build color variable cache for snapping
 67:         self.color_vars = {}
 68:         for var_name in self.allowed_variables:
 69:             val = resolve_variable(var_name, self.var_index)
 70:             if val:
 71:                 parsed = parse_color(val)
 72:                 if parsed:
 73:                     self.color_vars[var_name] = val
 74: 
 75:         self.missing_classes = []
 76:         self.missing_tokens = []
 77:         self.warnings = []
 78:         
 79:         self.stats = {
 80:             "nodes_resolved": 0,
 81:             "classes_mapped": 0,
 82:             "colors_snapped": 0,
 83:             "spacings_mapped": 0
 84:         }
 85: 
 86:     def snap_color(self, raw_color: str) -> str:
 87:         """Find the closest CSS variable for a raw color hex or rgb string."""
 88:         if not raw_color:
 89:             return ""
 90:         if raw_color.startswith("var("):
 91:             return raw_color
 92:             
 93:         parsed_raw = parse_color(raw_color)
 94:         if not parsed_raw:
 95:             return raw_color
 96: 
 97:         closest_var = None
 98:         min_dist = float("inf")
 99:         for var_name, var_raw in self.color_vars.items():
100:             dist = color_distance(raw_color, var_raw)
101:             if dist < min_dist:
102:                 min_dist = dist
103:                 closest_var = var_name
104: 
105:         threshold = 15.0  # snapping threshold
106:         if closest_var and min_dist <= threshold:
107:             self.stats["colors_snapped"] += 1
108:             return f"var({closest_var})"
109:             
110:         return raw_color
111: 
112:     def infer_tag_and_role(self, node: dict[str, Any], parent_tag: str | None = None) -> tuple[str, str]:
113:         """Infer HTML tag and semantic role from node metadata."""
114:         node_name = node.get("name", "").lower()
115:         node_type = node.get("type", "FRAME").upper()
116:         
117:         tag = "div"
118:         role = "structure"
119:         
120:         # Explicit tag markup in node name, e.g. [section]
121:         prefix_match = re.match(r"^\[([a-z0-9]+)\]", node.get("name", ""))
122:         if prefix_match:
123:             tag = prefix_match.group(1)
124:             role = f"custom-{tag}"
125:             return tag, role
126:             
127:         if "section" in node_name:
128:             tag = "section"
129:             role = "section"
130:         elif "container" in node_name:
131:             tag = "div"
132:             role = "container"
133:         elif "heading" in node_name or "title" in node_name:
134:             tag = "h2"
135:             role = "heading-2"
136:             if "h1" in node_name:
137:                 tag = "h1"
138:                 role = "heading-1"
139:             elif "h3" in node_name:
140:                 tag = "h3"
141:                 role = "heading-3"
142:         elif node_type == "TEXT":
143:             tag = "p"
144:             role = "paragraph"
145:             if "paragraph" not in node_name and ("title" in node_name or "heading" in node_name):
146:                 tag = "h2"
147:                 role = "heading-2"
148:         elif "button" in node_name or "cta" in node_name:
149:             tag = "a"
150:             role = "button"
151:             
152:         if parent_tag in ("ul", "ol"):
153:             tag = "li"
154:             role = "list-item"
155:             
156:         return tag, role
157: 
158:     def map_styles_to_classes(self, node: dict[str, Any], tag: str, role: str) -> list[str]:
159:         """Convert inline styled spacing, colors, and layout metrics into Finsweet classes."""
160:         classes = []
161:         styles = node.get("styles", {})
162:         node_name = node.get("name", "").lower()
163:         
164:         # 1. Padding & Spacing mapping to Finsweet utility classes
165:         padding_left = styles.get("padding-left", "")
166:         padding_right = styles.get("padding-right", "")
167:         if padding_left and padding_right:
168:             try:
169:                 pl_px = float(padding_left.replace("px", ""))
170:                 pr_px = float(padding_right.replace("px", ""))
171:                 if 20 <= pl_px <= 80 and 20 <= pr_px <= 80:
172:                     classes.append("padding-global")
173:                     self.stats["spacings_mapped"] += 1
174:             except ValueError:
175:                 pass
176: 
177:         padding_top = styles.get("padding-top", "")
178:         padding_bottom = styles.get("padding-bottom", "")
179:         if padding_top and padding_bottom:
180:             try:
181:                 pt_px = float(padding_top.replace("px", ""))
182:                 pb_px = float(padding_bottom.replace("px", ""))
183:                 if pt_px >= 100 or pb_px >= 100:
184:                     classes.append("padding-section-large")
185:                     self.stats["spacings_mapped"] += 1
186:                 elif pt_px >= 60 or pb_px >= 60:
187:                     classes.append("padding-section-medium")
188:                     self.stats["spacings_mapped"] += 1
189:                 elif pt_px >= 30 or pb_px >= 30:
190:                     classes.append("padding-section-small")
191:                     self.stats["spacings_mapped"] += 1
192:             except ValueError:
193:                 pass
194: 
195:         # 2. Sizing containers
196:         if role == "container" or "container" in node_name:
197:             classes.append("container-large")
198:             
199:         # 3. Typography styles
200:         if tag.startswith("h") and len(tag) == 2:
201:             classes.append(f"heading-style-{tag}")
202:             
203:         # 4. Button styles
204:         if role == "button" or tag == "a":
205:             classes.append("button")
206:             
207:         # 5. Snap colors
208:         if "color" in styles:
209:             styles["color"] = self.snap_color(styles["color"])
210:         if "background-color" in styles:
211:             styles["background-color"] = self.snap_color(styles["background-color"])
212:             
213:         # Clean mapped classes through the contract
214:         verified_classes = []
215:         for cls in classes:
216:             is_valid = (
217:                 cls in self.allowed_classes or
218:                 cls in self.allowed_combo_classes or
219:                 cls in self.structural_classes or
220:                 cls in self.reserved_classes or
221:                 cls.startswith("w-")
222:             )
223:             if is_valid:
224:                 verified_classes.append(cls)
225:                 self.stats["classes_mapped"] += 1
226:             else:
227:                 self.missing_classes.append({
228:                     "node_id": node.get("id"),
229:                     "class_name": cls,
230:                     "reason": f"Class '{cls}' mapped but not found in Client-First contract."
231:                 })
232:                 if not self.class_rules.get("selection_policy", {}).get("strict_mode", True):
233:                     verified_classes.append(cls)
234:                     
235:         return verified_classes
236: 
237:     def resolve_node(self, node: dict[str, Any], parent_tag: str | None = None) -> dict[str, Any]:
238:         """Recursively process blueprint nodes into semantic tree nodes."""
239:         node_id = node.get("id", "unknown")
240:         node_name = node.get("name", "")
241:         node_type = node.get("type", "FRAME")
242:         
243:         # 1. Infer tag & role
244:         tag, role = self.infer_tag_and_role(node, parent_tag)
245:         self.stats["nodes_resolved"] += 1
246:         
247:         # 2. Map styling to class list
248:         classes = self.map_styles_to_classes(node, tag, role)
249:         
250:         # 3. Handle media alt attributes if tag is image
251:         media = {}
252:         if tag == "img":
253:             media = {
254:                 "kind": "image",
255:                 "role": "informative",
256:                 "alt_policy": "required",
257:                 "alt_text": node_name,
