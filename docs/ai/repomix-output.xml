168:         return resolved
169: 
170:     def resolve_node(self, node: dict[str, Any], parent_tag: str | None = None) -> dict[str, Any]:
171:         node_id = node.get("id", "unknown")
172:         
173:         # tag and role resolution
174:         role, tag, confidence = self.infer_role_and_tag(node, parent_tag)
175:         self.stats["resolved_nodes"] += 1
176:         self.stats["confidence_sum"] += confidence
177: 
178:         # Class verification
179:         resolved_classes = self.resolve_classes(node_id, node.get("classes", []))
180: 
181:         # Media resolution (Phase 9 placeholder, populated deterministically)
182:         media = {}
183:         if tag == "img" or node.get("ambiguous_media"):
184:             media_role = "decorative" if "decorative" in node.get("name", "").lower() else "informative"
185:             media = {
186:                 "kind": node.get("media_kind", "image"),
187:                 "role": media_role,
188:                 "alt_policy": "required" if media_role == "informative" else "decorative",
189:                 "alt_text": "Decorative image" if media_role == "decorative" else node.get("name", "Asset image"),
190:                 "asset_ref": f"assets/{node_id}.png"
191:             }
192: 
193:         # Resolve children
194:         resolved_children = []
195:         for child in node.get("children", []):
196:             resolved_children.append(self.resolve_node(child, parent_tag=tag))
197: 
198:         return {
199:             "id": node_id,
200:             "name": node.get("name", ""),
201:             "type": node.get("type", "FRAME"),
202:             "role": role,
203:             "tag": tag,
204:             "classes": resolved_classes,
205:             "styles": node.get("styles", {}),
206:             "media": media,
207:             "children": resolved_children
208:         }
209: 
210: def main():
211:     parser = argparse.ArgumentParser(description="Resolve Semantic IR tag and class choices")
212:     parser.add_argument("--input", default="workspace/figma/figma.normalized-tree.json")
213:     parser.add_argument("--output", default="workspace/semantic/figma.semantic-tree.json")
214:     parser.add_argument("--tag-rules", default="agentic/rules/tag.rules.yaml")
215:     parser.add_argument("--class-rules", default="agentic/rules/class-selection.rules.yaml")
216:     parser.add_argument("--contract", default="knowledge-base/generated/client-first-library-contract.json")
217:     parser.add_argument("--reports-dir", default="workspace/reports")
218:     args = parser.parse_args()
219: 
220:     input_path = Path(args.input)
221:     output_path = Path(args.output)
222:     tag_rules_path = Path(args.tag_rules)
223:     class_rules_path = Path(args.class_rules)
224:     contract_path = Path(args.contract)
225:     reports_dir = Path(args.reports-dir) if hasattr(args, "reports-dir") else Path(args.reports_dir)
226: 
227:     # Load resources
228:     norm_tree_payload = load_json(input_path)
229:     
230:     # Rules parsing helper
231:     import yaml
232:     tag_rules = {}
233:     if tag_rules_path.exists():
234:         try:
235:             tag_rules = yaml.safe_load(tag_rules_path.read_text(encoding="utf-8"))
236:         except Exception:
237:             tag_rules = {}
238:     class_rules = {}
239:     if class_rules_path.exists():
240:         try:
241:             class_rules = yaml.safe_load(class_rules_path.read_text(encoding="utf-8"))
242:         except Exception:
243:             class_rules = {}
244: 
245:     contract = load_json(contract_path)
246: 
247:     if not norm_tree_payload:
248:         print(f"Error: Input normalized tree {input_path} empty or missing.")
249:         sys.exit(1)
250: 
251:     resolver = SemanticResolver(tag_rules, class_rules, contract)
252:     
253:     # Process
254:     normalized_tree = norm_tree_payload.get("normalized_tree", {})
255:     semantic_tree = resolver.resolve_node(normalized_tree)
256: 
257:     # Calculate global metrics
258:     node_count = resolver.stats["resolved_nodes"]
259:     avg_confidence = resolver.stats["confidence_sum"] / node_count if node_count > 0 else 0.0
260: 
261:     # Strict compliance validation
262:     success = True
263:     if avg_confidence < 0.60:
264:         success = False
265:         resolver.unresolved_elements.append({
266:             "node_id": semantic_tree.get("id"),
267:             "node_name": semantic_tree.get("name"),
268:             "reason": f"Global resolver confidence average {avg_confidence:.2f} is below strict threshold 0.60"
269:         })
270: 
271:     # Blocker check
272:     if len(resolver.missing_classes) > 0 and class_rules.get("selection_policy", {}).get("missing_class_behavior", "block") == "block":
273:         success = False
274: 
275:     # Output files
276:     output_payload = {
277:         "node_id": norm_tree_payload.get("node_id", "unknown"),
278:         "name": norm_tree_payload.get("name", "unknown"),
279:         "semantic_tree": semantic_tree,
280:         "metadata": {
281:             "resolved_at": datetime.now(timezone.utc).isoformat(),
282:             "resolver_version": "1.0.0",
283:             "confidence_score": round(avg_confidence, 3)
284:         }
285:     }
286: 
287:     missing_report = {
288:         "resolved_at": datetime.now(timezone.utc).isoformat(),
289:         "missing_classes": resolver.missing_classes,
290:         "missing_tokens": resolver.missing_tokens,
291:         "unresolved_elements": resolver.unresolved_elements,
292:         "confidence_score": round(avg_confidence, 3),
293:         "success": success
294:     }
295: 
296:     tag_report = {
297:         "resolved_at": datetime.now(timezone.utc).isoformat(),
298:         "nodes_resolved": node_count,
299:         "average_confidence": round(avg_confidence, 3),
300:         "success": success
301:     }
302: 
303:     class_usage_report = {
304:         "resolved_at": datetime.now(timezone.utc).isoformat(),
305:         "classes_verified": resolver.stats["classes_verified"],
306:         "missing_classes_count": len(resolver.missing_classes),
307:         "success": success
308:     }
309: 
310:     # Collect assets for manifest
311:     def collect_assets(node: dict[str, Any], assets_list: list[dict[str, Any]]) -> None:
312:         media_item = node.get("media")
313:         if media_item and media_item.get("kind") != "none":
314:             assets_list.append({
315:                 "figma_node_id": node.get("id"),
316:                 "filename": f"{node.get('id')}.png",
317:                 "role": media_item.get("role", "informative"),
318:                 "alt_text": media_item.get("alt_text", ""),
319:                 "aria_hidden": media_item.get("role") == "decorative",
320:                 "local_path": media_item.get("asset_ref", "")
321:             })
322:         for child in node.get("children", []):
323:             collect_assets(child, assets_list)
324: 
325:     assets = []
326:     collect_assets(semantic_tree, assets)
327:     
328:     asset_manifest = {
329:         "version": "1.0.0",
330:         "assets": assets,
331:         "metadata": {
332:             "updated_at": datetime.now(timezone.utc).isoformat(),
333:             "total_assets": len(assets)
334:         }
335:     }
336:     asset_manifest_path = output_path.parent.parent / "html" / "asset-manifest.json"
337:     asset_manifest_path.parent.mkdir(parents=True, exist_ok=True)
338:     asset_manifest_path.write_text(json.dumps(asset_manifest, indent=2, ensure_ascii=False), encoding="utf-8")
339: 
340:     # Ensure parent dirs exist
341:     output_path.parent.mkdir(parents=True, exist_ok=True)
342:     reports_dir.mkdir(parents=True, exist_ok=True)
343: 
344:     output_path.write_text(json.dumps(output_payload, indent=2, ensure_ascii=False), encoding="utf-8")
345:     (reports_dir / "missing-mapping-report.json").write_text(json.dumps(missing_report, indent=2, ensure_ascii=False), encoding="utf-8")
346:     (reports_dir / "tag-report.json").write_text(json.dumps(tag_report, indent=2, ensure_ascii=False), encoding="utf-8")
347:     (reports_dir / "class-usage-report.json").write_text(json.dumps(class_usage_report, indent=2, ensure_ascii=False), encoding="utf-8")
348: 
349:     print(f"Semantic resolution complete. Success: {success}. Confidence: {avg_confidence:.2f}")
350:     if not success:
351:         sys.exit(2)
352:     sys.exit(0)
353: 
354: if __name__ == "__main__":
355:     main()
</file>

