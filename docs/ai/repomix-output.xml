  1: import os
  2: import json
  3: from tools.css_indexer.parser import CSSParser
  4: from tools.css_indexer.classifier import CSSClassifier
  5: 
  6: class ContractBuilder:
  7:     def __init__(self, normalize_path, webflow_path, client_first_path):
  8:         self.normalize_path = normalize_path
  9:         self.webflow_path = webflow_path
 10:         self.client_first_path = client_first_path
 11:         self.parser = CSSParser()
 12: 
 13:     def build(self, output_dir):
 14:         os.makedirs(output_dir, exist_ok=True)
 15:         
 16:         # Parse files
 17:         norm_data = self.parser.parse_css_file(self.normalize_path)
 18:         webflow_data = self.parser.parse_css_file(self.webflow_path)
 19:         cf_data = self.parser.parse_css_file(self.client_first_path)
 20:         
 21:         cf_hash = self.parser.get_md5_hash(self.client_first_path)
 22:         
 23:         # 1. Allowed Classes & Combo Classes (Client-First specific)
 24:         allowed_classes = sorted(list(cf_data["classes"]))
 25:         allowed_combo_classes = sorted(list(cf_data["combo_classes"]))
 26:         allowed_variables = sorted(list(cf_data["variables"].keys()))
 27:         allowed_selectors = sorted(list(cf_data["selectors"]))
 28:         breakpoints = sorted(list(cf_data["breakpoints"]))
 29:         
 30:         # Webflow native reserved classes
 31:         reserved_webflow_classes = sorted(list(webflow_data["classes"]))
 32:         
 33:         # Styleguide classes
 34:         styleguide_only_classes = sorted([c for c in allowed_classes if CSSClassifier.classify_class(c) == "styleguide-only"])
 35:         
 36:         # 2. Build library contract JSON
 37:         contract = {
 38:             "version": "1.0.0",
 39:             "source": {
 40:                 "normalize_css": self.normalize_path,
 41:                 "webflow_css": self.webflow_path,
 42:                 "client_first_css": self.client_first_path,
 43:                 "client_first_css_hash": cf_hash
 44:             },
 45:             "strict_mode": True,
 46:             "allowed_classes": allowed_classes,
 47:             "allowed_combo_classes": allowed_combo_classes,
 48:             "allowed_variables": allowed_variables,
 49:             "allowed_selectors": allowed_selectors,
 50:             "breakpoints": breakpoints,
 51:             "reserved_webflow_classes": reserved_webflow_classes,
 52:             "styleguide_only_classes": styleguide_only_classes,
 53:             "structural_convention_classes": ["page-wrapper", "main-wrapper"],
 54:             "forbidden_in_final_html": ["fs-styleguide_*"],
 55:             "invalid_until_contract_proves": ["button_component", "card_component", "hero_layout"]
 56:         }
 57:         
 58:         # 3. Create indices
 59:         
 60:         # CSS Variable index
 61:         all_variables = {}
 62:         for source_data in [norm_data, webflow_data, cf_data]:
 63:             for var_name, definitions in source_data["variables"].items():
 64:                 if var_name not in all_variables:
 65:                     all_variables[var_name] = []
 66:                 all_variables[var_name].extend(definitions)
 67:                 
 68:         # CSS Class Index
 69:         class_index = {}
 70:         for c in set(allowed_classes) | set(reserved_webflow_classes):
 71:             class_index[c] = {
 72:                 "category": CSSClassifier.classify_class(c),
 73:                 "is_combo": False
 74:             }
 75:         for cc in allowed_combo_classes:
 76:             class_index[cc] = {
 77:                 "category": "combo",
 78:                 "is_combo": True
 79:             }
 80:             
 81:         # CSS Selector Index
 82:         selector_index = {}
 83:         for source_data in [norm_data, webflow_data, cf_data]:
 84:             for decl in source_data["declarations"]:
 85:                 sel = decl["selector"]
 86:                 if sel not in selector_index:
 87:                     selector_index[sel] = []
 88:                 selector_index[sel].append({
 89:                     "property": decl["property"],
 90:                     "value": decl["value"],
 91:                     "media": decl["media"]
 92:                 })
 93:                 
 94:         # Property Value Index
 95:         property_value_index = {}
 96:         for source_data in [norm_data, webflow_data, cf_data]:
 97:             for decl in source_data["declarations"]:
 98:                 prop = decl["property"]
 99:                 if prop not in property_value_index:
100:                     property_value_index[prop] = []
101:                 property_value_index[prop].append({
102:                     "selector": decl["selector"],
103:                     "value": decl["value"],
104:                     "media": decl["media"]
105:                 })
106:                 
107:         # Breakpoint Index
108:         breakpoint_index = {}
109:         for bp in breakpoints:
110:             breakpoint_index[bp] = []
111:         for source_data in [norm_data, webflow_data, cf_data]:
112:             for decl in source_data["declarations"]:
113:                 media = decl["media"]
114:                 if media:
115:                     if media not in breakpoint_index:
116:                         breakpoint_index[media] = []
117:                     breakpoint_index[media].append({
118:                         "selector": decl["selector"],
119:                         "property": decl["property"],
120:                         "value": decl["value"]
121:                     })
122:                     
123:         # Webflow Native Class Index
124:         webflow_native_index = {
125:             "version": "1.0.0",
126:             "reserved_classes": reserved_webflow_classes,
127:             "mappings": {}
128:         }
129:         for c in reserved_webflow_classes:
130:             webflow_native_index["mappings"][c] = {
131:                 "is_reserved": True,
132:                 "notes": "Webflow native engine structural class"
133:             }
134:             
135:         # Write JSONs
136:         files_to_write = {
137:             "client-first-library-contract.json": contract,
138:             "css-variable-index.json": all_variables,
139:             "css-class-index.json": class_index,
140:             "css-selector-index.json": selector_index,
141:             "css-property-value-index.json": property_value_index,
142:             "css-breakpoint-index.json": breakpoint_index,
143:             "webflow-native-class-index.json": webflow_native_index
144:         }
145:         
146:         for fname, data in files_to_write.items():
147:             path = os.path.join(output_dir, fname)
148:             with open(path, "w", encoding="utf-8") as f:
149:                 json.dump(data, f, indent=2)
150:                 
151:         print(f"Contract and indices built successfully in {output_dir}")
