 1: #!/usr/bin/env python3
 2: """Fail when source files contain local absolute filesystem paths."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import re
 7: from pathlib import Path
 8: 
 9: 
10: SKIP_DIRS = {".git", ".venv", "venv", "__pycache__", "workspace", "archives"}
11: SKIP_EXTENSIONS = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".zip", ".pyc"}
12: WINDOWS_PATH_PATTERN = re.compile(r"\b[A-Za-z]:[\\/][^\s\"'<>)]*")
13: UNC_PATH_PATTERN = re.compile(r"\\\\[A-Za-z0-9_.-]+\\[^\s\"'<>)]*")
14: LOCAL_UNIX_PATH_PATTERN = re.compile(r"(?<![\w:])/(?:Users|home|mnt|Volumes|tmp|var)/[^\s\"'<>)]*")
15: BAD_PATH_TOKENS = ("Mye" + "Drive", "Mys" + "Drive", "Leart" + "ing")
16: 
17: 
18: def should_skip(path: Path, root: Path) -> bool:
19:     relative = path.relative_to(root)
20:     if any(part in SKIP_DIRS for part in relative.parts):
21:         return True
22:     return path.suffix.lower() in SKIP_EXTENSIONS
23: 
24: 
25: def scan_file(path: Path) -> list[str]:
26:     text = path.read_text(encoding="utf-8", errors="ignore")
27:     failures: list[str] = []
28:     for pattern in (WINDOWS_PATH_PATTERN, UNC_PATH_PATTERN, LOCAL_UNIX_PATH_PATTERN):
29:         for match in pattern.findall(text):
30:             failures.append(f"{path.as_posix()} contains absolute path {match}")
31:     for token in BAD_PATH_TOKENS:
32:         if token in text:
33:             failures.append(f"{path.as_posix()} contains typo path token {token}")
34:     return failures
35: 
36: 
37: def validate(root: Path) -> list[str]:
38:     failures: list[str] = []
39:     for path in root.rglob("*"):
40:         if not path.is_file() or should_skip(path, root):
41:             continue
42:         failures.extend(scan_file(path))
43:     return failures
44: 
45: 
46: def main(argv: list[str] | None = None) -> int:
47:     parser = argparse.ArgumentParser(description=__doc__)
48:     parser.add_argument("--target", default=".", help="Folder to validate")
49:     args = parser.parse_args(argv)
50: 
51:     failures = validate(Path(args.target).resolve())
52:     if failures:
53:         print("relative path gate: fail")
54:         for failure in failures:
55:             print(f"  - {failure}")
56:         return 1
57:     print("relative path gate: pass")
58:     return 0
59: 
60: 
61: if __name__ == "__main__":
62:     raise SystemExit(main())
</file>

