 25: def resolve_variable(var_name: str, var_index: dict[str, Any], visited: set[str] | None = None) -> str | None:
 26:     """Recursively resolve a CSS variable to a raw value."""
 27:     if visited is None:
 28:         visited = set()
 29:     if var_name in visited:
 30:         return None
 31:     visited.add(var_name)
 32: 
 33:     entries = var_index.get(var_name, [])
 34:     if not entries:
 35:         return None
 36:     
 37:     base_val = None
 38:     for entry in entries:
 39:         if entry.get("media") is None:
 40:             base_val = entry.get("value")
 41:             break
 42:     if not base_val and entries:
 43:         base_val = entries[0].get("value")
 44: 
 45:     if not base_val:
 46:         return None
 47: 
 48:     match = re.match(r"^var\(([^)]+)\)$", str(base_val).strip())
 49:     if match:
 50:         return resolve_variable(match.group(1), var_index, visited)
 51:     return str(base_val)
