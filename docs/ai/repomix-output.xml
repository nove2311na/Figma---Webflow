  1: #!/usr/bin/env python3
  2: """Deterministic HTML Blueprint validation gate (Class strictness, structure, accessibility, syntax)."""
  3: from __future__ import annotations
  4: 
  5: import json
  6: import sys
  7: from datetime import datetime, timezone
  8: from pathlib import Path
  9: from typing import Any
 10: 
 11: def load_json(path: Path) -> Any:
 12:     if not path.exists():
 13:         return {}
 14:     return json.loads(path.read_text(encoding="utf-8"))
 15: 
 16: class HTMLValidator:
 17:     def __init__(self, contract: dict[str, Any]):
 18:         self.allowed_classes = set(contract.get("allowed_classes", []))
 19:         self.allowed_combo_classes = set(contract.get("allowed_combo_classes", []))
 20:         self.structural_classes = set(contract.get("structural_convention_classes", ["page-wrapper", "main-wrapper"]))
 21:         self.reserved_classes = set(contract.get("reserved_webflow_classes", []))
 22:         
 23:         self.failures = []
 24:         self.checks = {
 25:             "html_syntax": True,
 26:             "class_strictness": True,
 27:             "accessibility": True,
 28:             "client_first_structure": True
 29:         }
 30: 
 31:     def walk_node(self, node: dict[str, Any], path_tags: list[str]) -> None:
 32:         tag = node.get("tag", "div")
 33:         classes = node.get("classes", [])
 34:         attrs = node.get("attributes", {})
 35:         node_id = attrs.get("data-figma-node", "unknown")
 36:         
 37:         # 1. Class Strictness check
 38:         for cls in classes:
 39:             is_valid = (
 40:                 cls in self.allowed_classes or
 41:                 cls in self.allowed_combo_classes or
 42:                 cls in self.structural_classes or
 43:                 cls in self.reserved_classes or
 44:                 cls.startswith("w-")  # Webflow native
 45:             )
 46:             if not is_valid:
 47:                 self.checks["class_strictness"] = False
 48:                 self.failures.append({
 49:                     "node_id": node_id,
 50:                     "rule": "class_strictness",
 51:                     "details": f"Class '{cls}' not found in Client-First library contract."
 52:                 })
 53: 
 54:         # 2. Accessibility checks
 55:         if tag == "img":
 56:             # Image role check
 57:             alt = attrs.get("alt")
 58:             aria_hidden = attrs.get("aria-hidden")
 59:             if alt is None and aria_hidden != "true":
 60:                 self.checks["accessibility"] = False
 61:                 self.failures.append({
 62:                     "node_id": node_id,
 63:                     "rule": "accessibility",
 64:                     "details": f"Image tag <img> must have an 'alt' attribute or 'aria-hidden=\"true\"'."
 65:                 })
 66: 
 67:         if tag == "input":
 68:             # Input needs name/id
 69:             name = attrs.get("name")
 70:             inp_id = attrs.get("id")
 71:             if not name and not inp_id:
 72:                 self.checks["accessibility"] = False
 73:                 self.failures.append({
 74:                     "node_id": node_id,
 75:                     "rule": "accessibility",
 76:                     "details": f"Input control <input> must have a 'name' or 'id' attribute."
 77:                 })
 78: 
 79:         # Recursion
 80:         current_tags = path_tags + [tag]
 81:         for child in node.get("children", []):
 82:             self.walk_node(child, current_tags)
 83: 
 84:     def check_structure(self, body_bp: dict[str, Any]) -> None:
 85:         # Client-First structural check
 86:         # Root element should have class page-wrapper
 87:         root_classes = body_bp.get("classes", [])
 88:         if "page-wrapper" not in root_classes:
 89:             self.checks["client_first_structure"] = False
 90:             self.failures.append({
 91:                 "node_id": body_bp.get("attributes", {}).get("data-figma-node", "root"),
 92:                 "rule": "client_first_structure",
 93:                 "details": "Root body container must have the 'page-wrapper' class."
 94:             })
 95: 
 96:         # Main-wrapper check
 97:         children = body_bp.get("children", [])
 98:         has_main_wrapper = False
 99:         for child in children:
100:             if "main-wrapper" in child.get("classes", []):
101:                 has_main_wrapper = True
102:                 break
103:         
104:         if not has_main_wrapper:
105:             self.checks["client_first_structure"] = False
106:             self.failures.append({
107:                 "node_id": body_bp.get("attributes", {}).get("data-figma-node", "root"),
108:                 "rule": "client_first_structure",
109:                 "details": "Children of 'page-wrapper' must contain a 'main-wrapper' container."
110:             })
111: 
112: def validate_html(root: Path) -> list[str]:
113:     failures = []
114:     bp_path = root / "workspace" / "html" / "page.blueprint.json"
115:     html_path = root / "workspace" / "html" / "page.html"
116:     contract_path = root / "knowledge-base" / "generated" / "client-first-library-contract.json"
117: 
118:     if not bp_path.exists() or not html_path.exists():
119:         return ["Blueprint or rendered HTML files are missing."]
120: 
121:     bp_payload = load_json(bp_path)
122:     contract = load_json(contract_path)
123: 
124:     body_bp = bp_payload.get("body", {})
125:     if not body_bp:
126:         return ["Blueprint JSON has no body element."]
127: 
128:     validator = HTMLValidator(contract)
129:     
130:     # Run walks
131:     validator.walk_node(body_bp, [])
132:     validator.check_structure(body_bp)
133: 
134:     success = len(validator.failures) == 0
135: 
136:     # Write report
137:     report_payload = {
138:         "verified_at": datetime.now(timezone.utc).isoformat(),
139:         "local_html_path": str(html_path),
140:         "checks": validator.checks,
141:         "failures": validator.failures,
142:         "success": success
143:     }
144: 
145:     report_path = root / "workspace" / "reports" / "html-validation-report.json"
146:     report_path.parent.mkdir(parents=True, exist_ok=True)
147:     report_path.write_text(json.dumps(report_payload, indent=2, ensure_ascii=False), encoding="utf-8")
148: 
149:     # Return summary of failures for the runner
150:     for f in validator.failures:
151:         failures.append(f"[{f['rule']}] Node {f.get('node_id')}: {f['details']}")
152: 
153:     return failures
154: 
155: def main() -> int:
156:     root = Path(__file__).resolve().parents[3]
157:     failures = validate_html(root)
158:     if failures:
159:         print("html-blueprint-gate: FAIL")
160:         for f in failures:
161:             print(f"  - {f}")
162:         return 1
163:     print("html-blueprint-gate: PASS")
164:     return 0
165: 
166: if __name__ == "__main__":
167:     sys.exit(main())
</file>

