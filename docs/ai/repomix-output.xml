52:     if not styleguide_classes:
53:         errors.append("styleguide_only_classes array is missing or empty.")
54:     else:
55:         for sc in styleguide_classes:
56:             if not (sc.startswith("fs-styleguide_") or sc.startswith("fs-styleguide")):
57:                 errors.append(f"Class '{sc}' in styleguide_only_classes does not match styleguide name pattern.")
58:                 
59:     # Check .w-* not marked native/reserved
60:     reserved_classes = contract.get("reserved_webflow_classes", [])
61:     if not reserved_classes:
62:         errors.append("reserved_webflow_classes is empty or missing.")
63:     else:
64:         # Some .w- classes should be present
65:         w_classes = [c for c in reserved_classes if c.startswith("w-")]
66:         if not w_classes:
67:             errors.append("No 'w-' prefixed classes found in reserved_webflow_classes.")
68: 
