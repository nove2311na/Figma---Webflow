<file path="scripts/hooks/build-discipline-guard.js">
 1: #!/usr/bin/env node
 2: /**
 3:  * MAS Build Discipline Guard — PreToolUse hook for Bash tool.
 4:  *
 5:  * Enforces D-1 from agentic/policies/build-discipline.md:
 6:  *   "Write→Bash, never multi-line `python -c`"
 7:  *
 8:  * Reads Claude Code hook JSON from stdin:
 9:  *   {tool_name, tool_input: {command}, ...}
10:  *
11:  * Detects `python -c` invocations that contain embedded newlines (raw `\n` in
12:  * the command string OR escaped \n in a quoted python code block). Blocks
13:  * with exit code 2 and writes a clear D-1 message to stderr.
14:  *
15:  * Allows:
16:  *   - python (no -c)
17:  *   - python -c "single line; with semicolons" (no newlines, no embedded \n)
18:  *   - python scripts/anything.py
19:  *   - any other command
20:  *
21:  * Exit codes (Claude Code PreToolUse contract):
22:  *   0 = allow
23:  *   2 = block (stderr is shown to user as the reason)
24:  */
25: 'use strict';
26: 
27: const fs = require('fs');
28: 
29: let raw = '';
30: try {
31:   raw = fs.readFileSync(0, 'utf8');
32: } catch (err) {
33:   process.exit(0);
34: }
35: 
36: let payload = {};
37: try {
38:   payload = JSON.parse(raw);
39: } catch (err) {
40:   process.exit(0);
41: }
42: 
43: if (payload.tool_name !== 'Bash') {
44:   process.exit(0);
45: }
46: 
47: const command = (payload.tool_input && payload.tool_input.command) || '';
48: if (typeof command !== 'string' || command.length === 0) {
49:   process.exit(0);
50: }
51: 
52: const pyCRegex = /\bpython(?:3)?(?:\s+-c|\s+--c)\b/;
53: if (!pyCRegex.test(command)) {
54:   process.exit(0);
55: }
56: 
57: const hasRawNewline = command.includes('\n');
58: const hasEscapedNewline = /python[^"]*"[^"]*\\n[^"]*"/.test(command) || /python[^']*'[^']*\\n[^']*'/.test(command);
59: const hasHeredoc = /<<\s*['"]?python['"]?/.test(command);
60: 
61: if (hasRawNewline || hasEscapedNewline || hasHeredoc) {
62:   const reason = [
63:     '[MAS Build Discipline D-1] Blocked: multi-line `python -c` detected.',
64:     '',
65:     'Command contained an embedded newline inside `python -c` code, which',
66:     'Windows bash mangles (causes SyntaxError: EOL while scanning string).',
67:     '',
68:     'Required pattern (D-1): use the Write tool to save a .py file, then run it.',
69:     '  1. Write tool -> save scripts/<descriptive_name>.py',
70:     '  2. Bash: python scripts/<descriptive_name>.py',
71:     '',
72:     'Single-line `python -c` with semicolons IS allowed. Multi-line is not.',
73:     'See agentic/policies/build-discipline.md (D-1) for full rationale.',
74:   ].join('\n');
75:   process.stderr.write(reason + '\n');
76:   process.exit(2);
77: }
78: 
79: process.exit(0);
