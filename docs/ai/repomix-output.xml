  1: #!/usr/bin/env python3
  2: """Helper: print LLM instructions to update the per-project CF library from Figma variables.
  3: 
  4: This script does not call Figma MCP directly -- it prints a structured instruction
  5: block for the LLM agent to follow. The LLM then calls Figma MCP get_variable_defs,
  6: applies the naming rules from the prompt template, and writes the updated JSON files.
  7: 
  8: After the LLM writes the files, run:
  9:   python scripts/gates/validate_project_library.py --site-id <id>
 10: """
 11: from __future__ import annotations
 12: 
 13: import argparse
 14: import json
 15: import sys
 16: from pathlib import Path
 17: 
 18: sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
 19: from tools.library_resolver import (
 20:     CHANGELOG_FILENAME,
 21:     LIBRARIES_DIR,
 22:     LIBRARY_FILENAME,
 23:     TOKEN_MAP_FILENAME,
 24:     _library_dir,
 25:     load_registry,
 26:     scaffold_library_dir,
 27:     register_project,
 28: )
 29: 
 30: 
 31: def print_update_instructions(root: Path, site_id: str, figma_file_id: str) -> None:
 32:     """Print structured LLM instructions for Figma -> library update."""
 33:     lib_dir = _library_dir(root, site_id)
 34:     library_path = lib_dir / LIBRARY_FILENAME
 35:     token_map_path = lib_dir / TOKEN_MAP_FILENAME
 36:     changelog_path = lib_dir / CHANGELOG_FILENAME
 37:     prompt_path = root / "agentic" / "prompts" / "generate-cf-library.md"
 38: 
 39:     current_classes: dict = {}
 40:     if library_path.exists():
 41:         try:
 42:             current_classes = json.loads(library_path.read_text(encoding="utf-8")).get("classes", {})
 43:         except json.JSONDecodeError:
 44:             pass
 45: 
 46:     print("=" * 60)
 47:     print("FIGMA -> CLIENT-FIRST LIBRARY UPDATE INSTRUCTIONS")
 48:     print("=" * 60)
 49:     print(f"\nProject:       {site_id}")
 50:     print(f"Figma file:    {figma_file_id}")
 51:     print(f"Library path:  {LIBRARIES_DIR}/{site_id}/{LIBRARY_FILENAME}")
 52:     print(f"Token map:     {LIBRARIES_DIR}/{site_id}/{TOKEN_MAP_FILENAME}")
 53:     print(f"Changelog:     {LIBRARIES_DIR}/{site_id}/{CHANGELOG_FILENAME}")
 54:     print(f"Existing classes: {len(current_classes)} defined")
 55:     print()
 56:     print("STEP 1 -- Read the prompt template:")
 57:     print(f"  {prompt_path.relative_to(root)}")
 58:     print()
 59:     print("STEP 2 -- Call Figma MCP:")
 60:     print(f"  get_variable_defs(figma_file_id='{figma_file_id}')")
 61:     print()
 62:     print("STEP 3 -- Apply naming rules from prompt template.")
 63:     print("  For each Figma variable:")
 64:     print("    - Derive cf_category from variable type and path")
 65:     print("    - Derive semantic_name from last path segment (slugified)")
 66:     print("    - Build class name: {cf_category}-{semantic_name}")
 67:     print("    - Convert px -> rem (divide by 16) for spacing/typography")
 68:     print("    - Color variables generate text-color-*, background-color-*, border-color-* classes")
 69:     print()
 70:     print("STEP 4 -- Write updated files:")
 71:     print(f"  {LIBRARIES_DIR}/{site_id}/{TOKEN_MAP_FILENAME}")
 72:     print(f"  {LIBRARIES_DIR}/{site_id}/{LIBRARY_FILENAME}")
 73:     print()
 74:     print("STEP 5 -- Append changelog entries:")
 75:     print(f"  {LIBRARIES_DIR}/{site_id}/{CHANGELOG_FILENAME}")
 76:     print("  Format: {timestamp, class, old_value, new_value, source, reason}")
 77:     print()
 78:     print("STEP 6 -- Validate:")
 79:     print(f"  python scripts/gates/validate_project_library.py --site-id {site_id}")
 80:     print("=" * 60)
 81: 
 82: 
 83: def main(argv: list[str] | None = None) -> int:
 84:     parser = argparse.ArgumentParser(description=__doc__)
 85:     parser.add_argument("--site-id", required=True, help="Webflow site ID")
 86:     parser.add_argument("--figma-file-id", default="", help="Figma file ID (not full URL)")
 87:     parser.add_argument("--project-name", default="", help="Human-readable project name")
 88:     parser.add_argument("--target", default=".", help="Repo root path")
 89:     args = parser.parse_args(argv)
 90: 
 91:     root = Path(args.target).resolve()
 92: 
 93:     # Scaffold if library dir does not exist yet
 94:     lib_dir = _library_dir(root, args.site_id)
 95:     if not lib_dir.exists():
 96:         for action in scaffold_library_dir(root, args.site_id, args.figma_file_id):
 97:             print(action)
 98:         register_project(root, {
 99:             "webflow_site_id": args.site_id,
100:             "figma_file_id": args.figma_file_id,
101:             "name": args.project_name or args.site_id,
102:         })
103: 
104:     print_update_instructions(root, args.site_id, args.figma_file_id)
105:     return 0
106: 
107: 
108: if __name__ == "__main__":
109:     raise SystemExit(main())
</file>

