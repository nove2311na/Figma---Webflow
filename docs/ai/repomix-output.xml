<file path="scripts/restore_workspace.py">
 1: #!/usr/bin/env python3
 2: """Restore a workspace archive into an empty workspace."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import zipfile
 7: from pathlib import Path
 8: 
 9: 
10: ROOT = Path(__file__).resolve().parents[1]
11: WORKSPACE_DIR = ROOT / "workspace"
12: ARCHIVES_DIR = ROOT / "archives"
13: 
14: 
15: def list_archives() -> list[Path]:
16:     """Return workspace archives sorted by name."""
17:     if not ARCHIVES_DIR.exists():
18:         return []
19:     return sorted(path for path in ARCHIVES_DIR.iterdir() if path.suffix.lower() == ".zip")
20: 
21: 
22: def resolve_archive(selector: str) -> Path:
23:     """Resolve an archive by numeric index or filename."""
24:     archives = list_archives()
25:     if selector.isdigit():
26:         index = int(selector)
27:         if 0 <= index < len(archives):
28:             return archives[index]
29:     archive_path = ARCHIVES_DIR / selector
30:     if archive_path.exists() and archive_path.suffix.lower() == ".zip":
31:         return archive_path
32:     raise FileNotFoundError(f"archive not found: {selector}")
33: 
34: 
35: def ensure_safe_member(destination: Path, member_name: str) -> Path:
36:     """Prevent zip path traversal."""
37:     target = (destination / member_name).resolve()
38:     if destination.resolve() not in target.parents and target != destination.resolve():
39:         raise RuntimeError(f"unsafe archive member: {member_name}")
40:     return target
41: 
42: 
43: def restore(selector: str) -> Path:
44:     """Restore selected archive into an empty workspace."""
45:     archive_path = resolve_archive(selector)
46:     WORKSPACE_DIR.mkdir(parents=True, exist_ok=True)
47:     if any(WORKSPACE_DIR.iterdir()):
48:         raise RuntimeError("workspace is not empty; archive current workspace before restore")
49: 
50:     with zipfile.ZipFile(archive_path) as archive:
51:         for member in archive.infolist():
52:             target = ensure_safe_member(WORKSPACE_DIR, member.filename)
53:             if member.is_dir():
54:                 target.mkdir(parents=True, exist_ok=True)
55:             else:
56:                 target.parent.mkdir(parents=True, exist_ok=True)
57:                 target.write_bytes(archive.read(member))
58:     return archive_path
59: 
60: 
61: def main(argv: list[str] | None = None) -> int:
62:     parser = argparse.ArgumentParser(description=__doc__)
63:     parser.add_argument("archive", nargs="?", help="Archive filename or numeric index")
64:     args = parser.parse_args(argv)
65: 
66:     if not args.archive:
67:         archives = list_archives()
68:         if not archives:
69:             print("no archives found")
70:             return 0
71:         print("available archives:")
72:         for index, path in enumerate(archives):
73:             print(f"[{index}] {path.name}")
74:         return 0
75: 
76:     archive_path = restore(args.archive)
77:     print(f"workspace restored from: {archive_path.name}")
78:     return 0
79: 
80: 
81: if __name__ == "__main__":
82:     raise SystemExit(main())
</file>

