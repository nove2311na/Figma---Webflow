 1: #!/usr/bin/env python3
 2: """Print ordered Webflow MCP style_tool calls to sync a project library.
 3: 
 4: This script does not call Webflow MCP directly. It loads the per-project
 5: client-first-library.json and prints structured payloads for each class,
 6: which the LLM agent then executes via Webflow MCP style_tool.
 7: 
 8: After the LLM executes all calls, the script stamps last_synced in registry.json.
 9: """
10: from __future__ import annotations
11: 
12: import argparse
13: import json
14: import sys
15: from datetime import datetime, timezone
16: from pathlib import Path
17: 
18: sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
19: from tools.library_resolver import load_library, load_registry, update_last_synced
20: 
21: 
22: def build_style_payloads(library: dict) -> list[dict]:
23:     """Convert library classes to Webflow style_tool payload list."""
24:     payloads = []
25:     for class_name, class_def in library.get("classes", {}).items():
26:         payloads.append({
27:             "class_name": class_name,
28:             "webflow_property": class_def["webflow_property"],
29:             "value": class_def["value"],
30:             "figma_token": class_def.get("figma_token", ""),
31:             "cf_category": class_def.get("cf_category", ""),
32:         })
33:     return payloads
34: 
35: 
36: def print_sync_instructions(root: Path, site_id: str) -> int:
37:     """Load library and print MCP call sequence for LLM to execute."""
38:     try:
39:         library = load_library(root, site_id)
40:     except FileNotFoundError as exc:
41:         print(f"sync failed: {exc}")
42:         return 1
43: 
44:     payloads = build_style_payloads(library)
45:     if not payloads:
46:         print(f"sync skipped: no classes defined in library for {site_id}")
47:         return 0
48: 
49:     print("=" * 60)
50:     print("WEBFLOW STYLE SYNC INSTRUCTIONS")
51:     print("=" * 60)
52:     print(f"\nProject (Webflow site ID): {site_id}")
53:     print(f"Library version: {library.get('version', 'unknown')}")
54:     print(f"Classes to sync: {len(payloads)}")
55:     print()
56:     print("For each payload below, call Webflow MCP style_tool:")
57:     print("  style_tool(site_id=<site_id>, class_name=..., styles={property: value})")
58:     print()
59:     print("PAYLOADS (ordered by cf_category):")
60:     sorted_payloads = sorted(payloads, key=lambda p: (p["cf_category"], p["class_name"]))
61:     for i, payload in enumerate(sorted_payloads, 1):
62:         print(f"\n[{i}/{len(sorted_payloads)}]")
63:         print(f"  class_name:        {payload['class_name']}")
64:         print(f"  webflow_property:  {payload['webflow_property']}")
65:         print(f"  value:             {payload['value']}")
66:         print(f"  figma_token:       {payload['figma_token']}")
67: 
68:     print()
69:     print("After all calls succeed, run:")
70:     print(f"  python scripts/sync_library_to_webflow.py --site-id {site_id} --mark-synced")
71:     print("=" * 60)
72:     return 0
73: 
74: 
75: def main(argv: list[str] | None = None) -> int:
76:     parser = argparse.ArgumentParser(description=__doc__)
77:     parser.add_argument("--site-id", required=True, help="Webflow site ID")
78:     parser.add_argument("--target", default=".", help="Repo root path")
79:     parser.add_argument(
80:         "--mark-synced",
81:         action="store_true",
82:         help="Stamp last_synced in registry.json (call after LLM finishes MCP calls)",
83:     )
84:     args = parser.parse_args(argv)
85: 
86:     root = Path(args.target).resolve()
87: 
88:     if args.mark_synced:
89:         update_last_synced(root, args.site_id)
90:         print(f"last_synced stamped for {args.site_id}")
91:         return 0
92: 
93:     return print_sync_instructions(root, args.site_id)
94: 
95: 
96: if __name__ == "__main__":
97:     raise SystemExit(main())
