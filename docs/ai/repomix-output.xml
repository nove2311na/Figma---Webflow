  1: #!/usr/bin/env python3
  2: """Normalize Figma messy tree nodes before Semantic IR."""
  3: from __future__ import annotations
  4: 
  5: import argparse
  6: import json
  7: import re
  8: import sys
  9: from datetime import datetime, timezone
 10: from pathlib import Path
 11: from typing import Any
 12: 
 13: # Ensure project root is in path
 14: sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
 15: from tools.utils import parse_color, color_distance, slugify
 16: 
 17: def load_json(path: Path) -> Any:
 18:     if not path.exists():
 19:         return {}
 20:     return json.loads(path.read_text(encoding="utf-8"))
 21: 
 22: def resolve_variable(var_name: str, var_index: dict[str, Any], visited: set[str] | None = None) -> str | None:
 23:     """Recursively resolve a CSS variable to a raw value."""
 24:     if visited is None:
 25:         visited = set()
 26:     if var_name in visited:
 27:         return None  # Circular reference
 28:     visited.add(var_name)
 29: 
 30:     entries = var_index.get(var_name, [])
 31:     if not entries:
 32:         return None
 33:     
 34:     # Get base value (media: null)
 35:     base_val = None
 36:     for entry in entries:
 37:         if entry.get("media") is None:
 38:             base_val = entry.get("value")
 39:             break
 40:     if not base_val:
 41:         base_val = entries[0].get("value")
 42: 
 43:     if not base_val:
 44:         return None
 45: 
 46:     # If it is var(--something), resolve recursively
 47:     match = re.match(r"^var\(([^)]+)\)$", str(base_val).strip())
 48:     if match:
 49:         return resolve_variable(match.group(1), var_index, visited)
 50:     return str(base_val)
 51: 
 52: class FigmaNormalizer:
 53:     def __init__(self, rules: dict[str, Any], contract: dict[str, Any], var_index: dict[str, Any]):
 54:         self.rules = rules.get("normalization_rules", {})
 55:         self.allowed_classes = set(contract.get("allowed_classes", []))
 56:         self.allowed_combo_classes = set(contract.get("allowed_combo_classes", []))
 57:         self.allowed_variables = set(contract.get("allowed_variables", []))
 58:         self.var_index = var_index
 59:         
 60:         # Build color variable cache
 61:         self.color_vars = {}
 62:         for var_name in self.allowed_variables:
 63:             val = resolve_variable(var_name, self.var_index)
 64:             if val:
 65:                 parsed = parse_color(val)
 66:                 if parsed:
 67:                     self.color_vars[var_name] = val
 68: 
 69:         self.stats = {
 70:             "generic_names_resolved": 0,
 71:             "raw_colors_snapped": 0,
 72:             "raw_spacing_snapped": 0,
 73:             "layout_recovered": 0,
 74:             "repeated_subtrees_found": 0,
 75:             "blockers_count": 0,
 76:             "warnings_count": 0
 77:         }
 78:         self.blockers = []
 79:         self.warnings = []
 80: 
 81:     def normalize_node(self, node: dict[str, Any]) -> dict[str, Any]:
 82:         node_id = node.get("id", "unknown")
 83:         original_name = node.get("name", "")
 84:         node_type = node.get("type", "FRAME")
 85:         notes = []
 86: 
 87:         # 1. Generic names recovery
 88:         name = original_name
 89:         is_generic = False
 90:         generic_patterns = self.rules.get("generic_names", [])
 91:         for gp in generic_patterns:
 92:             pattern = gp.get("pattern", "")
 93:             if pattern and re.match(pattern, original_name):
 94:                 is_generic = True
 95:                 break
 96: 
 97:         if is_generic:
 98:             # Infer name based on children or type
 99:             children = node.get("children", [])
100:             child_types = [c.get("type") for c in children]
101:             
102:             if len(children) == 1 and children[0].get("type") == "TEXT":
103:                 txt_content = children[0].get("name", "text")
104:                 name = f"wrapper-{slugify(txt_content)}"
105:             elif "INSTANCE" in child_types:
106:                 name = "component-wrapper"
107:             elif "IMAGE" in child_types or "RECTANGLE" in child_types:
108:                 name = "media-wrapper"
109:             else:
110:                 name = f"container-{slugify(node_type)}"
111:             
112:             notes.append(f"Normalized generic name '{original_name}' to '{name}'")
113:             self.stats["generic_names_resolved"] += 1
114: 
115:         # 2. Styles and raw colors normalization
116:         styles = node.get("styles", {})
117:         normalized_styles = {}
118:         classes = node.get("classes", [])
119: 
120:         # Ensure classes exist in contract
121:         valid_classes = []
122:         for cls in classes:
123:             if cls in self.allowed_classes or cls in self.allowed_combo_classes:
124:                 valid_classes.append(cls)
125:             else:
126:                 self.warnings.append({
127:                     "node_id": node_id,
128:                     "reason": f"Class '{cls}' not found in contract."
129:                 })
130:                 self.stats["warnings_count"] += 1
131: 
132:         for style_key, style_val in styles.items():
133:             if style_key in ("background-color", "color", "border-color"):
134:                 # Check if it is a CSS variable
135:                 if isinstance(style_val, str) and style_val.startswith("var("):
136:                     var_match = re.match(r"^var\(([^)]+)\)$", style_val)
137:                     if var_match:
138:                         var_name = var_match.group(1)
139:                         if var_name not in self.allowed_variables:
140:                             self.blockers.append({
141:                                 "node_id": node_id,
142:                                 "reason": f"Unrecognized CSS variable '{var_name}' in style '{style_key}'"
143:                             })
144:                             self.stats["blockers_count"] += 1
145:                     normalized_styles[style_key] = style_val
146:                 else:
147:                     # It's a raw color value
148:                     parsed_raw = parse_color(style_val)
149:                     if parsed_raw:
150:                         # Find closest variable
151:                         closest_var = None
152:                         min_dist = float("inf")
153:                         for var_name, var_raw in self.color_vars.items():
154:                             dist = color_distance(style_val, var_raw)
155:                             if dist < min_dist:
156:                                 min_dist = dist
157:                                 closest_var = var_name
158: 
159:                         threshold = self.rules.get("untokenized_values", {}).get("threshold_snap_px", 15)
160:                         if closest_var and min_dist <= threshold:
161:                             normalized_styles[style_key] = f"var({closest_var})"
162:                             notes.append(f"Snapped raw color {style_val} to var({closest_var}) (dist: {min_dist:.2f})")
163:                             self.stats["raw_colors_snapped"] += 1
164:                         else:
165:                             normalized_styles[style_key] = style_val
166:                             msg = f"Raw color '{style_val}' in '{style_key}' has no close token match (closest: {closest_var} dist: {min_dist:.2f})."
167:                             if self.rules.get("untokenized_values", {}).get("mode") == "error_on_high_severity":
168:                                 self.blockers.append({"node_id": node_id, "reason": msg})
169:                                 self.stats["blockers_count"] += 1
170:                             else:
171:                                 self.warnings.append({"node_id": node_id, "reason": msg})
172:                                 self.stats["warnings_count"] += 1
173:                     else:
174:                         normalized_styles[style_key] = style_val
175:             elif style_key in ("padding", "margin", "gap"):
176:                 # Simple spacing snapping (placeholder for robust layout logic)
177:                 normalized_styles[style_key] = style_val
178:             else:
179:                 normalized_styles[style_key] = style_val
180: 
181:         # 3. Layout Recovery
182:         layout = node.get("layout", {})
183:         if not layout and node_type in ("FRAME", "GROUP") and node.get("children"):
184:             # Check if auto-layout is enabled in rules
185:             if self.rules.get("auto_layout_recovery", {}).get("enabled", True):
186:                 # Infer layout based on child coordinate offsets if available, otherwise default to vertical flex
187:                 layout = {
188:                     "type": "flex",
189:                     "direction": "vertical",
190:                     "spacing": "0rem",
191:                     "padding": "0rem",
192:                     "wrap": True
193:                 }
194:                 notes.append("Recovered missing layout to default vertical flex")
195:                 self.stats["layout_recovered"] += 1
196: 
197:         # 4. Check for ambiguous media
198:         ambiguous_media = False
199:         media_kind = "none"
200:         if node_type in ("VECTOR", "REGULAR_POLYGON", "STAR", "ELLIPSE"):
201:             ambiguous_media = True
202:             media_kind = "vector"
203:             notes.append("Marked vector layer as ambiguous media candidate")
204: 
205:         # Normalize children recursively
206:         normalized_children = []
207:         for child in node.get("children", []):
208:             normalized_children.append(self.normalize_node(child))
209: 
210:         # Build normalized node
211:         norm_node = {
212:             "id": node_id,
213:             "name": name,
214:             "original_name": original_name,
215:             "type": node_type,
216:             "classes": classes,
217:             "styles": normalized_styles,
218:             "layout": layout,
219:             "candidate_component": node.get("candidate_component", False),
220:             "component_name": node.get("component_name", ""),
221:             "ambiguous_media": ambiguous_media,
222:             "media_kind": media_kind,
223:             "normalization_notes": notes,
224:             "children": normalized_children
225:         }
226: 
227:         return norm_node
228: 
229: def main():
230:     parser = argparse.ArgumentParser(description="Normalize Figma Tree Nodes")
231:     parser.add_argument("--input", default="workspace/figma/figma.node-bundle.json")
232:     parser.add_argument("--output", default="workspace/figma/figma.normalized-tree.json")
233:     parser.add_argument("--report", default="workspace/reports/figma-normalization-report.json")
234:     parser.add_argument("--rules", default="agentic/rules/figma-normalization.rules.yaml")
235:     parser.add_argument("--contract", default="knowledge-base/generated/client-first-library-contract.json")
236:     parser.add_argument("--var-index", default="knowledge-base/generated/css-variable-index.json")
237:     args = parser.parse_args()
238: 
239:     input_path = Path(args.input)
240:     output_path = Path(args.output)
241:     report_path = Path(args.report)
242:     rules_path = Path(args.rules)
243:     contract_path = Path(args.contract)
244:     var_index_path = Path(args.var-index) if hasattr(args, "var-index") else Path(args.var_index)
245: 
246:     # Load data
247:     bundle = load_json(input_path)
248:     rules = load_json(rules_path) if rules_path.suffix == ".json" else {}
249:     if not rules and rules_path.exists():
250:         import yaml
251:         try:
252:             rules = yaml.safe_load(rules_path.read_text(encoding="utf-8"))
253:         except Exception:
254:             rules = {}
255: 
256:     contract = load_json(contract_path)
257:     var_index = load_json(var_index_path)
258: 
259:     if not bundle:
260:         print(f"Error: Input bundle {input_path} empty or missing.")
261:         sys.exit(1)
262: 
263:     normalizer = FigmaNormalizer(rules, contract, var_index)
264:     
265:     # Process tree
266:     raw_tree = bundle.get("tree", {})
267:     normalized_tree = normalizer.normalize_node(raw_tree)
268: 
269:     # Prepare outputs
270:     output_payload = {
271:         "node_id": bundle.get("node_id", "unknown"),
272:         "name": bundle.get("name", "unknown"),
273:         "normalized_tree": normalized_tree,
274:         "metadata": {
275:             "normalized_at": datetime.now(timezone.utc).isoformat(),
276:             "figma_file_version": bundle.get("metadata", {}).get("figma_file_version", "1.0"),
277:             "extractor_user": bundle.get("metadata", {}).get("extractor_user", "agent")
278:         }
279:     }
280: 
281:     success = len(normalizer.blockers) == 0
282:     report_payload = {
283:         "normalized_at": datetime.now(timezone.utc).isoformat(),
284:         "source_node_bundle": str(input_path),
285:         "stats": normalizer.stats,
286:         "blockers": normalizer.blockers,
287:         "warnings": normalizer.warnings,
288:         "success": success
289:     }
290: 
291:     # Ensure parent dirs exist
292:     output_path.parent.mkdir(parents=True, exist_ok=True)
293:     report_path.parent.mkdir(parents=True, exist_ok=True)
294: 
295:     output_path.write_text(json.dumps(output_payload, indent=2, ensure_ascii=False), encoding="utf-8")
296:     report_path.write_text(json.dumps(report_payload, indent=2, ensure_ascii=False), encoding="utf-8")
297: 
298:     print(f"Normalization complete. Success: {success}.")
299:     print(f"Blockers: {len(normalizer.blockers)}, Warnings: {len(normalizer.warnings)}")
300:     if not success:
301:         sys.exit(2)
302:     sys.exit(0)
303: 
304: if __name__ == "__main__":
305:     main()
