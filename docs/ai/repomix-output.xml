  1: #!/usr/bin/env python3
  2: """Render logical HTML Blueprint and output physical HTML with Client-First guidelines."""
  3: from __future__ import annotations
  4: 
  5: import argparse
  6: import html
  7: import json
  8: import sys
  9: from datetime import datetime, timezone
 10: from pathlib import Path
 11: from typing import Any
 12: 
 13: # Ensure project root is in path
 14: sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
 15: 
 16: def load_json(path: Path) -> Any:
 17:     if not path.exists():
 18:         return {}
 19:     return json.loads(path.read_text(encoding="utf-8"))
 20: 
 21: def build_blueprint_node(sem_node: dict[str, Any]) -> dict[str, Any]:
 22:     """Convert a semantic node into a blueprint node."""
 23:     tag = sem_node.get("tag", "div")
 24:     classes = sem_node.get("classes", [])
 25:     
 26:     # Construct attributes
 27:     attrs = {
 28:         "data-figma-node": sem_node.get("id", "")
 29:     }
 30: 
 31:     # Data markers for sections & components
 32:     role = sem_node.get("role", "")
 33:     node_name = sem_node.get("name", "")
 34:     if role == "section" or "section" in node_name.lower():
 35:         attrs["data-section"] = sem_node.get("name", "Section")
 36:     elif role == "component" or "component" in role:
 37:         attrs["data-component"] = sem_node.get("name", "Component")
 38: 
 39:     node_type = sem_node.get("type", "FRAME")
 40:     text_content = ""
 41:     if node_type == "TEXT":
 42:         # Text nodes hold raw content in figma name
 43:         text_content = sem_node.get("name", "")
 44: 
 45:     children = []
 46:     for child in sem_node.get("children", []):
 47:         children.append(build_blueprint_node(child))
 48: 
 49:     node_bp = {
 50:         "tag": tag,
 51:         "classes": classes,
 52:         "attributes": attrs,
 53:         "children": children
 54:     }
 55:     if text_content:
 56:         node_bp["text"] = text_content
 57: 
 58:     return node_bp
 59: 
 60: def render_blueprint_to_html(bp_node: dict[str, Any], indent_level: int = 0) -> str:
 61:     """Recursively render a blueprint node into indented HTML."""
 62:     indent = "  " * indent_level
 63:     tag = bp_node.get("tag", "div")
 64:     classes = bp_node.get("classes", [])
 65:     attrs = bp_node.get("attributes", {})
 66:     text_val = bp_node.get("text", "")
 67:     children = bp_node.get("children", [])
 68: 
 69:     # Assemble attribute string
 70:     attr_list = []
 71:     if classes:
 72:         attr_list.append(f'class="{" ".join(classes)}"')
 73:     for k, v in attrs.items():
 74:         attr_list.append(f'{k}="{html.escape(v)}"')
 75:     
 76:     attr_str = " " + " ".join(attr_list) if attr_list else ""
 77: 
 78:     # Self-closing tags
 79:     if tag in ("img", "input", "br", "hr", "meta", "link") and not children and not text_val:
 80:         return f"{indent}<{tag}{attr_str} />"
 81: 
 82:     # Single-line rendering for text only
 83:     if not children and text_val:
 84:         escaped_text = html.escape(text_val)
 85:         return f"{indent}<{tag}{attr_str}>{escaped_text}</{tag}>"
 86: 
 87:     # Multi-line rendering for tags with children
 88:     html_lines = [f"{indent}<{tag}{attr_str}>"]
 89:     
 90:     # If there is both text and children (uncommon in clean layouts but handled)
 91:     if text_val:
 92:         html_lines.append(f"{indent}  {html.escape(text_val)}")
 93: 
 94:     for child in children:
 95:         html_lines.append(render_blueprint_to_html(child, indent_level + 1))
 96: 
 97:     html_lines.append(f"{indent}</{tag}>")
 98:     return "\n".join(html_lines)
 99: 
100: def main():
101:     parser = argparse.ArgumentParser(description="Render HTML from Semantic IR Blueprint")
102:     parser.add_argument("--input", default="workspace/semantic/figma.semantic-tree.json")
103:     parser.add_argument("--blueprint-out", default="workspace/html/page.blueprint.json")
104:     parser.add_argument("--html-out", default="workspace/html/page.html")
105:     args = parser.parse_args()
106: 
107:     input_path = Path(args.input)
108:     bp_path = Path(args.blueprint_out)
109:     html_path = Path(args.html_out)
110: 
111:     semantic_payload = load_json(input_path)
112:     if not semantic_payload:
113:         print(f"Error: Semantic tree payload {input_path} empty or missing.")
114:         sys.exit(1)
115: 
116:     semantic_root = semantic_payload.get("semantic_tree", {})
117:     
118:     # Build blueprint tree
119:     body_content_bp = build_blueprint_node(semantic_root)
120:     
121:     # Apply Client-First structural wrapping: page-wrapper -> main-wrapper -> contents
122:     # If the root semantic node is already page-wrapper, keep it, otherwise wrap it
123:     root_classes = body_content_bp.get("classes", [])
124:     
125:     if "page-wrapper" not in root_classes:
126:         # Wrap everything in page-wrapper and main-wrapper
127:         main_wrapper_bp = {
128:             "tag": "main",
129:             "classes": ["main-wrapper"],
130:             "attributes": {"role": "main"},
131:             "children": [body_content_bp]
132:         }
133:         body_bp = {
134:             "tag": "div",
