<file path="scripts/gates/pipeline/validate_figma_normalization.py">
 1: #!/usr/bin/env python3
 2: """Deterministic quality gate for Figma Normalization."""
 3: from __future__ import annotations
 4: 
 5: import json
 6: import sys
 7: from pathlib import Path
 8: 
 9: def validate_normalization(root: Path) -> list[str]:
10:     failures = []
11:     report_path = root / "workspace" / "reports" / "figma-normalization-report.json"
12:     tree_path = root / "workspace" / "figma" / "figma.normalized-tree.json"
13: 
14:     if not report_path.exists():
15:         failures.append("Normalization report is missing.")
16:         return failures
17:     if not tree_path.exists():
18:         failures.append("Normalized Figma tree file is missing.")
19:         return failures
20: 
21:     try:
22:         report = json.loads(report_path.read_text(encoding="utf-8"))
23:     except Exception as e:
24:         failures.append(f"Failed to parse normalization report JSON: {e}")
25:         return failures
26: 
27:     try:
28:         tree = json.loads(tree_path.read_text(encoding="utf-8"))
29:     except Exception as e:
30:         failures.append(f"Failed to parse normalized tree JSON: {e}")
31:         return failures
32: 
33:     if not report.get("success", False):
34:         failures.append("Figma normalization report indicates FAILURE.")
35:     
36:     blockers = report.get("blockers", [])
37:     if blockers:
38:         for b in blockers:
39:             failures.append(f"Blocker at node '{b.get('node_id')}': {b.get('reason')}")
40: 
41:     # Schema integrity check
42:     for key in ("node_id", "name", "normalized_tree", "metadata"):
43:         if key not in tree:
44:             failures.append(f"Normalized tree missing key: {key}")
45: 
46:     return failures
47: 
48: def main() -> int:
49:     root = Path(__file__).resolve().parents[3]
50:     failures = validate_normalization(root)
51:     if failures:
52:         print("figma-normalization-gate: FAIL")
53:         for f in failures:
54:             print(f"  - {f}")
55:         return 1
