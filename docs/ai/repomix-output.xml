 75: def build_raw_blueprint(node: dict[str, Any]) -> dict[str, Any]:
 76:     """Recursively traverse Figma nodes to build raw layout blueprint node."""
 77:     node_id = node.get("id", "unknown")
 78:     node_name = node.get("name", "Unnamed Node")
 79:     node_type = node.get("type", "FRAME")
 80:     
 81:     styles = extract_node_styles(node)
 82:     
 83:     # Infer basic semantic tag based on Figma name patterns
 84:     tag = "div"
 85:     name_lower = node_name.lower()
 86:     if "[section]" in name_lower or "section" in name_lower:
 87:         tag = "section"
 88:     elif "[h1]" in name_lower or "h1" in name_lower:
 89:         tag = "h1"
 90:     elif "[h2]" in name_lower or "h2" in name_lower:
 91:         tag = "h2"
 92:     elif "[h3]" in name_lower or "h3" in name_lower:
 93:         tag = "h3"
 94:     elif "[p]" in name_lower or "paragraph" in name_lower:
 95:         tag = "p"
 96:     elif "[a]" in name_lower or "button" in name_lower or "cta" in name_lower:
 97:         tag = "a"
 98:     elif node_type == "TEXT":
 99:         tag = "p"
100: 
101:     text_content = node.get("characters", "") if node_type == "TEXT" else ""
102:     
103:     children = []
104:     for child in node.get("children", []):
105:         children.append(build_raw_blueprint(child))
106:         
107:     bp_node = {
108:         "id": node_id,
109:         "name": node_name,
110:         "type": node_type,
111:         "tag": tag,
112:         "styles": styles,
113:         "children": children
114:     }
115:     if text_content:
116:         bp_node["text"] = text_content
117:         
118:     return bp_node
119: 
120: def render_inline_html(node: dict[str, Any], indent_level: int = 0) -> str:
121:     """Recursively render raw blueprint nodes into raw HTML with inline styles."""
122:     indent = "  " * indent_level
123:     tag = node.get("tag", "div")
124:     styles = node.get("styles", {})
125:     text_content = node.get("text", "")
126:     children = node.get("children", [])
127:     
128:     # Assemble inline style attribute
129:     style_parts = [f"{k}: {v}" for k, v in styles.items()]
130:     style_str = f' style="{"; ".join(style_parts)}"' if style_parts else ""
131:     attrs_str = f' data-figma-id="{node.get("id")}"{style_str}'
132:     
133:     if not children and text_content:
134:         return f"{indent}<{tag}{attrs_str}>{html.escape(text_content)}</{tag}>"
135:         
136:     html_lines = [f"{indent}<{tag}{attrs_str}>"]
137:     if text_content:
138:         html_lines.append(f"{indent}  {html.escape(text_content)}")
139:         
140:     for child in children:
141:         html_lines.append(render_inline_html(child, indent_level + 1))
142:         
143:     html_lines.append(f"{indent}</{tag}>")
144:     return "\n".join(html_lines)
145: 
146: def main():
147:     parser = argparse.ArgumentParser(description="Extract Figma raw context and generate inline HTML")
148:     parser.add_argument("--input", default="workspace/figma/figma.raw-context.json")
