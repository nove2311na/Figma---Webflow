 27: def compile_node(element: Any, operations: list[dict[str, Any]], parent_node_id: str | None = None) -> str | None:
 28:     """Recursively compile HTML elements into build plan operations."""
 29:     if not hasattr(element, "name") or element.name is None:
 30:         return None
 31: 
 32:     tag = element.name
 33:     classes = element.get("class", [])
 34:     figma_id = element.get("data-figma-node") or f"gen-{element.name}-{len(operations)}"
 35:     
 36:     # Map HTML tags to Webflow native element types
 37:     el_type = "div"
 38:     if tag in ("h1", "h2", "h3", "h4", "h5", "h6"):
 39:         el_type = "heading"
 40:     elif tag == "p":
 41:         el_type = "paragraph"
 42:     elif tag == "span":
 43:         el_type = "text-block"
 44:     elif tag == "a":
 45:         el_type = "link"
 46:     elif tag == "img":
 47:         el_type = "image"
 48:     elif tag == "input":
 49:         el_type = "input"
 50: 
 51:     # Create element operation
 52:     op = {
 53:         "type": "create_element",
 54:         "payload": {
 55:             "type": el_type,
 56:             "tag": tag,
 57:             "classes": classes,
 58:             "parent_id": parent_node_id,
 59:             "text": element.get_text(strip=True) if tag in ("p", "span", "h1", "h2", "h3", "h4", "h5", "h6", "a") and not element.find() else ""
 60:         },
 61:         "node_id": figma_id
 62:     }
 63:     
 64:     if tag == "img":
 65:         op["payload"]["src"] = element.get("src", "")
 66:         op["payload"]["alt"] = element.get("alt", "")
 67: 
 68:     operations.append(op)
 69: 
 70:     # Compile children
 71:     for child in element.find_all(recursive=False):
 72:         compile_node(child, operations, parent_node_id=figma_id)
 73: 
 74:     return figma_id
 75: 
 76: def compile_chunks(chunks_dir: Path, manifest: dict[str, Any]) -> list[dict[str, Any]]:
 77:     operations = []
 78:     
 79:     # Pre-seed classes if any
 80:     # (In a real run, classes are resolved from the Client-First contract)
 81:     
 82:     for chunk in manifest.get("chunks", []):
 83:         filename = chunk.get("filename")
 84:         chunk_type = chunk.get("type")
 85:         if chunk_type == "global-styles" or not filename:
 86:             continue
 87: 
 88:         chunk_path = chunks_dir / filename
 89:         if not chunk_path.exists():
 90:             continue
 91: 
 92:         content = chunk_path.read_text(encoding="utf-8")
 93:         
 94:         if USE_BS4:
 95:             soup = BeautifulSoup(content, "html.parser")
 96:             root_el = soup.find()
 97:             if root_el:
 98:                 compile_node(root_el, operations)
 99:         else:
100:             # Simple regex fallback if BS4 not installed
101:             # Extract classes and tags
102:             tags = re.findall(r'<([a-z1-6]+)([^>]*class="([^"]+)")?[^>]*>(.*?)</\1>', content, re.DOTALL)
103:             for idx, (tag, _, classes_str, text) in enumerate(tags):
104:                 classes = classes_str.split() if classes_str else []
105:                 operations.append({
106:                     "type": "create_element",
107:                     "payload": {
108:                         "type": tag,
109:                         "tag": tag,
110:                         "classes": classes,
111:                         "parent_id": None,
112:                         "text": text.strip() if "<" not in text else ""
113:                     },
114:                     "node_id": f"gen-regex-{idx}"
115:                 })
116: 
117:     return operations
118: 
119: def main():
120:     parser = argparse.ArgumentParser(description="Compile HTML Chunks into Webflow Native Build Plan")
121:     parser.add_argument("--chunks-dir", default="workspace/html/chunks")
122:     parser.add_argument("--meta", default="workspace/meta.json")
123:     parser.add_argument("--output", default="workspace/webflow-native/native-build-plan.json")
124:     args = parser.parse_args()
125: 
126:     chunks_dir = Path(args.chunks_dir)
127:     meta_path = Path(args.meta)
128:     output_path = Path(args.output)
129: 
130:     manifest_path = chunks_dir / "section-manifest.json"
131:     if not manifest_path.exists():
132:         print(f"Error: manifest {manifest_path} is missing.")
133:         sys.exit(1)
134: 
135:     manifest = load_json(manifest_path)
136:     meta = load_json(meta_path)
137: 
138:     print(f"Compiling native operations from chunks in {chunks_dir}...")
139:     operations = compile_chunks(chunks_dir, manifest)
140: 
141:     build_plan = {
142:         "version": "1.0.0",
143:         "target_site_id": meta.get("webflowSiteId", "mock-site-id"),
144:         "target_page_id": meta.get("webflowPageId", "mock-page-id"),
145:         "target_branch": "refactor/html-first-compiler-revised",
146:         "operations": operations,
147:         "metadata": {
148:             "compiled_at": datetime.now(timezone.utc).isoformat(),
149:             "total_operations": len(operations)
150:         }
151:     }
152: 
153:     output_path.parent.mkdir(parents=True, exist_ok=True)
154:     output_path.write_text(json.dumps(build_plan, indent=2, ensure_ascii=False), encoding="utf-8")
155: 
156:     print(f"Compilation complete. Serialized {len(operations)} operations to {output_path}.")
157:     sys.exit(0)
158: 
159: if __name__ == "__main__":
160:     main()
