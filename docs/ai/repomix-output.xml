<file path="scripts/gates/system/validate_build_contract.py">
  1: #!/usr/bin/env python3
  2: """Validate Webflow build contracts in blueprints before a parallel-section build.
  3: 
  4: Checks that every section carries an HTML contract + class list, that every referenced
  5: class either already exists in the per-project library or is declared in the page-level
  6: new_classes list, and that no two sections declare the same class name with conflicting
  7: definitions (the parallel-build naming-race guard).
  8: """
  9: from __future__ import annotations
 10: 
 11: import argparse
 12: import json
 13: import sys
 14: from pathlib import Path
 15: 
 16: sys.path.insert(0, str(Path(__file__).resolve().parents[3]))
 17: from tools.library_resolver import load_library
 18: 
 19: REQUIRED_SECTION_FIELDS = ("section_id", "html_contract", "cf_classes")
 20: REQUIRED_NEW_CLASS_FIELDS = ("name", "cf_category", "webflow_property", "value")
 21: 
 22: 
 23: def _iter_blueprints(root: Path, blueprint: str | None) -> list[Path]:
 24:     if blueprint:
 25:         return [Path(blueprint)]
 26:     bp_dir = root / "workspace" / "blueprints"
 27:     if not bp_dir.is_dir():
 28:         return []
 29:     return sorted(bp_dir.glob("*.json"))
 30: 
 31: 
 32: def validate_build_contract(root: Path, site_id: str, blueprint: str | None = None) -> list[str]:
 33:     """Return list of failure strings; empty list means pass."""
 34:     failures: list[str] = []
 35: 
 36:     # Existing classes from the per-project library
 37:     existing_classes: set[str] = set()
 38:     try:
 39:         library = load_library(root, site_id)
 40:         existing_classes = set(library.get("classes", {}).keys())
 41:     except FileNotFoundError:
 42:         failures.append(f"site_id '{site_id}' not in registry; cannot resolve library")
 43: 
 44:     blueprints = _iter_blueprints(root, blueprint)
 45:     if not blueprints:
 46:         failures.append("no blueprints found to validate")
 47:         return failures
 48: 
 49:     for bp_path in blueprints:
 50:         if not bp_path.exists():
 51:             failures.append(f"blueprint not found: {bp_path}")
 52:             continue
 53:         try:
 54:             data = json.loads(bp_path.read_text(encoding="utf-8"))
 55:         except json.JSONDecodeError as exc:
 56:             failures.append(f"{bp_path.name}: invalid JSON: {exc}")
 57:             continue
 58: 
 59:         name = bp_path.name
 60: 
 61:         # Page-level new_classes: detect duplicate names with conflicting definitions (naming-race guard)
 62:         new_classes: dict[str, str] = {}
 63:         for entry in data.get("new_classes", []):
 64:             for field in REQUIRED_NEW_CLASS_FIELDS:
 65:                 if not entry.get(field):
 66:                     failures.append(f"{name}: new_class missing field '{field}': {entry.get('name', '?')}")
 67:             cls_name = entry.get("name", "")
 68:             if not cls_name:
 69:                 continue
 70:             definition = json.dumps(
 71:                 {k: entry.get(k) for k in REQUIRED_NEW_CLASS_FIELDS},
 72:                 sort_keys=True,
 73:             )
 74:             if cls_name in new_classes and new_classes[cls_name] != definition:
 75:                 failures.append(
 76:                     f"{name}: class '{cls_name}' declared with conflicting definitions "
 77:                     "in new_classes (naming-race risk)"
 78:                 )
 79:             new_classes[cls_name] = definition
 80: 
 81:         declarable = existing_classes | set(new_classes.keys())
 82: 
 83:         sections = data.get("sections", [])
 84:         for i, section in enumerate(sections):
 85:             sec_id = section.get("section_id", f"index_{i}")
 86:             for field in REQUIRED_SECTION_FIELDS:
 87:                 if not section.get(field):
 88:                     failures.append(f"{name}: section '{sec_id}' missing field '{field}'")
 89: 
 90:             for cls in section.get("cf_classes", []):
 91:                 if cls not in declarable:
 92:                     failures.append(
 93:                         f"{name}: section '{sec_id}' references class '{cls}' "
 94:                         "not in library and not declared in new_classes"
 95:                     )
 96: 
 97:     return failures
 98: 
 99: 
100: def main(argv: list[str] | None = None) -> int:
101:     parser = argparse.ArgumentParser(description=__doc__)
102:     parser.add_argument("--site-id", required=True, help="Webflow site ID")
103:     parser.add_argument("--target", default=".", help="Repo root path")
104:     parser.add_argument("--blueprint", default=None, help="Single blueprint path (default: all workspace/blueprints/*.json)")
105:     args = parser.parse_args(argv)
106: 
107:     root = Path(args.target).resolve()
108:     failures = validate_build_contract(root, args.site_id, args.blueprint)
109: 
110:     if failures:
111:         print(f"build contract gate: fail ({args.site_id})")
112:         for failure in failures:
113:             print(f"  - {failure}")
114:         return 1
115: 
116:     print(f"build contract gate: pass ({args.site_id})")
117:     return 0
118: 
119: 
120: if __name__ == "__main__":
121:     raise SystemExit(main())
</file>

