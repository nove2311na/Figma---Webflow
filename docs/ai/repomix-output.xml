43:             
44:     # Check known variables missing: --_layout---spacing--medium, --_layout---spacing--global-padding, --_theme---text-color--primary
45:     known_variables = ["--_layout---spacing--medium", "--_layout---spacing--global-padding", "--_theme---text-color--primary"]
46:     for kv in known_variables:
47:         if kv not in allowed_variables:
48:             errors.append(f"Expected variable '{kv}' is missing from allowed_variables.")
49:             
