142:     """Suggest Client-First class decisions from a small Figma property sample.
143: 
144:     The helper is intentionally conservative: it returns mapping candidates with
145:     source rules, but the architect still decides final class application.
146:     """
147:     library = class_map or load_client_first_class_map()
148:     mappings = library.get("figma_property_map", [])
149:     suggestions: list[dict[str, str]] = []
150:     property_text = " ".join(f"{key}={value}" for key, value in figma_properties.items()).lower()
151: 
152:     for mapping in mappings:
153:         signals = mapping.get("signals", [])
154:         if any(str(signal).lower() in property_text for signal in signals):
155:             suggestions.append(
156:                 {
157:                     "figma_property": str(mapping.get("figma_property", "")),
158:                     "client_first_decision": str(mapping.get("client_first_decision", "")),
159:                     "source": "knowledge-base/client-first-class-map.json",
160:                 }
