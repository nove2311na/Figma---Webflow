 1: #!/usr/bin/env python3
 2: """Validate Claude skill anatomy for the MAS workspace."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import re
 7: from pathlib import Path
 8: 
 9: 
10: REQUIRED_RESOURCE_DIRS = ("references", "scripts", "assets")
11: REQUIRED_SECTIONS = ("## Use When", "## Workflow", "## Validation")
12: 
13: 
14: def read_text(path: Path) -> str:
15:     try:
16:         return path.read_text(encoding="utf-8", errors="ignore")
17:     except OSError:
18:         return ""
19: 
20: 
21: def parse_frontmatter(text: str) -> dict[str, str]:
22:     if not text.startswith("---\n"):
23:         return {}
24:     end = text.find("\n---", 4)
25:     if end == -1:
26:         return {}
27:     values: dict[str, str] = {}
28:     for line in text[4:end].splitlines():
29:         if ":" not in line:
30:             continue
31:         key, value = line.split(":", 1)
32:         values[key.strip()] = value.strip()
33:     return values
34: 
35: 
36: def validate_skill(skill_dir: Path) -> list[str]:
37:     failures: list[str] = []
38:     skill_file = skill_dir / "SKILL.md"
39:     text = read_text(skill_file)
40:     if not text.strip():
41:         return [f"{skill_file.as_posix()} is missing or empty"]
42: 
43:     frontmatter = parse_frontmatter(text)
44:     name = frontmatter.get("name", "")
45:     description = frontmatter.get("description", "")
46:     if not re.fullmatch(r"[a-z0-9-]{1,64}", name):
47:         failures.append(f"{skill_file.as_posix()} has invalid name")
48:     if len(description) < 40:
49:         failures.append(f"{skill_file.as_posix()} needs a trigger-oriented description")
50: 
51:     for section in REQUIRED_SECTIONS:
52:         if section not in text:
53:             failures.append(f"{skill_file.as_posix()} missing section {section}")
54: 
55:     for directory in REQUIRED_RESOURCE_DIRS:
56:         if not (skill_dir / directory).is_dir():
57:             failures.append(f"{skill_dir.as_posix()} missing {directory}/")
58: 
59:     if len(text.splitlines()) > 500:
60:         failures.append(f"{skill_file.as_posix()} exceeds 500 lines")
61:     return failures
62: 
63: 
64: def validate(root: Path) -> list[str]:
65:     skills_root = root / ".claude" / "skills"
66:     if not skills_root.is_dir():
67:         return [".claude/skills is missing"]
68: 
69:     failures: list[str] = []
70:     skill_dirs = sorted(path for path in skills_root.iterdir() if path.is_dir())
71:     if not skill_dirs:
72:         return [".claude/skills has no skill folders"]
73:     for skill_dir in skill_dirs:
74:         failures.extend(validate_skill(skill_dir))
75:     return failures
76: 
77: 
78: def main(argv: list[str] | None = None) -> int:
79:     parser = argparse.ArgumentParser(description=__doc__)
80:     parser.add_argument("--target", default=".", help="Folder to validate")
81:     args = parser.parse_args(argv)
82: 
83:     failures = validate(Path(args.target).resolve())
84:     if failures:
85:         print("skill anatomy gate: fail")
86:         for failure in failures:
87:             print(f"  - {failure}")
88:         return 1
89:     print("skill anatomy gate: pass")
90:     return 0
91: 
92: 
93: if __name__ == "__main__":
94:     raise SystemExit(main())
</file>

