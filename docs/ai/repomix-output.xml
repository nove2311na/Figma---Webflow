  1: #!/usr/bin/env python3
  2: """Slice the compiled HTML page into self-contained section chunks."""
  3: from __future__ import annotations
  4: 
  5: import argparse
  6: import json
  7: import re
  8: import sys
  9: from datetime import datetime, timezone
 10: from pathlib import Path
 11: from typing import Any
 12: 
 13: # Try to use BeautifulSoup, fallback to simple custom regex if missing
 14: try:
 15:     from bs4 import BeautifulSoup
 16:     USE_BS4 = True
 17: except ImportError:
 18:     USE_BS4 = False
 19: 
 20: def load_json(path: Path) -> Any:
 21:     if not path.exists():
 22:         return {}
 23:     return json.loads(path.read_text(encoding="utf-8"))
 24: 
 25: def slice_with_bs4(html_content: str, chunks_dir: Path) -> list[dict[str, Any]]:
 26:     soup = BeautifulSoup(html_content, "html.parser")
 27:     chunks = []
 28: 
 29:     # 1. Global styles chunk
 30:     head = soup.find("head")
 31:     styles_html = ""
 32:     if head:
 33:         links = head.find_all("link")
 34:         styles_html = "\n".join(str(link) for link in links)
 35: 
 36:     global_styles_filename = "section-global-styles.html"
 37:     (chunks_dir / global_styles_filename).write_text(styles_html, encoding="utf-8")
 38:     chunks.append({
 39:         "id": "global-styles",
 40:         "name": "Global Styles",
 41:         "filename": global_styles_filename,
 42:         "figma_node_id": "global",
 43:         "type": "global-styles"
 44:     })
 45: 
 46:     # 2. Main structure checks
 47:     # Find navigation elements (either <nav> or element with nav classes)
 48:     nav_el = soup.find("nav") or soup.find(class_=re.compile("nav"))
 49:     if nav_el:
 50:         nav_filename = "section-nav.html"
 51:         (chunks_dir / nav_filename).write_text(str(nav_el), encoding="utf-8")
 52:         chunks.append({
 53:             "id": "nav",
 54:             "name": "Navigation Bar",
 55:             "filename": nav_filename,
 56:             "figma_node_id": nav_el.get("data-figma-node", "nav"),
 57:             "type": "nav"
 58:         })
 59: 
 60:     # Find sections
 61:     # They can be inside <main> or directly in body
 62:     main_el = soup.find("main") or soup.find(class_="main-wrapper")
 63:     sections_container = main_el if main_el else soup.find("body")
 64:     
 65:     sections = []
 66:     if sections_container:
 67:         # Find direct children that are sections or sections by tag/class
 68:         sections = sections_container.find_all(["section", "div"], recursive=False)
 69:         # If no direct children found, search for sections inside container
 70:         if not sections:
 71:             sections = sections_container.find_all("section")
 72: 
 73:     section_idx = 1
 74:     for sec in sections:
 75:         # Avoid double-slicing nav/footer
 76:         if sec.name in ("nav", "footer") or "nav" in "".join(sec.get("class", [])) or "footer" in "".join(sec.get("class", [])):
 77:             continue
 78:             
 79:         figma_id = sec.get("data-figma-node", f"section-{section_idx}")
 80:         sec_name = sec.get("data-section") or sec.get("id") or f"section-{section_idx}"
 81:         slug = re.sub(r"[^a-z0-9\-]", "", sec_name.lower().replace(" ", "-").replace("_", "-"))
 82:         filename = f"section-{slug}.html"
 83: 
 84:         (chunks_dir / filename).write_text(str(sec), encoding="utf-8")
 85:         chunks.append({
 86:             "id": f"section-{slug}",
 87:             "name": sec_name,
 88:             "filename": filename,
 89:             "figma_node_id": figma_id,
 90:             "type": "section"
 91:         })
 92:         section_idx += 1
 93: 
 94:     # 3. Footer chunk
 95:     footer_el = soup.find("footer") or soup.find(class_=re.compile("footer"))
 96:     if footer_el:
 97:         footer_filename = "section-footer.html"
 98:         (chunks_dir / footer_filename).write_text(str(footer_el), encoding="utf-8")
 99:         chunks.append({
100:             "id": "footer",
101:             "name": "Footer",
102:             "filename": footer_filename,
103:             "figma_node_id": footer_el.get("data-figma-node", "footer"),
104:             "type": "footer"
105:         })
106: 
107:     return chunks
108: 
109: def slice_with_regex(html_content: str, chunks_dir: Path) -> list[dict[str, Any]]:
110:     # Fallback regex-based slicing if beautifulsoup is absent
111:     chunks = []
112:     
113:     # Extract link stylesheets
114:     links = re.findall(r'<link[^>]*href="[^"]*"[^>]*>', html_content)
115:     styles_html = "\n".join(links)
116:     global_styles_filename = "section-global-styles.html"
117:     (chunks_dir / global_styles_filename).write_text(styles_html, encoding="utf-8")
118:     chunks.append({
119:         "id": "global-styles",
120:         "name": "Global Styles",
121:         "filename": global_styles_filename,
122:         "figma_node_id": "global",
123:         "type": "global-styles"
124:     })
125: 
126:     # Regex search for sections with data-section/data-figma-node
127:     sections = re.findall(r'(<(section|div)[^>]*data-section="([^"]*)"[^>]*>.*?</\2>)', html_content, re.DOTALL)
128:     for idx, (full_tag, tag_name, sec_name) in enumerate(sections, 1):
129:         figma_match = re.search(r'data-figma-node="([^"]*)"', full_tag)
130:         figma_id = figma_match.group(1) if figma_match else f"section-{idx}"
131:         
132:         slug = re.sub(r"[^a-z0-9\-]", "", sec_name.lower().replace(" ", "-").replace("_", "-"))
133:         filename = f"section-{slug}.html"
134:         (chunks_dir / filename).write_text(full_tag, encoding="utf-8")
135:         
136:         sec_type = "section"
137:         if "nav" in slug or "navbar" in slug:
138:             sec_type = "nav"
139:         elif "footer" in slug:
140:             sec_type = "footer"
141: 
142:         chunks.append({
143:             "id": f"section-{slug}",
144:             "name": sec_name,
145:             "filename": filename,
146:             "figma_node_id": figma_id,
147:             "type": sec_type
148:         })
149: 
150:     return chunks
151: 
152: def main():
153:     parser = argparse.ArgumentParser(description="Slice HTML file into section chunks")
154:     parser.add_argument("--input", default="workspace/html/page.html")
155:     parser.add_argument("--chunks-dir", default="workspace/html/chunks")
156:     args = parser.parse_args()
157: 
158:     input_path = Path(args.input)
159:     chunks_dir = Path(args.chunks_dir)
160: 
161:     if not input_path.exists():
162:         print(f"Error: Input HTML file {input_path} is missing.")
163:         sys.exit(1)
164: 
165:     html_content = input_path.read_text(encoding="utf-8")
166:     chunks_dir.mkdir(parents=True, exist_ok=True)
167: 
168:     if USE_BS4:
169:         print("Using BeautifulSoup for robust HTML parsing.")
170:         chunks = slice_with_bs4(html_content, chunks_dir)
171:     else:
172:         print("Warning: bs4 not found. Using fallback regex parser.")
173:         chunks = slice_with_regex(html_content, chunks_dir)
174: 
175:     # Write manifest
176:     manifest_payload = {
177:         "version": "1.0.0",
178:         "chunks": chunks,
179:         "metadata": {
180:             "sliced_at": datetime.now(timezone.utc).isoformat(),
181:             "total_chunks": len(chunks)
182:         }
183:     }
184: 
185:     manifest_path = chunks_dir / "section-manifest.json"
186:     manifest_path.write_text(json.dumps(manifest_payload, indent=2, ensure_ascii=False), encoding="utf-8")
187: 
188:     print(f"Slicing complete. Sliced {len(chunks)} chunks under {chunks_dir}.")
189:     sys.exit(0)
190: 
191: if __name__ == "__main__":
192:     main()
</file>

<file path="scripts/pipeline/sync_library_to_webflow.py">
 1: #!/usr/bin/env python3
 2: """Print ordered Webflow MCP style_tool calls to sync a project library.
 3: 
 4: This script does not call Webflow MCP directly. It loads the per-project
 5: client-first-library.json and prints structured payloads for each class,
 6: which the LLM agent then executes via Webflow MCP style_tool.
 7: 
 8: After the LLM executes all calls, the script stamps last_synced in registry.json.
 9: """
10: from __future__ import annotations
11: 
12: import argparse
13: import json
14: import sys
15: from datetime import datetime, timezone
16: from pathlib import Path
17: 
18: sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
19: from tools.library_resolver import load_library, load_registry, update_last_synced
20: 
21: 
22: def build_style_payloads(library: dict) -> list[dict]:
23:     """Convert library classes to Webflow style_tool payload list."""
24:     payloads = []
25:     for class_name, class_def in library.get("classes", {}).items():
26:         payloads.append({
27:             "class_name": class_name,
28:             "webflow_property": class_def["webflow_property"],
29:             "value": class_def["value"],
30:             "figma_token": class_def.get("figma_token", ""),
31:             "cf_category": class_def.get("cf_category", ""),
32:         })
33:     return payloads
34: 
35: 
36: def print_sync_instructions(root: Path, site_id: str) -> int:
37:     """Load library and print MCP call sequence for LLM to execute."""
38:     try:
39:         library = load_library(root, site_id)
40:     except FileNotFoundError as exc:
41:         print(f"sync failed: {exc}")
42:         return 1
43: 
44:     payloads = build_style_payloads(library)
45:     if not payloads:
46:         print(f"sync skipped: no classes defined in library for {site_id}")
47:         return 0
48: 
49:     print("=" * 60)
50:     print("WEBFLOW STYLE SYNC INSTRUCTIONS")
51:     print("=" * 60)
52:     print(f"\nProject (Webflow site ID): {site_id}")
53:     print(f"Library version: {library.get('version', 'unknown')}")
54:     print(f"Classes to sync: {len(payloads)}")
55:     print()
56:     print("For each payload below, call Webflow MCP style_tool:")
57:     print("  style_tool(site_id=<site_id>, class_name=..., styles={property: value})")
58:     print()
59:     print("PAYLOADS (ordered by cf_category):")
60:     sorted_payloads = sorted(payloads, key=lambda p: (p["cf_category"], p["class_name"]))
61:     for i, payload in enumerate(sorted_payloads, 1):
62:         print(f"\n[{i}/{len(sorted_payloads)}]")
63:         print(f"  class_name:        {payload['class_name']}")
64:         print(f"  webflow_property:  {payload['webflow_property']}")
65:         print(f"  value:             {payload['value']}")
66:         print(f"  figma_token:       {payload['figma_token']}")
67: 
68:     print()
69:     print("After all calls succeed, run:")
70:     print(f"  python scripts/sync_library_to_webflow.py --site-id {site_id} --mark-synced")
71:     print("=" * 60)
72:     return 0
73: 
74: 
75: def main(argv: list[str] | None = None) -> int:
76:     parser = argparse.ArgumentParser(description=__doc__)
77:     parser.add_argument("--site-id", required=True, help="Webflow site ID")
78:     parser.add_argument("--target", default=".", help="Repo root path")
79:     parser.add_argument(
80:         "--mark-synced",
81:         action="store_true",
82:         help="Stamp last_synced in registry.json (call after LLM finishes MCP calls)",
83:     )
84:     args = parser.parse_args(argv)
85: 
86:     root = Path(args.target).resolve()
87: 
88:     if args.mark_synced:
89:         update_last_synced(root, args.site_id)
90:         print(f"last_synced stamped for {args.site_id}")
91:         return 0
92: 
93:     return print_sync_instructions(root, args.site_id)
94: 
95: 
96: if __name__ == "__main__":
97:     raise SystemExit(main())
