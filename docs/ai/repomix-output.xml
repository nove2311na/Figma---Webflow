 1: #!/usr/bin/env python3
 2: """Validate MAS phase transitions when runtime state exists."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import json
 7: from pathlib import Path
 8: from typing import Any
 9: 
10: 
11: def load_state(path: Path) -> list[dict[str, Any]]:
12:     payload = json.loads(path.read_text(encoding="utf-8"))
13:     if not isinstance(payload, list):
14:         raise ValueError("workspace/state.json must be a list")
15:     return [entry for entry in payload if isinstance(entry, dict)]
16: 
17: 
18: def has_blueprint_approval(entries: list[dict[str, Any]]) -> bool:
19:     for entry in entries:
20:         text = " ".join(str(entry.get(key, "")) for key in ("type", "phase", "message", "approver"))
21:         if "approval" in text.lower() and "phase_1_blueprint" in text and "Approved" in text and "user" in text:
22:             return True
23:     return False
24: 
25: 
26: def phase_2_started(entries: list[dict[str, Any]]) -> bool:
27:     for entry in entries:
28:         phase = str(entry.get("phase", ""))
29:         entry_type = str(entry.get("type", "")).lower()
30:         if phase == "phase_2_webflow_build" or "webflow" in entry_type:
31:             return True
32:     return False
33: 
34: 
35: def validate(root: Path) -> list[str]:
36:     state_path = root / "workspace" / "state.json"
37:     if not state_path.exists():
38:         return []
39:     try:
40:         entries = load_state(state_path)
41:     except (OSError, json.JSONDecodeError, ValueError) as error:
42:         return [f"workspace/state.json invalid: {error}"]
43: 
44:     if phase_2_started(entries) and not has_blueprint_approval(entries):
45:         return ["phase_2_webflow_build started without user approval for phase_1_blueprint"]
46:     return []
47: 
48: 
49: def main(argv: list[str] | None = None) -> int:
50:     parser = argparse.ArgumentParser(description=__doc__)
51:     parser.add_argument("--target", default=".", help="Folder to validate")
52:     args = parser.parse_args(argv)
53: 
54:     failures = validate(Path(args.target).resolve())
55:     if failures:
56:         print("phase state gate: fail")
57:         for failure in failures:
58:             print(f"  - {failure}")
59:         return 1
60:     print("phase state gate: pass")
61:     return 0
62: 
63: 
64: if __name__ == "__main__":
65:     raise SystemExit(main())
</file>

