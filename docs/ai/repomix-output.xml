 29: @dataclass(frozen=True)
 30: class RgbaColor:
 31:     """RGBA color with 0-255 RGB channels and 0-1 alpha."""
 32: 
 33:     r: int
 34:     g: int
 35:     b: int
 36:     a: float = 1.0
 37: 
 38: 
 39: def to_rem(value: str | int | float | list[str | int | float] | None) -> str:
 40:     """Convert px-like values into rem strings."""
 41:     if value is None:
 42:         return "0rem"
 43: 
 44:     def convert_one(item: str | int | float) -> str:
 45:         try:
 46:             number = float(str(item).replace("px", ""))
 47:         except ValueError:
 48:             return "0rem"
 49:         if number == 0:
 50:             return "0rem"
 51:         converted = number / BASE_FONT_SIZE
 52:         return f"{converted:.3f}".rstrip("0").rstrip(".") + "rem"
 53: 
 54:     if isinstance(value, list):
 55:         return " ".join(convert_one(item) for item in value)
 56:     if isinstance(value, str) and " " in value.strip():
 57:         return " ".join(convert_one(item) for item in value.split())
 58:     return convert_one(value)
 59: 
 60: 
 61: def slugify(value: str) -> str:
 62:     """Create a Client-First-safe slug while preserving underscores."""
 63:     normalized = unicodedata.normalize("NFD", value.lower().strip())
 64:     ascii_text = "".join(char for char in normalized if unicodedata.category(char) != "Mn")
 65:     cleaned = re.sub(r"[^a-z0-9\s\-_]", "", ascii_text)
 66:     return re.sub(r"-+", "-", re.sub(r"\s+", "-", cleaned)).strip("-")
 67: 
 68: 
 69: def format_class(prefix: str, element: str | None = None, *, is_utility: bool = False) -> str:
 70:     """Format a class according to Client-First naming conventions."""
 71:     clean_prefix = slugify(prefix)
 72:     if is_utility or not element:
 73:         return clean_prefix
 74:     return f"{clean_prefix}_{slugify(element)}"
 75: 
 76: 
 77: def parse_color(value: str | dict[str, Any]) -> RgbaColor | None:
 78:     """Parse a hex string or Figma RGBA dict into a color."""
 79:     if isinstance(value, dict) and {"r", "g", "b"}.issubset(value):
 80:         return RgbaColor(
 81:             r=round(float(value["r"]) * 255),
 82:             g=round(float(value["g"]) * 255),
 83:             b=round(float(value["b"]) * 255),
 84:             a=round(float(value.get("a", 1)), 2),
 85:         )
 86:     if isinstance(value, str):
 87:         return hex_to_rgba(value)
 88:     return None
 89: 
 90: 
 91: def hex_to_rgba(value: str) -> RgbaColor | None:
 92:     """Parse #RGB, #RGBA, #RRGGBB, or #RRGGBBAA."""
 93:     text = value.strip().lstrip("#")
 94:     if len(text) in {3, 4}:
 95:         text = "".join(char * 2 for char in text)
 96:     if len(text) not in {6, 8} or not re.fullmatch(r"[0-9a-fA-F]+", text):
 97:         return None
 98:     alpha = int(text[6:8], 16) / 255 if len(text) == 8 else 1.0
 99:     return RgbaColor(
100:         r=int(text[0:2], 16),
101:         g=int(text[2:4], 16),
102:         b=int(text[4:6], 16),
103:         a=round(alpha, 2),
104:     )
105: 
106: 
107: def color_distance(first: str | dict[str, Any], second: str | dict[str, Any]) -> float:
108:     """Return Euclidean color distance including alpha."""
109:     first_color = parse_color(first)
110:     second_color = parse_color(second)
111:     if not first_color or not second_color:
112:         return 1000.0
113:     return math.sqrt(
114:         (second_color.r - first_color.r) ** 2
115:         + (second_color.g - first_color.g) ** 2
116:         + (second_color.b - first_color.b) ** 2
117:         + ((second_color.a - first_color.a) * 255) ** 2
118:     )
119: 
