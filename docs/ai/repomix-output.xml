  1: """Registry-based resolver for multi-project Client-First libraries."""
  2: from __future__ import annotations
  3: 
  4: import json
  5: from datetime import datetime, timezone
  6: from pathlib import Path
  7: from typing import Any
  8: 
  9: LIBRARIES_DIR = "knowledge-base/libraries"
 10: REGISTRY_FILENAME = "registry.json"
 11: LIBRARY_FILENAME = "client-first-library.json"
 12: TOKEN_MAP_FILENAME = "figma-token-map.json"
 13: CHANGELOG_FILENAME = "changelog.json"
 14: 
 15: 
 16: def _registry_path(target: Path) -> Path:
 17:     return target / LIBRARIES_DIR / REGISTRY_FILENAME
 18: 
 19: 
 20: def _library_dir(target: Path, site_id: str) -> Path:
 21:     return target / LIBRARIES_DIR / site_id
 22: 
 23: 
 24: def load_registry(target: Path) -> dict[str, Any]:
 25:     """Load registry.json; return empty registry if missing."""
 26:     path = _registry_path(target)
 27:     if not path.exists():
 28:         return {"version": "1.0", "projects": []}
 29:     return json.loads(path.read_text(encoding="utf-8"))
 30: 
 31: 
 32: def _save_registry(target: Path, registry: dict[str, Any]) -> None:
 33:     path = _registry_path(target)
 34:     path.parent.mkdir(parents=True, exist_ok=True)
 35:     path.write_text(json.dumps(registry, indent=2, ensure_ascii=False), encoding="utf-8")
 36: 
 37: 
 38: def resolve_library(target: Path, site_id: str) -> Path:
 39:     """Return path to client-first-library.json for site_id.
 40: 
 41:     Raises FileNotFoundError when the project is not registered.
 42:     """
 43:     registry = load_registry(target)
 44:     for project in registry.get("projects", []):
 45:         if project.get("webflow_site_id") == site_id:
 46:             lib_path = target / project["library_path"]
 47:             return lib_path
 48:     raise FileNotFoundError(f"site_id '{site_id}' not found in registry")
 49: 
 50: 
 51: def load_library(target: Path, site_id: str) -> dict[str, Any]:
 52:     """Load client-first-library.json for site_id."""
 53:     lib_path = resolve_library(target, site_id)
 54:     return json.loads(lib_path.read_text(encoding="utf-8"))
 55: 
 56: 
 57: def register_project(target: Path, meta: dict[str, Any]) -> None:
 58:     """Upsert a project entry into registry.json.
 59: 
 60:     meta must contain: webflow_site_id, figma_file_id, name.
 61:     Optional: library_path (auto-derived if absent).
 62:     """
 63:     site_id: str = meta["webflow_site_id"]
 64:     library_path = meta.get(
 65:         "library_path",
 66:         f"{LIBRARIES_DIR}/{site_id}/{LIBRARY_FILENAME}",
 67:     )
 68:     entry = {
 69:         "id": site_id,
 70:         "name": meta.get("name", site_id),
 71:         "webflow_site_id": site_id,
 72:         "figma_file_id": meta.get("figma_file_id", ""),
 73:         "library_path": library_path,
 74:         "last_synced": meta.get("last_synced", None),
 75:     }
 76:     registry = load_registry(target)
 77:     existing_ids = [p["webflow_site_id"] for p in registry["projects"]]
 78:     if site_id in existing_ids:
 79:         registry["projects"] = [
 80:             entry if p["webflow_site_id"] == site_id else p
 81:             for p in registry["projects"]
 82:         ]
 83:     else:
 84:         registry["projects"].append(entry)
 85:     _save_registry(target, registry)
 86: 
 87: 
 88: def scaffold_library_dir(target: Path, site_id: str, figma_file_id: str = "") -> list[str]:
 89:     """Create per-project library directory and seed files if missing.
 90: 
 91:     Returns list of action strings describing what was created or kept.
 92:     """
 93:     lib_dir = _library_dir(target, site_id)
 94:     lib_dir.mkdir(parents=True, exist_ok=True)
 95:     actions: list[str] = [f"library dir ready: {LIBRARIES_DIR}/{site_id}/"]
 96: 
 97:     shell_library: dict[str, Any] = {
 98:         "project_id": site_id,
 99:         "webflow_site_id": site_id,
100:         "figma_file_id": figma_file_id,
101:         "version": "0.1.0",
102:         "updated_at": datetime.now(timezone.utc).isoformat(),
103:         "classes": {},
104:     }
105:     shell_token_map: dict[str, Any] = {
106:         "figma_file_id": figma_file_id,
107:         "updated_at": datetime.now(timezone.utc).isoformat(),
108:         "naming_convention": {
109:             "pattern": "{cf_category}-{semantic_name}",
110:             "categories": [
111:                 "text-color",
112:                 "background-color",
113:                 "border-color",
114:                 "spacing",
115:                 "font-size",
116:                 "font-weight",
117:                 "border-radius",
118:                 "opacity",
119:             ],
120:         },
121:         "mappings": {},
122:     }
123: 
124:     for filename, payload in [
125:         (LIBRARY_FILENAME, shell_library),
126:         (TOKEN_MAP_FILENAME, shell_token_map),
127:         (CHANGELOG_FILENAME, []),
128:     ]:
129:         file_path = lib_dir / filename
130:         if file_path.exists():
131:             actions.append(f"kept {LIBRARIES_DIR}/{site_id}/{filename}")
132:         else:
133:             file_path.write_text(
134:                 json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8"
135:             )
136:             actions.append(f"created {LIBRARIES_DIR}/{site_id}/{filename}")
137: 
138:     return actions
139: 
140: 
141: def update_last_synced(target: Path, site_id: str) -> None:
142:     """Stamp last_synced timestamp for site_id in registry."""
143:     registry = load_registry(target)
144:     for project in registry["projects"]:
145:         if project["webflow_site_id"] == site_id:
146:             project["last_synced"] = datetime.now(timezone.utc).isoformat()
147:             break
148:     _save_registry(target, registry)
149: 
150: 
151: if __name__ == "__main__":
152:     # Smoke test: load registry from current dir
153:     import sys
154: 
155:     root = Path(sys.argv[1]) if len(sys.argv) > 1 else Path(".")
156:     reg = load_registry(root)
157:     print(f"registry loaded — {len(reg.get('projects', []))} project(s)")
158:     for p in reg.get("projects", []):
159:         print(f"  {p['webflow_site_id']} → {p['library_path']}")
