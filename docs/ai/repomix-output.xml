25: 
26: def phase_2_started(entries: list[dict[str, Any]]) -> bool:
27:     for entry in entries:
28:         phase = str(entry.get("phase", ""))
29:         entry_type = str(entry.get("type", "")).lower()
30:         if phase == "phase_2_webflow_build" or "webflow" in entry_type:
31:             return True
32:     return False
