 1: #!/usr/bin/env python3
 2: """Scan committed files for common secret patterns."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import re
 7: from pathlib import Path
 8: 
 9: 
10: SKIP_DIRS = {".git", ".venv", "venv", "__pycache__", "node_modules", "workspace", "archives"}
11: SECRET_PATTERNS = [
12:     re.compile(r"(?i)(api[_-]?key|secret|token|password)\s*[:=]\s*['\"]?[A-Za-z0-9_\-]{16,}"),
13:     re.compile(r"sk-[A-Za-z0-9]{20,}"),
14:     re.compile(r"xox[baprs]-[A-Za-z0-9\-]{20,}"),
15: ]
16: 
17: 
18: def should_skip(path: Path) -> bool:
19:     return any(part in SKIP_DIRS for part in path.parts)
20: 
21: 
22: def read_text(path: Path) -> str:
23:     try:
24:         return path.read_text(encoding="utf-8", errors="ignore")
25:     except OSError:
26:         return ""
27: 
28: 
29: def scan(root: Path) -> list[str]:
30:     findings: list[str] = []
31:     for path in root.rglob("*"):
32:         if should_skip(path) or not path.is_file():
33:             continue
34:         text = read_text(path)
35:         if any(pattern.search(text) for pattern in SECRET_PATTERNS):
36:             findings.append(str(path.relative_to(root)))
37:     return findings
38: 
39: 
40: def main(argv: list[str] | None = None) -> int:
41:     parser = argparse.ArgumentParser(description=__doc__)
42:     parser.add_argument("--target", default=".", help="Folder to scan")
43:     args = parser.parse_args(argv)
44: 
45:     findings = scan(Path(args.target).resolve())
46:     if findings:
47:         print("secret scan: fail")
48:         for finding in findings:
49:             print(f"  - {finding}")
50:         return 1
51:     print("secret scan: pass")
52:     return 0
53: 
54: 
55: if __name__ == "__main__":
56:     raise SystemExit(main())
</file>

