<file path="scripts/run_all_gates.py">
 1: #!/usr/bin/env python3
 2: """B.4: Run all 11 Python gates, print summary table, return non-zero on any failure.
 3: 
 4: Sequential execution. Each gate is run as a subprocess; we capture exit code + tail
 5: of stdout/stderr. No interactive prompts.
 6: """
 7: from __future__ import annotations
 8: 
 9: import json
10: import subprocess
11: import sys
12: from datetime import datetime, timezone
13: from pathlib import Path
14: 
15: REPO = Path(__file__).resolve().parents[1]
16: GATES_DIR = REPO / "scripts" / "gates"
17: EVIDENCE = REPO / "workspace" / "sections" / "gate-results.json"
18: 
19: # (gate_script, extra_args). --target is appended.
20: GATES = [
21:     ("validate_agentic_structure.py", []),
22:     ("scan_secrets.py", []),
23:     ("validate_skills.py", []),
24:     ("validate_agent_system_spec.py", []),
25:     ("validate_workspace_artifacts.py", []),
26:     ("validate_phase_state.py", []),
27:     ("validate_relative_paths.py", []),
28:     ("validate_client_first_library.py", []),
29:     ("validate_build_contract.py", ["--site-id", "6920a7d45c61690dd10ac690"]),
30:     ("validate_project_library.py", ["--site-id", "6920a7d45c61690dd10ac690"]),
31:     ("run_quality_gate.py", []),
32: ]
33: 
34: 
35: def main() -> int:
36:     results = []
37:     print(f"{'gate':<40} {'exit':<6} {'status':<8} duration_ms")
38:     print("-" * 80)
39:     for script, extra in GATES:
40:         path = GATES_DIR / script
41:         if not path.exists():
42:             results.append({"script": script, "exit": 127, "status": "MISSING", "stdout": "", "stderr": "script not found"})
43:             print(f"{script:<40} {'n/a':<6} {'MISSING':<8}")
44:             continue
45:         cmd = [sys.executable, str(path), "--target", str(REPO), *extra]
46:         t0 = datetime.now(timezone.utc)
47:         try:
48:             r = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
49:             dt = (datetime.now(timezone.utc) - t0).total_seconds() * 1000
50:             status = "PASS" if r.returncode == 0 else "FAIL"
51:             results.append({
52:                 "script": script,
53:                 "exit": r.returncode,
54:                 "status": status,
55:                 "stdout_tail": r.stdout[-400:] if r.stdout else "",
56:                 "stderr_tail": r.stderr[-400:] if r.stderr else "",
57:                 "duration_ms": int(dt),
58:             })
59:             print(f"{script:<40} {r.returncode:<6} {status:<8} {int(dt)}")
60:             if r.returncode != 0 and r.stderr:
61:                 print(f"  stderr: {r.stderr.strip()[-200:]}")
62:         except subprocess.TimeoutExpired:
63:             results.append({"script": script, "exit": -1, "status": "TIMEOUT"})
64:             print(f"{script:<40} TIMEOUT")
65:     print("-" * 80)
66:     passed = sum(1 for r in results if r["status"] == "PASS")
67:     failed = sum(1 for r in results if r["status"] == "FAIL")
68:     print(f"SUMMARY: {passed} pass, {failed} fail of {len(GATES)}")
69:     EVIDENCE.parent.mkdir(parents=True, exist_ok=True)
70:     EVIDENCE.write_text(json.dumps({"ran_at": datetime.now(timezone.utc).isoformat(), "results": results}, indent=2), encoding="utf-8")
71:     return 0 if failed == 0 else 1
72: 
73: 
74: if __name__ == "__main__":
75:     raise SystemExit(main())
</file>

