  1: #!/usr/bin/env python3
  2: """Validate the per-project Client-First library for a given Webflow site ID."""
  3: from __future__ import annotations
  4: 
  5: import argparse
  6: import json
  7: import sys
  8: from pathlib import Path
  9: 
 10: # Allow importing from tools/ when run as CLI from repo root
 11: sys.path.insert(0, str(Path(__file__).resolve().parents[3]))
 12: from tools.library_resolver import (
 13:     CHANGELOG_FILENAME,
 14:     LIBRARIES_DIR,
 15:     LIBRARY_FILENAME,
 16:     TOKEN_MAP_FILENAME,
 17:     _library_dir,
 18:     load_registry,
 19:     resolve_library,
 20: )
 21: 
 22: REQUIRED_CF_CATEGORIES = {
 23:     "text-color",
 24:     "background-color",
 25:     "border-color",
 26:     "spacing",
 27:     "font-size",
 28:     "font-weight",
 29:     "border-radius",
 30:     "opacity",
 31: }
 32: REQUIRED_CLASS_FIELDS = {"figma_token", "cf_category", "webflow_property", "value"}
 33: REQUIRED_TOKEN_MAP_ENTRY_FIELDS = {"figma_value"}
 34: 
 35: 
 36: def validate_project_library(root: Path, site_id: str) -> list[str]:
 37:     """Return list of failure strings; empty list means pass."""
 38:     failures: list[str] = []
 39:     
 40:     # 1. Registry entry exists
 41:     registry = load_registry(root)
 42:     registered_ids = {p["webflow_site_id"] for p in registry.get("projects", [])}
 43:     if site_id not in registered_ids:
 44:         failures.append(f"site_id '{site_id}' not in registry.json")
 45: 
 46:     try:
 47:         lib_dir = resolve_library(root, site_id).parent
 48:     except Exception:
 49:         lib_dir = _library_dir(root, site_id)
 50: 
 51:     # 2. Library dir exists
 52:     if not lib_dir.is_dir():
 53:         failures.append(f"library dir missing: {lib_dir.relative_to(root).as_posix() if lib_dir.is_relative_to(root) else lib_dir}")
 54:         return failures  # Cannot continue without dir
 55: 
 56:     # 3. client-first-library.json
 57:     lib_path = lib_dir / LIBRARY_FILENAME
 58:     if not lib_path.exists():
 59:         failures.append(f"{LIBRARY_FILENAME} missing for {site_id}")
 60:     else:
 61:         try:
 62:             library = json.loads(lib_path.read_text(encoding="utf-8"))
 63:         except json.JSONDecodeError as exc:
 64:             failures.append(f"{LIBRARY_FILENAME} invalid JSON: {exc}")
 65:             library = {}
 66: 
 67:         for field in ("project_id", "webflow_site_id", "figma_file_id", "version", "classes"):
 68:             if not library.get(field):
 69:                 failures.append(f"{LIBRARY_FILENAME} missing or empty field: {field}")
 70: 
 71:         classes = library.get("classes", {})
 72:         if not isinstance(classes, dict):
 73:             failures.append(f"{LIBRARY_FILENAME} 'classes' must be an object")
 74:         else:
 75:             for class_name, class_def in classes.items():
 76:                 for req in REQUIRED_CLASS_FIELDS:
 77:                     if not class_def.get(req):
 78:                         failures.append(
 79:                             f"{LIBRARY_FILENAME} class '{class_name}' missing field: {req}"
 80:                         )
 81:                 cf_cat = class_def.get("cf_category", "")
 82:                 if cf_cat and cf_cat not in REQUIRED_CF_CATEGORIES:
 83:                     failures.append(
 84:                         f"{LIBRARY_FILENAME} class '{class_name}' invalid cf_category: '{cf_cat}'"
 85:                     )
 86: 
 87:     # 4. figma-token-map.json
 88:     token_map_path = lib_dir / TOKEN_MAP_FILENAME
 89:     if not token_map_path.exists():
 90:         failures.append(f"{TOKEN_MAP_FILENAME} missing for {site_id}")
 91:     else:
 92:         try:
 93:             token_map = json.loads(token_map_path.read_text(encoding="utf-8"))
 94:         except json.JSONDecodeError as exc:
 95:             failures.append(f"{TOKEN_MAP_FILENAME} invalid JSON: {exc}")
 96:             token_map = {}
 97: 
 98:         for field in ("figma_file_id", "mappings", "naming_convention"):
 99:             if field not in token_map:
100:                 failures.append(f"{TOKEN_MAP_FILENAME} missing field: {field}")
101: 
102:         mappings = token_map.get("mappings", {})
103:         for token_path, entry in mappings.items():
104:             if not entry.get("figma_value"):
105:                 failures.append(
106:                     f"{TOKEN_MAP_FILENAME} token '{token_path}' missing figma_value"
107:                 )
108: 
109:         # 5. Cross-check: every class in library has a source token in token-map
110:         if "classes" in locals() and isinstance(classes, dict) and isinstance(mappings, dict):
111:             for class_name, class_def in classes.items():
112:                 token = class_def.get("figma_token", "")
113:                 if token and token not in mappings:
114:                     failures.append(
115:                         f"class '{class_name}' references figma_token '{token}' "
116:                         f"not found in {TOKEN_MAP_FILENAME}"
117:                     )
118: 
119:     # 6. changelog.json exists and non-empty if library has classes
120:     changelog_path = lib_dir / CHANGELOG_FILENAME
121:     if not changelog_path.exists():
122:         failures.append(f"{CHANGELOG_FILENAME} missing for {site_id}")
123:     else:
124:         try:
125:             changelog = json.loads(changelog_path.read_text(encoding="utf-8"))
126:         except json.JSONDecodeError as exc:
127:             failures.append(f"{CHANGELOG_FILENAME} invalid JSON: {exc}")
128:             changelog = []
129: 
130:         lib_classes = {}
131:         if lib_path.exists():
132:             try:
133:                 lib_classes = json.loads(lib_path.read_text(encoding="utf-8")).get("classes", {})
134:             except json.JSONDecodeError:
135:                 pass
136:         if lib_classes and not changelog:
137:             failures.append(
138:                 f"{CHANGELOG_FILENAME} is empty but library has classes — "
139:                 "every class must have at least one changelog entry"
140:             )
141: 
142:     return failures
143: 
144: 
145: def main(argv: list[str] | None = None) -> int:
146:     parser = argparse.ArgumentParser(description=__doc__)
147:     parser.add_argument("--site-id", required=True, help="Webflow site ID")
148:     parser.add_argument("--target", default=".", help="Repo root path")
149:     args = parser.parse_args(argv)
150: 
151:     root = Path(args.target).resolve()
152:     failures = validate_project_library(root, args.site_id)
153: 
154:     if failures:
155:         print(f"project library gate: fail ({args.site_id})")
156:         for failure in failures:
157:             print(f"  - {failure}")
158:         return 1
159: 
160:     print(f"project library gate: pass ({args.site_id})")
161:     return 0
162: 
163: 
164: if __name__ == "__main__":
165:     raise SystemExit(main())
