<file path="scripts/gates/run_quality_gate.py">
  1: #!/usr/bin/env python3
  2: """Run a lightweight quality gate for the MAS Claude Code workspace."""
  3: from __future__ import annotations
  4: 
  5: import argparse
  6: import json
  7: import sys
  8: from pathlib import Path
  9: 
 10: sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
 11: from scripts.gates.system.validate_project_library import validate_project_library
 12: from scripts.gates.system.validate_build_contract import validate_build_contract
 13: 
 14: 
 15: REQUIRED_TEXT = {
 16:     "CLAUDE.md": ["Claude Code", "python", "Webflow", "client-first-library-contract.json"],
 17:     "agentic/memory/team-memory.md": ["Hard Invariants", "Agent Team", "standalone baseline"],
 18:     "agentic/policies/runtime-instructions.md": ["Claude Code", "Python", "Webflow", "approval"],
 19:     "agentic/orchestration/sop.md": ["Phase 0", "Phase 1", "Phase 2", "Phase 3", "approval"],
 20:     "agentic/orchestration/reflection-loop.md": ["reflection_review", "revise", "Stop Conditions"],
 21:     "agentic/specs/system/agent-system-spec.md": ["Seed Input", "Agents", "MCP Servers", "Standalone Architecture Baseline"],
 22:     "agentic/specs/contracts/figma-to-client-first-mapping.md": ["figma_property", "client_first_class", "class_strategy"],
 23:     "agentic/specs/contracts/visual-qa-evidence-contract.md": ["[APPROVED]", "[FIX]", "webflow_state_ref"],
 24:     "agentic/knowledge/client-first-library.md": ["client-first-class-map.json", "figma_property", "webflow_property"],
 25:     "agentic/policies/tool-risk-levels.md": ["R0", "R4", "risk_class"],
 26:     "agentic/policies/approval-gates.md": ["Webflow writes", "logical blueprint rendered to physical HTML"],
 27:     ".user_versions/VERSION_HISTORY.md": ["v0.1.0", "v0.2.0", "v0.3.0"],
 28: }
 29: 
 30: FORBIDDEN_TEXT = {
 31:     "CLAUDE.md": ["n" + "pm run"],
 32:     "README.md": ["n" + "pm ci", "Gemi" + "ni-native"],
 33:     "agentic/policies/runtime-instructions.md": ["." + "gemini/agents", "." + "gemini/skills"],
 34:     "agentic/orchestration/sop.md": ["Node" + ".js"],
 35: }
 36: 
 37: 
 38: def read_text(path: Path) -> str:
 39:     try:
 40:         return path.read_text(encoding="utf-8", errors="ignore")
 41:     except OSError:
 42:         return ""
 43: 
 44: 
 45: def _load_workspace_site_id(root: Path) -> str:
 46:     """Return webflowSiteId from workspace/meta.json if present; empty string otherwise."""
 47:     meta_path = root / "workspace" / "meta.json"
 48:     if not meta_path.exists():
 49:         return ""
 50:     try:
 51:         meta = json.loads(meta_path.read_text(encoding="utf-8"))
 52:         return meta.get("webflowSiteId", "")
 53:     except (json.JSONDecodeError, OSError):
 54:         return ""
 55: 
 56: 
 57: def validate(root: Path) -> list[str]:
 58:     failures: list[str] = []
 59:     for relative_path, phrases in REQUIRED_TEXT.items():
 60:         text = read_text(root / relative_path)
 61:         if not text.strip():
 62:             failures.append(f"{relative_path} is missing or empty")
 63:             continue
 64:         for phrase in phrases:
 65:             if phrase not in text:
 66:                 failures.append(f"{relative_path} missing phrase {phrase}")
 67: 
 68:     for relative_path, phrases in FORBIDDEN_TEXT.items():
 69:         text = read_text(root / relative_path)
 70:         for phrase in phrases:
 71:             if phrase in text:
 72:                 failures.append(f"{relative_path} contains deprecated phrase {phrase}")
 73: 
 74:     # Auto-run project library gate when workspace has a webflowSiteId
 75:     site_id = _load_workspace_site_id(root)
 76:     if site_id:
 77:         lib_failures = validate_project_library(root, site_id)
 78:         for failure in lib_failures:
 79:             failures.append(f"[project-library:{site_id}] {failure}")
 80: 
 81:         # Build-contract gate only when blueprints exist (a build is in progress)
 82:         if (root / "workspace" / "blueprints").is_dir() and any(
 83:             (root / "workspace" / "blueprints").glob("*.json")
 84:         ):
 85:             contract_failures = validate_build_contract(root, site_id)
 86:             for failure in contract_failures:
 87:                 failures.append(f"[build-contract:{site_id}] {failure}")
 88: 
 89:     return failures
 90: 
 91: 
 92: def run_sub_gate(gate_script: str) -> list[str]:
 93:     import subprocess
 94:     # gate_script can be:
 95:     #   "pipeline/validate_foo.py"  -> resolves to scripts/gates/pipeline/validate_foo.py
 96:     #   "system/validate_foo.py"    -> resolves to scripts/gates/system/validate_foo.py
 97:     #   absolute or already-rooted path (contains os.sep or starts with scripts/)
 98:     if gate_script.startswith("scripts/"):
 99:         resolved = gate_script
100:     else:
101:         resolved = f"scripts/gates/{gate_script}"
102:     res = subprocess.run(
103:         [sys.executable, resolved],
104:         capture_output=True,
105:         text=True,
106:         encoding="utf-8"
107:     )
108:     if res.returncode != 0:
109:         return [f"Gate {gate_script} failed: {res.stderr.strip() or res.stdout.strip()}"]
110:     return []
111: 
112: def main(argv: list[str] | None = None) -> int:
113:     parser = argparse.ArgumentParser(description=__doc__)
114:     parser.add_argument("--target", default=".", help="Folder to validate")
115:     parser.add_argument("--profile", default=None, help="Validation profile (e.g. html-first)")
116:     args = parser.parse_args(argv)
117: 
118:     root = Path(args.target).resolve()
119:     
120:     if args.profile == "html-first":
121:         print("Running HTML-first compiler validation profile...")
122:         failures = []
123:         
124:         # List of gates to execute sequentially
125:         gates = [
126:             # System gates first (structure must be valid before pipeline checks)
127:             "system/validate_agentic_structure.py",
128:             "system/validate_workspace_artifacts.py",
129:             # Pipeline gates in compiler order
130:             "pipeline/validate_css_contract.py",
131:             "pipeline/validate_css_index.py",
132:             "pipeline/validate_figma_normalization.py",
133:             "pipeline/validate_semantic_ir.py",
134:             "pipeline/validate_html_blueprint.py",
135:             "pipeline/validate_asset_policy.py",
136:             "pipeline/validate_html_chunks.py",
137:             "pipeline/validate_resolver_benchmark.py",
138:             "pipeline/validate_native_build_plan.py"
139:         ]
140:         
141:         for gate in gates:
142:             print(f"Executing gate: {gate}...")
143:             failures.extend(run_sub_gate(gate))
144:             
145:         if failures:
146:             print("\nquality gate [html-first]: FAIL")
147:             for failure in failures:
148:                 print(f"  - {failure}")
149:             return 1
150:         print("\nquality gate [html-first]: PASS")
151:         return 0
152: 
153:     failures = validate(root)
154:     if failures:
155:         print("quality gate: fail")
156:         for failure in failures:
157:             print(f"  - {failure}")
158:         return 1
159:     print("quality gate: pass")
160:     return 0
161: 
162: 
163: if __name__ == "__main__":
164:     raise SystemExit(main())
</file>

