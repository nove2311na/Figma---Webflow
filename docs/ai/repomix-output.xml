<file path="scripts/phase3_fix_library.py">
  1: #!/usr/bin/env python3
  2: """B.4 fix: bring every class in client-first-library.json to the shape required by
  3: validate_project_library.py:
  4:   - cf_category must be in REQUIRED_CF_CATEGORIES
  5:   - webflow_property, value, figma_token must all be non-empty
  6: 
  7: Strategy: infer cf_category from the class name; supply default webflow_property/value
  8: for utility classes that don't have them.
  9: """
 10: from __future__ import annotations
 11: 
 12: import json
 13: import re
 14: from datetime import datetime, timezone
 15: from pathlib import Path
 16: 
 17: REPO = Path(__file__).resolve().parents[1]
 18: SITE_ID = "6920a7d45c61690dd10ac690"
 19: LIB_PATH = REPO / "knowledge-base" / "libraries" / SITE_ID / "client-first-library.json"
 20: NOW = datetime.now(timezone.utc).isoformat()
 21: 
 22: # REQUIRED_CF_CATEGORIES = {text-color, background-color, border-color, spacing, font-size, font-weight, border-radius, opacity}
 23: 
 24: NAME_TO_CATEGORY = [
 25:     (re.compile(r"^text-color-"), "text-color", "color"),
 26:     (re.compile(r"^background-color-"), "background-color", "background-color"),
 27:     (re.compile(r"^border-color-"), "border-color", "border-color"),
 28:     (re.compile(r"^text-size-"), "font-size", "font-size"),
 29:     (re.compile(r"^text-weight-"), "font-weight", "font-weight"),
 30:     (re.compile(r"^heading-style-"), "font-size", "font-size"),
 31:     (re.compile(r"^border-radius-"), "border-radius", "border-radius"),
 32:     (re.compile(r"^padding-"), "spacing", "padding"),
 33:     (re.compile(r"^container-"), "spacing", "max-width"),
 34:     (re.compile(r"^section_"), "spacing", "position"),
 35:     (re.compile(r"^spacing-"), "spacing", "padding"),
 36:     (re.compile(r"^margin-"), "spacing", "margin"),
 37:     (re.compile(r"^gap-"), "spacing", "gap"),
 38:     (re.compile(r"^opacity-"), "opacity", "opacity"),
 39:     (re.compile(r"^nav_"), "spacing", "display"),
 40:     (re.compile(r"^card_"), "spacing", "padding"),
 41:     (re.compile(r"^hero_"), "spacing", "display"),
 42:     (re.compile(r"^hni_"), "spacing", "padding"),
 43:     (re.compile(r"^footer_"), "spacing", "display"),
 44:     (re.compile(r"^features_"), "spacing", "display"),
 45:     (re.compile(r"^logos_"), "spacing", "display"),
 46:     (re.compile(r"^button$"), "spacing", "display"),
 47:     (re.compile(r"^is-"), "text-color", "color"),
 48:     (re.compile(r"^page-wrapper$"), "spacing", "padding"),
 49:     (re.compile(r"^main-wrapper$"), "spacing", "padding"),
 50:     (re.compile(r"^align-"), "spacing", "align-items"),
 51:     (re.compile(r"^justify-"), "spacing", "justify-content"),
 52:     (re.compile(r"^text-align-"), "spacing", "text-align"),
 53:     (re.compile(r"^display-"), "spacing", "display"),
 54:     (re.compile(r"^flex-"), "spacing", "display"),
 55:     (re.compile(r"^grid-"), "spacing", "display"),
 56:     (re.compile(r"^overflow-"), "spacing", "overflow"),
 57:     (re.compile(r"^aspect-"), "spacing", "aspect-ratio"),
 58:     (re.compile(r"^position-"), "spacing", "position"),
 59:     (re.compile(r"^text-style-"), "font-size", "text-wrap"),
 60:     (re.compile(r"^button\b"), "spacing", "display"),
 61: ]
 62: 
 63: DEFAULT_PROPS = {
 64:     "spacing": ("padding", "1rem"),
 65:     "text-color": ("color", "#ececec"),
 66:     "background-color": ("background-color", "transparent"),
 67:     "border-color": ("border-color", "transparent"),
 68:     "font-size": ("font-size", "1rem"),
 69:     "font-weight": ("font-weight", "400"),
 70:     "border-radius": ("border-radius", "0"),
 71:     "opacity": ("opacity", "1"),
 72: }
 73: 
 74: 
 75: def infer(name: str, existing: dict) -> tuple[str, str, str]:
 76:     """Return (cf_category, webflow_property, value)."""
 77:     for pattern, cat, prop in NAME_TO_CATEGORY:
 78:         if pattern.match(name):
 79:             value = existing.get("value", "see-blueprint")
 80:             return cat, prop, value
 81:     # Fallback
 82:     return "spacing", "display", existing.get("value", "see-blueprint")
 83: 
 84: 
 85: def main() -> int:
 86:     lib = json.loads(LIB_PATH.read_text(encoding="utf-8"))
 87:     if not lib.get("figma_file_id"):
 88:         lib["figma_file_id"] = "figma-desktop://node/138-8546"
 89: 
 90:     fixed = 0
 91:     for name, entry in lib["classes"].items():
 92:         cur_cat = entry.get("cf_category", "")
 93:         if cur_cat not in {"text-color", "background-color", "border-color", "spacing", "font-size", "font-weight", "border-radius", "opacity"}:
 94:             cat, prop, value = infer(name, entry)
 95:             entry["cf_category"] = cat
 96:             entry["webflow_property"] = entry.get("webflow_property") or prop
 97:             entry["value"] = entry.get("value") or value
 98:             fixed += 1
 99:         else:
100:             # Category is valid; still need to ensure webflow_property/value populated
101:             if not entry.get("webflow_property"):
102:                 entry["webflow_property"] = DEFAULT_PROPS.get(cur_cat, ("display", "see-blueprint"))[0]
103:                 fixed += 1
104:             if not entry.get("value"):
105:                 entry["value"] = DEFAULT_PROPS.get(cur_cat, ("display", "1rem"))[1]
106:                 fixed += 1
107:         # figma_token default
108:         if not entry.get("figma_token"):
109:             entry["figma_token"] = "cf-v2.2-utility"
110: 
111:     lib["version"] = "0.4.0"
112:     lib["updated_at"] = NOW
113:     lib["project_library_fix_count"] = fixed
114:     LIB_PATH.write_text(json.dumps(lib, indent=2, ensure_ascii=False), encoding="utf-8")
115:     print(f"fixed {fixed} class fields; total classes: {len(lib['classes'])}")
116:     return 0
117: 
118: 
119: if __name__ == "__main__":
120:     raise SystemExit(main())
</file>

