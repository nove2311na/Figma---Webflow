 24: def extract_node_styles(node: dict[str, Any]) -> dict[str, str]:
 25:     """Extract and normalize inline styles from Figma node properties."""
 26:     raw_styles = node.get("styles", {})
 27:     inline_styles = {}
 28:     
 29:     for key, val in raw_styles.items():
 30:         # Keep background color, color, border, text styles, margins, padding, gaps, widths, heights
 31:         if key in (
 32:             "background-color", "color", "border-color", "border-width", "border-style",
 33:             "padding", "padding-left", "padding-right", "padding-top", "padding-bottom",
 34:             "margin", "margin-left", "margin-right", "margin-top", "margin-bottom",
 35:             "font-size", "font-family", "font-weight", "line-height", "text-align",
 36:             "gap", "width", "height", "display", "flex-direction", "justify-content",
 37:             "align-items", "flex-wrap"
 38:         ):
 39:             inline_styles[key] = str(val)
 40:             
 41:     # Add display properties if flex-direction or layoutMode suggests flex
 42:     layout_mode = node.get("layoutMode")
 43:     if layout_mode in ("HORIZONTAL", "VERTICAL"):
 44:         inline_styles["display"] = "flex"
 45:         inline_styles["flex-direction"] = "row" if layout_mode == "HORIZONTAL" else "column"
 46:         
 47:         # Figma spacing mode to css justification
 48:         primary_align = node.get("primaryAxisAlignItems")
 49:         counter_align = node.get("counterAxisAlignItems")
 50:         if primary_align == "CENTER":
 51:             inline_styles["justify-content"] = "center"
 52:         elif primary_align == "MAX":
 53:             inline_styles["justify-content"] = "flex-end"
 54:         elif primary_align == "SPACE_BETWEEN":
 55:             inline_styles["justify-content"] = "space-between"
 56:             
 57:         if counter_align == "CENTER":
 58:             inline_styles["align-items"] = "center"
 59:         elif counter_align == "MAX":
 60:             inline_styles["align-items"] = "flex-end"
 61:             
 62:         item_spacing = node.get("itemSpacing")
 63:         if item_spacing is not None:
 64:             inline_styles["gap"] = f"{item_spacing}px"
 65:             
 66:     # Normalize explicit paddings if layout properties are present
 67:     paddings = []
 68:     for side in ("top", "right", "bottom", "left"):
 69:         pad_val = node.get(f"padding{side.capitalize()}")
 70:         if pad_val is not None:
 71:             inline_styles[f"padding-{side}"] = f"{pad_val}px"
 72:             
 73:     return inline_styles
