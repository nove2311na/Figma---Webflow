 1: #!/usr/bin/env python3
 2: """Deterministic verification gate for Webflow Native Build Plan."""
 3: from __future__ import annotations
 4: 
 5: import json
 6: import sys
 7: from pathlib import Path
 8: from typing import Any
 9: 
10: def load_json(path: Path) -> dict:
11:     if not path.exists():
12:         return {}
13:     try:
14:         return json.loads(path.read_text(encoding="utf-8"))
15:     except Exception:
16:         return {}
17: 
18: def validate_plan(root: Path) -> list[str]:
19:     failures = []
20:     plan_path = root / "workspace" / "webflow-native" / "native-build-plan.json"
21:     contract_path = root / "knowledge-base" / "generated" / "client-first-library-contract.json"
22: 
23:     if not plan_path.exists():
24:         failures.append("native-build-plan.json file is missing.")
25:         return failures
26: 
27:     plan = load_json(plan_path)
28:     contract = load_json(contract_path)
29:     allowed_classes = set(contract.get("allowed_classes", [])) | set(contract.get("allowed_combo_classes", [])) | set(contract.get("structural_convention_classes", [])) | set(contract.get("reserved_webflow_classes", []))
30: 
31:     # Basic validations
32:     for key in ("version", "target_site_id", "target_page_id", "operations", "metadata"):
33:         if key not in plan:
34:             failures.append(f"Build plan missing key: {key}")
35: 
36:     branch = plan.get("target_branch", "")
37:     if not branch or branch in ("main", "master", "production"):
38:         failures.append(f"Forbidden target branch: '{branch}'. Mutations must operate on a temporary site branch.")
39: 
40:     operations = plan.get("operations", [])
41:     for idx, op in enumerate(operations):
42:         op_type = op.get("type")
43:         payload = op.get("payload", {})
44:         node_id = op.get("node_id", "unknown")
45: 
46:         if op_type == "create_element":
47:             classes = payload.get("classes", [])
48:             for cls in classes:
49:                 if cls not in allowed_classes and not cls.startswith("w-"):
50:                     failures.append(f"Operation {idx} (node {node_id}) uses class '{cls}' not found in CSS contract.")
51: 
52:         # Ensure no destructive operations without approval
53:         if op_type == "delete_element":
54:             failures.append(f"Operation {idx}: Destructive operations (delete_element) are forbidden during refactor runs.")
55: 
56:     return failures
57: 
58: def main() -> int:
59:     root = Path(__file__).resolve().parents[3]
60:     failures = validate_plan(root)
61:     if failures:
62:         print("native-build-plan-gate: FAIL")
63:         for f in failures:
64:             print(f"  - {f}")
65:         return 1
66:     print("native-build-plan-gate: PASS")
67:     return 0
68: 
