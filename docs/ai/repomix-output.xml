 1: #!/usr/bin/env python3
 2: """Validate the structured Client-First class library."""
 3: from __future__ import annotations
 4: 
 5: import argparse
 6: import json
 7: from pathlib import Path
 8: from typing import Any
 9: 
10: 
11: REQUIRED_GROUPS = ("structure", "typography", "spacing", "color", "layout", "state")
12: REQUIRED_TOP_LEVEL = ("version", "principles", "class_groups", "figma_property_map")
13: REQUIRED_ITEM_KEYS = ("applies_to", "figma_signals", "webflow_properties", "class_strategy")
14: 
15: 
16: def load_json(path: Path) -> Any:
17:     return json.loads(path.read_text(encoding="utf-8"))
18: 
19: 
20: def validate(root: Path) -> list[str]:
21:     path = root / "knowledge-base" / "client-first-class-map.json"
22:     if not path.is_file():
23:         return ["knowledge-base/client-first-class-map.json is missing"]
24: 
25:     failures: list[str] = []
26:     try:
27:         payload = load_json(path)
28:     except (OSError, json.JSONDecodeError) as error:
29:         return [f"knowledge-base/client-first-class-map.json invalid JSON: {error}"]
30: 
31:     if not isinstance(payload, dict):
32:         return ["knowledge-base/client-first-class-map.json must be an object"]
33: 
34:     for key in REQUIRED_TOP_LEVEL:
35:         if key not in payload:
36:             failures.append(f"class map missing {key}")
37: 
38:     class_groups = payload.get("class_groups", {})
39:     if not isinstance(class_groups, dict):
40:         failures.append("class_groups must be an object")
41:         class_groups = {}
42: 
43:     for group in REQUIRED_GROUPS:
44:         items = class_groups.get(group)
45:         if not isinstance(items, list) or not items:
46:             failures.append(f"class_groups.{group} must be a non-empty list")
47:             continue
48:         for index, item in enumerate(items):
49:             if not isinstance(item, dict):
50:                 failures.append(f"class_groups.{group}[{index}] must be an object")
51:                 continue
52:             if "class" not in item and "class_pattern" not in item:
53:                 failures.append(f"class_groups.{group}[{index}] needs class or class_pattern")
54:             for key in REQUIRED_ITEM_KEYS:
55:                 if key not in item or item[key] in ("", [], {}):
56:                     failures.append(f"class_groups.{group}[{index}] missing {key}")
57: 
58:     mappings = payload.get("figma_property_map", [])
59:     if not isinstance(mappings, list) or len(mappings) < 8:
60:         failures.append("figma_property_map must contain at least 8 mapping rules")
61:     else:
62:         for index, item in enumerate(mappings):
63:             if not isinstance(item, dict):
64:                 failures.append(f"figma_property_map[{index}] must be an object")
65:                 continue
66:             for key in ("figma_property", "signals", "client_first_decision"):
67:                 if key not in item or item[key] in ("", [], {}):
68:                     failures.append(f"figma_property_map[{index}] missing {key}")
69: 
70:     theory_path = root / "knowledge-base" / "client-first-theory.md"
71:     if not theory_path.is_file():
72:         failures.append("knowledge-base/client-first-theory.md is missing")
73:     return failures
74: 
75: 
76: def main(argv: list[str] | None = None) -> int:
77:     parser = argparse.ArgumentParser(description=__doc__)
78:     parser.add_argument("--target", default=".", help="Folder to validate")
79:     args = parser.parse_args(argv)
80: 
81:     failures = validate(Path(args.target).resolve())
82:     if failures:
83:         print("client-first library gate: fail")
84:         for failure in failures:
85:             print(f"  - {failure}")
86:         return 1
87:     print("client-first library gate: pass")
88:     return 0
89: 
90: 
91: if __name__ == "__main__":
92:     raise SystemExit(main())
