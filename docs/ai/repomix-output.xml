 14: BASE_FONT_SIZE = 16
 15: COLOR_THRESHOLD = 15
 16: SPACING_SCALE = {
 17:     "tiny": 4,
 18:     "small": 8,
 19:     "medium": 16,
 20:     "large": 32,
 21:     "huge": 64,
 22:     "section-small": 40,
 23:     "section-medium": 80,
