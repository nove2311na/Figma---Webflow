 1: class CSSClassifier:
 2:     def __init__(self):
 3:         pass
 4: 
 5:     @staticmethod
 6:     def classify_class(class_name):
 7:         """
 8:         Classifies a CSS class name into Client-First categories.
 9:         """
10:         if class_name.startswith("fs-styleguide_") or class_name.startswith("fs-styleguide"):
11:             return "styleguide-only"
12:         elif class_name.startswith("w-"):
13:             return "native"
14:         elif class_name.startswith("padding-") or class_name.startswith("margin-") or class_name.startswith("spacer-"):
15:             return "spacing"
16:         elif class_name.startswith("gap-"):
17:             return "gap"
18:         elif class_name.startswith("grid-"):
19:             return "grid"
20:         elif class_name.startswith("flex-"):
21:             return "flex"
22:         elif class_name.startswith("heading-style-") or class_name.startswith("text-size-") or class_name.startswith("text-weight-") or class_name.startswith("text-style-"):
23:             return "typography"
24:         elif class_name.startswith("text-color-") or class_name.startswith("background-color-") or class_name.startswith("border-color-"):
25:             return "color"
26:         elif any(comp in class_name for comp in ["button", "form", "nav", "card", "section", "header", "footer", "menu", "input", "dropdown"]):
27:             return "components"
28:         else:
29:             return "custom"
