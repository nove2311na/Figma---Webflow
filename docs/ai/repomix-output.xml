<file path="tools/css_indexer/parser.py">
 1: import re
 2: import hashlib
 3: import tinycss2
 4: 
 5: class CSSParser:
 6:     def __init__(self):
 7:         pass
 8: 
 9:     @staticmethod
10:     def get_md5_hash(file_path):
11:         hasher = hashlib.md5()
12:         with open(file_path, "rb") as f:
13:             buf = f.read()
14:             hasher.update(buf)
15:         return hasher.hexdigest()
16: 
17:     def parse_css_file(self, file_path):
18:         """
19:         Parses a CSS file and extracts rules, declarations, variables, classes, selectors, and media queries.
20:         """
21:         with open(file_path, "r", encoding="utf-8") as f:
22:             css_content = f.read()
23: 
24:         rules = tinycss2.parse_stylesheet(css_content, skip_comments=True)
25:         
26:         extracted_data = {
27:             "classes": set(),
28:             "combo_classes": set(),
29:             "variables": {},  # var_name -> list of values with media scope
30:             "selectors": set(),
31:             "breakpoints": set(),
32:             "declarations": [] # list of (selector, property, value, media)
33:         }
34: 
35:         self._parse_rules(rules, extracted_data, media_query=None)
36:         return extracted_data
37: 
38:     def _parse_rules(self, rules, data, media_query=None):
39:         for rule in rules:
40:             if rule.type == "qualified-rule":
41:                 # Parse selector
42:                 selector_str = tinycss2.serialize(rule.prelude).strip()
43:                 if not selector_str:
44:                     continue
45:                 
46:                 # Split by commas for multiple selectors
47:                 selectors = [s.strip() for s in selector_str.split(",")]
48:                 for sel in selectors:
49:                     data["selectors"].add(sel)
50:                     
51:                     # Extract classes and combo classes
52:                     # E.g. .button.is-secondary -> class 'button', combo 'is-secondary'
53:                     # E.g. .container-large -> class 'container-large'
54:                     # Split by space to get individual element selectors
55:                     parts = sel.split()
56:                     for part in parts:
57:                         # Extract all class sequences: .class1.class2
58:                         classes_in_part = re.findall(r"\.([a-zA-Z0-9_-]+)", part)
59:                         if classes_in_part:
60:                             # The first one is the main class
61:                             main_class = classes_in_part[0]
62:                             data["classes"].add(main_class)
63:                             # Subsequent ones in the same compounded selector are combo classes
64:                             for combo in classes_in_part[1:]:
65:                                 data["combo_classes"].add(combo)
66: 
67:                 # Parse declarations
68:                 decls = tinycss2.parse_declaration_list(rule.content, skip_comments=True)
69:                 for decl in decls:
70:                     if decl.type == "declaration":
71:                         prop_name = decl.name
72:                         prop_val = tinycss2.serialize(decl.value).strip()
73:                         
74:                         # Check if it is a CSS variable definition
75:                         if prop_name.startswith("--"):
76:                             if prop_name not in data["variables"]:
77:                                 data["variables"][prop_name] = []
78:                             data["variables"][prop_name].append({
79:                                 "value": prop_val,
80:                                 "media": media_query
81:                             })
82:                         
83:                         for sel in selectors:
84:                             data["declarations"].append({
85:                                 "selector": sel,
86:                                 "property": prop_name,
87:                                 "value": prop_val,
88:                                 "media": media_query
89:                             })
90:                             
91:             elif rule.type == "at-rule" and rule.at_keyword == "media":
92:                 media_str = tinycss2.serialize(rule.prelude).strip()
93:                 data["breakpoints"].add(media_str)
94:                 # Parse sub-rules recursively
95:                 sub_rules = tinycss2.parse_rule_list(rule.content, skip_comments=True)
96:                 self._parse_rules(sub_rules, data, media_query=media_str)
