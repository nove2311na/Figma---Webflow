  1: #!/usr/bin/env python3
  2: import os
  3: import sys
  4: import json
  5: import re
  6: import argparse
  7: from datetime import datetime, timezone
  8: 
  9: # Add root folder to sys.path
 10: root_dir = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", ".."))
 11: sys.path.append(root_dir)
 12: 
 13: def load_json(path):
 14:     with open(path, "r", encoding="utf-8") as f:
 15:         return json.load(f)
 16: 
 17: def save_json(path, data):
 18:     os.makedirs(os.path.dirname(path), exist_ok=True)
 19:     with open(path, "w", encoding="utf-8") as f:
 20:         json.dump(data, f, indent=2, ensure_ascii=False)
 21: 
 22: def calculate_match(node, signature):
 23:     # Weights
 24:     w_name = 0.20
 25:     w_type = 0.10
 26:     w_topology = 0.50
 27:     w_tokens = 0.20
 28: 
 29:     # 1. Name Score
 30:     name = node.get("name", "")
 31:     name_pattern = signature.get("name_pattern", "")
 32:     s_name = 0.0
 33:     if name_pattern:
 34:         try:
 35:             if re.search(name_pattern, name, re.IGNORECASE):
 36:                 s_name = 1.0
 37:             elif re.search(signature.get("component_id", ""), name, re.IGNORECASE):
 38:                 s_name = 0.5
 39:         except Exception:
 40:             if signature.get("component_id", "").lower() in name.lower():
 41:                 s_name = 0.5
 42: 
 43:     # 2. Node Type Score
 44:     node_type = node.get("type", "")
 45:     sig_node_type = signature.get("node_type", "")
 46:     s_type = 1.0 if node_type == sig_node_type else 0.0
 47: 
 48:     # 3. Layout Topology Score
 49:     topology = signature.get("layout_topology", {})
 50:     children = node.get("children", [])
 51:     s_topology = 1.0
 52:     
 53:     if topology:
 54:         min_children = topology.get("min_children", 0)
 55:         max_children = topology.get("max_children", 999)
 56:         role_rules = topology.get("children", [])
 57:         
 58:         satisfied_roles = 0
 59:         total_roles = len(role_rules)
 60:         
 61:         # Track child assignments to avoid double-counting
 62:         used_child_ids = set()
 63:         
 64:         for rule in role_rules:
 65:             role_name_pattern = rule.get("name_pattern", ".*")
 66:             role_node_types = rule.get("node_types", [])
 67:             min_count = rule.get("min_count", 0)
 68:             max_count = rule.get("max_count", 999)
 69:             
 70:             matched_count = 0
 71:             for child in children:
 72:                 if matched_count >= max_count:
 73:                     break
 74:                 child_id = child.get("id")
 75:                 if child_id in used_child_ids:
 76:                     continue
 77:                 child_type = child.get("type", "")
 78:                 child_name = child.get("name", "")
 79:                 
 80:                 type_matches = not role_node_types or child_type in role_node_types
 81:                 name_matches = False
 82:                 try:
 83:                     name_matches = bool(re.search(role_name_pattern, child_name, re.IGNORECASE))
 84:                 except Exception:
 85:                     name_matches = True
 86:                     
 87:                 if type_matches and name_matches:
 88:                     matched_count += 1
 89:                     used_child_ids.add(child_id)
 90:             
 91:             if min_count <= matched_count <= max_count:
 92:                 satisfied_roles += 1
 93:         
 94:         if total_roles > 0:
 95:             s_topology = satisfied_roles / total_roles
 96:         else:
 97:             s_topology = 1.0
 98:             
 99:         # Penalize if child count is out of bounds
100:         child_count = len(children)
101:         if child_count < min_children or child_count > max_children:
102:             s_topology *= 0.5
103: 
104:     # 4. Token Cluster Score
105:     token_cluster = signature.get("token_cluster", {})
106:     s_tokens = 1.0
107:     if token_cluster:
108:         classes = token_cluster.get("classes", [])
109:         css_props = token_cluster.get("css_properties", [])
110:         
111:         matched_tokens = 0
112:         total_tokens = len(classes) + len(css_props)
113:         
114:         if total_tokens > 0:
115:             # Check classes
116:             node_classes = node.get("classes", [])
117:             # Also check if name contains class as fallback (slugified)
118:             slugified_name = name.lower().replace(" ", "-").replace("_", "-")
119:             for cls in classes:
120:                 if cls in node_classes or cls in slugified_name or cls in name.lower():
121:                     matched_tokens += 1
122:             
123:             # Check css properties from node styles if present
124:             node_styles = node.get("styles", {})
125:             for prop in css_props:
126:                 # Mock styles might have keys or properties
127:                 if prop in node_styles or prop in node.get("css_properties", []):
128:                     matched_tokens += 1
129:             
130:             s_tokens = matched_tokens / total_tokens
131: 
132:     # Total Score
133:     total_score = (w_name * s_name) + (w_type * s_type) + (w_topology * s_topology) + (w_tokens * s_tokens)
134:     return total_score
135: 
136: def walk_and_match(node, signatures, matched_list, unmatched_list, blockers, is_strict=True):
137:     node_type = node.get("type", "")
138:     node_name = node.get("name", "")
139:     node_id = node.get("id", "")
140: 
141:     # We evaluate frames, instances, or anything named with potential component triggers
142:     is_candidate = (node_type == "INSTANCE") or (node_type == "FRAME" and any(
143:         kw in node_name.lower() for kw in ["button", "card", "navbar", "nav", "footer", "form", "input", "group", "section"]
144:     ))
145: 
146:     if is_candidate:
147:         highest_score = 0.0
148:         best_sig = None
149:         
150:         for sig in signatures:
151:             score = calculate_match(node, sig)
152:             if score > highest_score:
153:                 highest_score = score
154:                 best_sig = sig
155:                 
156:         if best_sig and highest_score >= 0.85:
157:             matched_list.append({
158:                 "figma_node_id": node_id,
159:                 "figma_node_name": node_name,
160:                 "component_id": best_sig["component_id"],
161:                 "signature_id": best_sig["id"],
162:                 "confidence": round(highest_score, 4),
163:                 "matching_notes": f"Matched {best_sig['id']} with confidence {highest_score:.2f}"
164:             })
165:         else:
166:             # Unmatched or candidate warning
167:             highest_component = best_sig["component_id"] if best_sig else None
168:             reason = f"No signature matched with usable confidence. Best match: {best_sig['id'] if best_sig else 'None'} ({highest_score:.2f})"
169:             
170:             unmatched_list.append({
171:                 "figma_node_id": node_id,
172:                 "figma_node_name": node_name,
173:                 "highest_candidate_component": highest_component,
174:                 "highest_confidence": round(highest_score, 4),
175:                 "reason": reason
176:             })
177:             
178:             if is_strict:
179:                 blockers.append(f"Strict Mode Blocker: Node '{node_name}' ({node_id}) has no usable component match ({highest_score:.2f} < 0.85)")
180: 
181:     # Recurse children
182:     for child in node.get("children", []):
183:         walk_and_match(child, signatures, matched_list, unmatched_list, blockers, is_strict)
184: 
185: def main():
186:     parser = argparse.ArgumentParser(description="Component Matching CLI")
187:     parser.add_argument("--figma-bundle", required=True, help="Path to Figma node bundle JSON")
188:     parser.add_argument("--registry", default="knowledge-base/component-registry.json", help="Path to component registry JSON")
189:     parser.add_argument("--signatures", default="knowledge-base/component-signatures.json", help="Path to signatures JSON")
190:     parser.add_argument("--out-match-report", default="workspace/reports/component-match-report.json", help="Output path for match report")
191:     parser.add_argument("--out-sync-report", default="workspace/reports/component-sync-report.json", help="Output path for sync report")
192:     parser.add_argument("--strict", action="store_true", default=True, help="Enable strict mode matching enforcement")
193: 
194:     args = parser.parse_args()
195: 
196:     # Resolve paths relative to root if they are relative
197:     figma_path = args.figma_bundle if os.path.isabs(args.figma_bundle) else os.path.join(root_dir, args.figma_bundle)
198:     registry_path = args.registry if os.path.isabs(args.registry) else os.path.join(root_dir, args.registry)
199:     sigs_path = args.signatures if os.path.isabs(args.signatures) else os.path.join(root_dir, args.signatures)
200:     out_match_path = args.out_match_report if os.path.isabs(args.out_match_report) else os.path.join(root_dir, args.out_match_report)
201:     out_sync_path = args.out_sync_report if os.path.isabs(args.out_sync_report) else os.path.join(root_dir, args.out_sync_report)
202: 
203:     if not os.path.exists(figma_path):
204:         print(f"Error: Figma bundle not found at {figma_path}")
205:         sys.exit(1)
206:     if not os.path.exists(registry_path):
207:         print(f"Error: Registry not found at {registry_path}")
208:         sys.exit(1)
209:     if not os.path.exists(sigs_path):
210:         print(f"Error: Signatures not found at {sigs_path}")
211:         sys.exit(1)
212: 
213:     print(f"Loading Figma Bundle: {figma_path}")
214:     bundle = load_json(figma_path)
215:     registry = load_json(registry_path)
216:     signatures = load_json(sigs_path).get("signatures", [])
217: 
218:     matched_instances = []
219:     unmatched_instances = []
220:     blockers = []
221: 
222:     # Run recursive matching from figma tree root
223:     tree = bundle.get("tree", {})
224:     if tree:
225:         walk_and_match(tree, signatures, matched_instances, unmatched_instances, blockers, args.strict)
226: 
227:     status = "pass" if not blockers else "fail"
228: 
229:     # 1. Save Component Match Report
230:     match_report = {
231:       "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
232:       "matched_instances": matched_instances,
233:       "unmatched_instances": unmatched_instances,
234:       "status": status,
235:       "blockers": blockers
236:     }
237:     save_json(out_match_path, match_report)
238:     print(f"Saved Component Match Report to {out_match_path} (Status: {status})")
239: 
240:     # 2. Save Component Sync Report
241:     synced_components = list(set(m["component_id"] for m in matched_instances))
242:     
243:     # Identify out of sync components
244:     # A component is out of sync if there are active unmatched instances that matched it as highest candidate
245:     out_of_sync = []
246:     for unm in unmatched_instances:
247:         cand = unm.get("highest_candidate_component")
248:         if cand and cand not in [o["component_id"] for o in out_of_sync]:
249:             out_of_sync.append({
250:                 "component_id": cand,
251:                 "reason": unm["reason"]
252:             })
253:             
254:     sync_report = {
255:       "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
256:       "registry_version": "1.0.0",
257:       "total_components": len(registry.get("components", [])),
258:       "synced_components": synced_components,
259:       "out_of_sync_components": out_of_sync,
260:       "status": status,
261:       "errors": blockers
262:     }
263:     save_json(out_sync_path, sync_report)
264:     print(f"Saved Component Sync Report to {out_sync_path} (Status: {status})")
265: 
266:     if blockers:
267:         print(f"\nMatching failed with {len(blockers)} blocker(s):")
268:         for blk in blockers:
269:             print(f" - {blk}")
270:         sys.exit(1)
271:     else:
272:         print("\nComponent matching completed successfully. All components synced.")
273:         sys.exit(0)
274: 
275: if __name__ == "__main__":
276:     main()
