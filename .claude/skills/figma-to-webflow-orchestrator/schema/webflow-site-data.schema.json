{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mas-figma-webflow.local/schemas/figma-to-webflow-orchestrator/webflow-site-data.schema.json",
  "title": "Webflow Site Data Input",
  "description": "Input schema for init_workspace.py. Accepts one Webflow site object or an array of site objects returned by Webflow MCP data_sites_tool/get_site.",
  "oneOf": [
    { "$ref": "#/$defs/site" },
    {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/site" }
    }
  ],
  "$defs": {
    "site": {
      "type": "object",
      "additionalProperties": true,
      "anyOf": [
        { "required": ["id"] },
        { "required": ["siteId"] }
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "siteId": { "type": "string", "minLength": 1 },
        "shortName": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "displayName": { "type": "string", "minLength": 1 },
        "figmaFileKey": { "type": ["string", "null"] }
      }
    }
  }
}
