{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClientFirstBaselineContract",
  "type": "object",
  "required": ["meta", "variables", "classes", "excluded"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schemaVersion", "source", "baseline", "scope", "generatedAt"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "source": { "type": "string" },
        "baseline": { "type": "string" },
        "scope": { "type": "string", "enum": ["client-first-only"] },
        "generatedAt": { "type": "string" }
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "type", "value", "source", "editableInFigma", "syncPolicy"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["color", "number", "string", "boolean", "size", "font-weight", "font-family", "letter-spacing"]
          },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "source": {
            "type": "object",
            "required": ["selector", "property"],
            "properties": {
              "selector": { "type": "string" },
              "property": { "type": "string" }
            }
          },
          "editableInFigma": { "type": "boolean" },
          "syncPolicy": { "type": "string" }
        }
      }
    },
    "classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["selector", "type", "category", "properties", "breakpoints", "pseudoStates", "editableInFigma", "syncPolicy"],
        "properties": {
          "selector": { "type": "string" },
          "type": { "type": "string" },
          "category": { "type": "string" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "breakpoints": {
            "type": "object",
            "required": ["main", "medium", "small", "tiny"],
            "properties": {
              "main": { "type": "object" },
              "medium": { "type": "object" },
              "small": { "type": "object" },
              "tiny": { "type": "object" }
            }
          },
          "pseudoStates": { "type": "object" },
          "editableInFigma": { "type": "boolean" },
          "syncPolicy": { "type": "string" }
        }
      }
    },
    "excluded": {
      "type": "object",
      "required": ["webflowNativeSelectors", "nativeElementSelectors", "unsupportedSelectors"],
      "properties": {
        "webflowNativeSelectors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nativeElementSelectors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unsupportedSelectors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
