{
  "signatures_version": "2.0.0",
  "description": "Rules for identifying Webflow Symbols from Figma node names during the Semantic Tree translation phase.",
  "signatures": {
    "navbar": {
      "name_patterns": ["(?i)^nav", "(?i)navigation", "(?i)header"],
      "minimum_children": 1
    },
    "footer": {
      "name_patterns": ["(?i)^footer"],
      "minimum_children": 1
    },
    "hero": {
      "name_patterns": ["(?i)^hero", "(?i)header section"],
      "minimum_children": 2
    }
  }
}
