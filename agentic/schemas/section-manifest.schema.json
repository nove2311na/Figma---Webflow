{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Manifest Schema",
  "type": "object",
  "required": ["version", "chunks", "metadata"],
  "properties": {
    "version": { "type": "string" },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "filename", "figma_node_id", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "filename": { "type": "string" },
          "figma_node_id": { "type": "string" },
          "type": { "type": "string", "enum": ["nav", "section", "footer", "global-styles", "other"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["sliced_at", "total_chunks"],
      "properties": {
        "sliced_at": { "type": "string", "format": "date-time" },
        "total_chunks": { "type": "integer" }
      }
    }
  }
}