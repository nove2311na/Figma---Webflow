{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Figma Normalization Report Schema",
  "type": "object",
  "required": ["normalized_at", "source_node_bundle", "stats", "blockers", "warnings", "success"],
  "properties": {
    "normalized_at": { "type": "string", "format": "date-time" },
    "source_node_bundle": { "type": "string" },
    "stats": {
      "type": "object",
      "required": [
        "generic_names_resolved",
        "raw_colors_snapped",
        "raw_spacing_snapped",
        "layout_recovered",
        "repeated_subtrees_found",
        "blockers_count",
        "warnings_count"
      ],
      "properties": {
        "generic_names_resolved": { "type": "integer" },
        "raw_colors_snapped": { "type": "integer" },
        "raw_spacing_snapped": { "type": "integer" },
        "layout_recovered": { "type": "integer" },
        "repeated_subtrees_found": { "type": "integer" },
        "blockers_count": { "type": "integer" },
        "warnings_count": { "type": "integer" }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "reason"],
        "properties": {
          "node_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "reason"],
        "properties": {
          "node_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "success": { "type": "boolean" }
  }
}