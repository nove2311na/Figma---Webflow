{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Figma Node Bundle Schema",
  "type": "object",
  "required": ["node_id", "name", "tree", "styles", "metadata"],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "tree": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "children": { "type": "array" }
      },
      "required": ["id", "name", "type"]
    },
    "styles": {
      "type": "object",
      "properties": {
        "colors": { "type": "array" },
        "typography": { "type": "array" },
        "spacing": { "type": "array" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["extracted_at", "figma_file_version", "extractor_user"],
      "properties": {
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "figma_file_version": {
          "type": "string"
        },
        "extractor_user": {
          "type": "string"
        }
      }
    }
  }
}