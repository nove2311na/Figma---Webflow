{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Asset Manifest Schema",
  "type": "object",
  "required": ["version", "assets", "metadata"],
  "properties": {
    "version": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["figma_node_id", "filename", "role", "alt_text"],
        "properties": {
          "figma_node_id": { "type": "string" },
          "filename": { "type": "string" },
          "role": { "type": "string", "enum": ["informative", "decorative", "functional", "complex"] },
          "alt_text": { "type": "string" },
          "aria_hidden": { "type": "boolean" },
          "local_path": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["updated_at", "total_assets"],
      "properties": {
        "updated_at": { "type": "string", "format": "date-time" },
        "total_assets": { "type": "integer" }
      }
    }
  }
}