{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Figma Semantic Tree Schema",
  "type": "object",
  "required": ["node_id", "name", "semantic_tree", "metadata"],
  "properties": {
    "node_id": { "type": "string" },
    "name": { "type": "string" },
    "semantic_tree": {
      "$ref": "#/definitions/SemanticNode"
    },
    "metadata": {
      "type": "object",
      "required": ["resolved_at", "resolver_version", "confidence_score"],
      "properties": {
        "resolved_at": { "type": "string", "format": "date-time" },
        "resolver_version": { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    }
  },
  "definitions": {
    "SemanticNode": {
      "type": "object",
      "required": ["id", "name", "type", "role", "tag", "classes"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "role": { "type": "string" },
        "tag": { "type": "string" },
        "classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "styles": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "media": {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "enum": ["icon", "image", "vector", "none"] },
            "role": { "type": "string", "enum": ["informative", "decorative", "functional", "complex", "unknown"] },
            "alt_policy": { "type": "string" },
            "alt_text": { "type": "string" },
            "asset_ref": { "type": "string" }
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/SemanticNode" }
        }
      }
    }
  }
}