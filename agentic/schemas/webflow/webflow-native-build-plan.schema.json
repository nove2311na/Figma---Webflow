{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Webflow Native Build Plan Schema",
  "type": "object",
  "required": ["version", "target_site_id", "target_page_id", "operations", "metadata"],
  "properties": {
    "version": { "type": "string" },
    "target_site_id": { "type": "string" },
    "target_page_id": { "type": "string" },
    "target_branch": { "type": "string" },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "payload"],
        "properties": {
          "type": { "type": "string", "enum": ["create_class", "update_class", "create_element", "update_element", "move_element", "delete_element"] },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "node_id": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["compiled_at", "total_operations"],
      "properties": {
        "compiled_at": { "type": "string", "format": "date-time" },
        "total_operations": { "type": "integer" }
      }
    }
  }
}