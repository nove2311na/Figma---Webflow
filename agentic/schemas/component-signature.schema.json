{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentSignatureSchema",
  "type": "object",
  "required": ["signatures"],
  "properties": {
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "component_id", "name_pattern", "node_type", "layout_topology", "token_cluster", "repeated_patterns", "min_confidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "component_id": {
            "type": "string"
          },
          "name_pattern": {
            "type": "string"
          },
          "node_type": {
            "type": "string",
            "enum": ["INSTANCE", "FRAME", "TEXT", "RECTANGLE", "GROUP", "VECTOR"]
          },
          "layout_topology": {
            "type": "object",
            "required": ["min_children", "max_children", "children"],
            "properties": {
              "min_children": {
                "type": "integer"
              },
              "max_children": {
                "type": "integer"
              },
              "children": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["role", "node_types", "name_pattern", "min_count", "max_count"],
                  "properties": {
                    "role": {
                      "type": "string"
                    },
                    "node_types": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "name_pattern": {
                      "type": "string"
                    },
                    "min_count": {
                      "type": "integer"
                    },
                    "max_count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "token_cluster": {
            "type": "object",
            "required": ["classes"],
            "properties": {
              "classes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "css_properties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "repeated_patterns": {
            "type": ["object", "null"],
            "properties": {
              "item_role": {
                "type": "string"
              },
              "exact_repetition": {
                "type": "boolean"
              }
            }
          },
          "min_confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    }
  }
}