{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Figma Normalized Tree Schema",
  "type": "object",
  "required": ["node_id", "name", "normalized_tree", "metadata"],
  "properties": {
    "node_id": { "type": "string" },
    "name": { "type": "string" },
    "normalized_tree": {
      "$ref": "#/definitions/NormalizedNode"
    },
    "metadata": {
      "type": "object",
      "required": ["normalized_at", "figma_file_version", "extractor_user"],
      "properties": {
        "normalized_at": { "type": "string", "format": "date-time" },
        "figma_file_version": { "type": "string" },
        "extractor_user": { "type": "string" }
      }
    }
  },
  "definitions": {
    "NormalizedNode": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "original_name": { "type": "string" },
        "type": { "type": "string" },
        "classes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "styles": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "layout": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["flex", "grid", "none"] },
            "direction": { "type": "string", "enum": ["horizontal", "vertical", "none"] },
            "spacing": { "type": "string" },
            "padding": { "type": "string" },
            "wrap": { "type": "boolean" }
          }
        },
        "candidate_component": { "type": "boolean" },
        "component_name": { "type": "string" },
        "ambiguous_media": { "type": "boolean" },
        "media_kind": { "type": "string", "enum": ["icon", "image", "vector", "none"] },
        "normalization_notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/NormalizedNode" }
        }
      }
    }
  }
}