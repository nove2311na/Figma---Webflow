{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentSyncReportSchema",
  "type": "object",
  "required": ["timestamp", "registry_version", "total_components", "synced_components", "out_of_sync_components", "status", "errors"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "registry_version": {
      "type": "string"
    },
    "total_components": {
      "type": "integer"
    },
    "synced_components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_sync_components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "reason"],
        "properties": {
          "component_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}