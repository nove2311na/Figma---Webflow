{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "docs/ai/repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "showLineNumbers": true
  },
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      "venv/**",
      ".venv/**",
      "node_modules/**",
      "workspace/**",
      "archives/**",
      "*.log",
      "*.tmp",
      ".git/**",
      ".gemini/**",
      "repomix-output.xml",
      "docs/ai/repomix-output.xml",
      ".claude/**",
      ".user_bugs-log/**",
      ".user_guides/**",
      ".user_versions/**"
    ]
  }
}
